        .btn-delete-modern:hover:not(:disabled) {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            box-shadow: 0 6px 8px -1px rgba(220, 38, 38, 0.3);
            transform: translateY(-1px);
        }

        .btn-delete-modern:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-delete-modern:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .spinner-delete {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>

    @code {
        private List<UserLicenseInfo>? users;
        private bool isLoading = true;
        private bool showModal = false;
        private bool showDeleteConfirmation = false;
        private UserLicenseInfo? selectedUser;
        private UserLicenseInfo? userToDelete;
        private GenerateLicenseRequest licenseRequest = new();
        private string errorMessage = string.Empty;
        private string generatedLicenseKey = string.Empty;
        private bool isGenerating = false;
        private bool isDeleting = false;

        protected override async Task OnInitializedAsync()
        {
            // Suscribirse a cambios de estado de autenticación
            AuthState.OnAuthStateChanged += StateHasChanged;

            // Si no está autenticado, redirigir al login
            if (!AuthState.IsAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }

            await LoadUsers();
        }

        public void Dispose()
        {
            // Desuscribirse cuando se destruya el componente
            AuthState.OnAuthStateChanged -= StateHasChanged;
        }

        private async Task LoadUsers()
        {
            isLoading = true;
            try
            {
                var response = await ApiService.GetAllUsersWithLicensesAsync();
                users = response?.Users;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading users: {ex.Message}");
            }
            finally
            {
                isLoading = false;
            }
        }

        private void ShowGenerateLicenseModal(UserLicenseInfo user)
        {
            selectedUser = user;
            licenseRequest = new GenerateLicenseRequest
            {
                UserId = user.UserId,
                LicenseType = "Basic",
                DurationMonths = 12,
                CompanyName = user.CompanyName
            };
            generatedLicenseKey = string.Empty;
            errorMessage = string.Empty;
            showModal = true;
        }

        private async Task GenerateLicense()
        {
            isGenerating = true;
            errorMessage = string.Empty;
            generatedLicenseKey = string.Empty;

            try
            {
                var response = await ApiService.GenerateLicenseAsync(licenseRequest);

                if (response?.Success == true && !string.IsNullOrEmpty(response.LicenseKey))
                {
                    generatedLicenseKey = response.LicenseKey;
                    await LoadUsers(); // Recargar lista de usuarios
                }
                else
                {
                    errorMessage = response?.Message ?? "Error al generar la licencia";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error: {ex.Message}";
            }
            finally
            {
                isGenerating = false;
            }
        }

        private async Task CopyLicenseKey()
        {
            // En un escenario real, usarías JavaScript interop para copiar al portapapeles
            // Por ahora, solo mostramos el mensaje
            Console.WriteLine($"Licencia copiada: {generatedLicenseKey}");
        }

        private void CloseModal()
        {
            showModal = false;
            selectedUser = null;
            generatedLicenseKey = string.Empty;
            errorMessage = string.Empty;
        }

        private void ShowDeleteLicenseConfirmation(UserLicenseInfo user)
        {
            userToDelete = user;
            showDeleteConfirmation = true;
        }

        private void CancelDelete()
        {
            showDeleteConfirmation = false;
            userToDelete = null;
        }

        private async Task DeleteLicense()
        {
            if (userToDelete == null || !userToDelete.LicenseId.HasValue)
                return;

            isDeleting = true;
            try
            {
                // IMPORTANTE: Ahora usamos DeleteLicenseAsync para ELIMINAR FÍSICAMENTE de la base de datos
                // Esto previene que claves eliminadas puedan ser reutilizadas
                var success = await ApiService.DeleteLicenseAsync(userToDelete.LicenseId.Value);

                if (success)
                {
                    // Recargar la lista de usuarios
                    await LoadUsers();
                    showDeleteConfirmation = false;
                    userToDelete = null;
                }
                else
                {
                    errorMessage = "No se pudo eliminar la licencia de la base de datos";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error eliminando licencia: {ex.Message}";
            }
            finally
            {
                isDeleting = false;
            }
        }

        private string GetLicenseClass(string? licenseType)
        {
            return licenseType?.ToLower() switch
            {
                "trial" => "trial",
                "basic" => "basic",
                "premium" => "premium",
                "enterprise" => "enterprise",
                _ => ""
            };
        }
    }
}
