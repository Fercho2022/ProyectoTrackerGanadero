@page "/licenses"
@using AdminPanelLicenses.Services
@inject AdminApiService ApiService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Licencias - Admin Panel</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <p>Redirigiendo a login...</p>
}
else
{
    <div class="dashboard-container">
        <div class="dashboard-header">
            <div>
                <h1>📋 Gestión de Licencias</h1>
                <p>Bienvenido, <strong>@AuthState.Username</strong></p>
            </div>
            <button class="btn btn-secondary" @onclick="HandleLogout">
                Cerrar Sesión
            </button>
        </div>

        @if (isLoading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
                <p>Cargando estadísticas...</p>
            </div>
        }
        else if (stats != null)
        {
            <div class="stats-grid">
                <div class="stat-card total">
                    <div class="stat-icon">👥</div>
                    <div class="stat-info">
                        <div class="stat-value">@stats.TotalUsers</div>
                        <div class="stat-label">Usuarios Totales</div>
                    </div>
                </div>

                <div class="stat-card active">
                    <div class="stat-icon">✅</div>
                    <div class="stat-info">
                        <div class="stat-value">@stats.ActiveLicenses</div>
                        <div class="stat-label">Licencias Activas</div>
                    </div>
                </div>

                <div class="stat-card trial">
                    <div class="stat-icon">🔄</div>
                    <div class="stat-info">
                        <div class="stat-value">@stats.TrialLicenses</div>
                        <div class="stat-label">Licencias Trial</div>
                    </div>
                </div>

                <div class="stat-card expired">
                    <div class="stat-icon">⚠️</div>
                    <div class="stat-info">
                        <div class="stat-value">@stats.ExpiredLicenses</div>
                        <div class="stat-label">Licencias Expiradas</div>
                    </div>
                </div>
            </div>

            <div class="quick-actions">
                <h2>Acciones Rápidas</h2>
                <div class="actions-grid">
                    <button class="action-card" @onclick="NavigateToUsers">
                        <div class="action-icon">👤</div>
                        <div class="action-title">Gestionar Usuarios</div>
                        <div class="action-desc">Ver y administrar usuarios y licencias</div>
                    </button>

                    <button class="action-card" @onclick="LoadStats">
                        <div class="action-icon">🔄</div>
                        <div class="action-title">Actualizar Estadísticas</div>
                        <div class="action-desc">Recargar los datos del dashboard</div>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="error-message">
                <p>❌ Error cargando estadísticas. Verifica que la API esté activa.</p>
                <button class="btn btn-primary" @onclick="LoadStats">Reintentar</button>
            </div>
        }
    </div>

    <style>
        .dashboard-container {
            padding: 24px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            padding-bottom: 16px;
            border-bottom: 2px solid #e0e0e0;
        }

        .dashboard-header h1 {
            font-size: 32px;
            color: #333;
            margin: 0;
        }

        .dashboard-header p {
            color: #666;
            margin: 8px 0 0 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            gap: 16px;
            align-items: center;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        }

        .stat-card.total {
            border-left: 4px solid #667eea;
        }

        .stat-card.active {
            border-left: 4px solid #48bb78;
        }

        .stat-card.trial {
            border-left: 4px solid #ed8936;
        }

        .stat-card.expired {
            border-left: 4px solid #f56565;
        }

        .stat-icon {
            font-size: 48px;
        }

        .stat-info {
            flex: 1;
        }

        .stat-value {
            font-size: 36px;
            font-weight: bold;
            color: #333;
        }

        .stat-label {
            font-size: 14px;
            color: #666;
            margin-top: 4px;
        }

        .quick-actions {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .quick-actions h2 {
            font-size: 24px;
            color: #333;
            margin-bottom: 20px;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 16px;
        }

        .action-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 20px;
            text-align: left;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .action-card:hover {
            transform: scale(1.05);
        }

        .action-icon {
            font-size: 32px;
            margin-bottom: 12px;
        }

        .action-title {
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .action-desc {
            font-size: 14px;
            opacity: 0.9;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-secondary {
            background: #e0e0e0;
            color: #333;
        }

        .btn-secondary:hover {
            background: #d0d0d0;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

        .loading-container {
            text-align: center;
            padding: 60px 20px;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .error-message {
            background: #fee;
            border: 1px solid #fcc;
            border-radius: 8px;
            padding: 24px;
            text-align: center;
        }

        .error-message p {
            color: #c33;
            font-size: 18px;
            margin-bottom: 16px;
        }
    </style>

    @code {
        private LicenseStats? stats;
        private bool isLoading = true;

        protected override async Task OnInitializedAsync()
        {
            // Suscribirse a cambios de estado de autenticación
            AuthState.OnAuthStateChanged += StateHasChanged;

            // Si no está autenticado, redirigir al login
            if (!AuthState.IsAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
            }
            else
            {
                await LoadStats();
            }
        }

        public void Dispose()
        {
            // Desuscribirse cuando se destruya el componente
            AuthState.OnAuthStateChanged -= StateHasChanged;
        }

        private async Task LoadStats()
        {
            isLoading = true;
            try
            {
                var response = await ApiService.GetLicenseStatsAsync();
                stats = response?.Stats;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading stats: {ex.Message}");
            }
            finally
            {
                isLoading = false;
            }
        }

        private void NavigateToUsers()
        {
            try
            {
                Console.WriteLine("Navigating to /users");
                Navigation.NavigateTo("/users", forceLoad: true);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error navigating to users: {ex.Message}");
            }
        }

        private void HandleLogout()
        {
            AuthState.SetUnauthenticated();
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    }
}
