@page "/settings"
@using TrackerGanaderoBlazorHibridMaui.Services
@using System.ComponentModel.DataAnnotations
@inject TrackerManagementService TrackerManagementService
@inject LicenseService LicenseService
@inject IJSRuntime JSRuntime

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-primary">⚙️ Configuración del Sistema</h2>
                <button class="btn btn-outline-primary btn-sm" @onclick="RefreshAll">
                    <i class="fas fa-sync-alt me-2"></i>Actualizar
                </button>
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2">Cargando configuración...</p>
        </div>
    }
    else
    {
        <!-- License Management Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-key me-2"></i>Gestión de Licencias
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (_customerInfo == null || !_customerInfo.HasCustomer)
                        {
                            <!-- License Activation Form -->
                            <div class="alert alert-info">
                                <h6 class="alert-heading">Active su licencia</h6>
                                <p class="mb-3">Para gestionar trackers, debe activar una licencia válida proporcionada por el desarrollador.</p>
                                <EditForm Model="_activationModel" OnValidSubmit="ActivateLicense">
                                    <DataAnnotationsValidator />

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-key"></i>
                                        </span>
                                        <InputText @bind-Value="_activationModel.LicenseKey"
                                                   class="form-control"
                                                   placeholder="TG-YYYY-XXXX-XXXX-XXXX"
                                                   disabled="@_isActivating" />
                                        <button type="submit" class="btn btn-primary" disabled="@_isActivating">
                                            @if (_isActivating)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2"></span>
                                            }
                                            Activar
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => _activationModel.LicenseKey)" class="text-danger mt-1" />
                                </EditForm>
                            </div>
                        }
                        else
                        {
                            <!-- Customer Info Display -->
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="text-muted">Información del Cliente</h6>
                                    <p><strong>Empresa:</strong> @_customerInfo.Customer.CompanyName</p>
                                    <p><strong>Plan:</strong> <span class="badge bg-primary">@_customerInfo.Customer.Plan</span></p>
                                    <p><strong>Estado:</strong>
                                        <span class="badge @(_customerInfo.Customer.IsSubscriptionActive ? "bg-success" : "bg-danger")">
                                            @(_customerInfo.Customer.IsSubscriptionActive ? "Activo" : "Inactivo")
                                        </span>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-muted">Límites y Uso</h6>
                                    <div class="mb-2">
                                        <small class="text-muted">Trackers</small>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar" role="progressbar"
                                                 style="width: @(GetProgressPercentage(_customerInfo.Customer.ActiveTrackers, _customerInfo.Customer.TrackerLimit))%">
                                                @_customerInfo.Customer.ActiveTrackers / @_customerInfo.Customer.TrackerLimit
                                            </div>
                                        </div>
                                    </div>
                                    @if (_customerInfo.ActiveLicense != null)
                                    {
                                        <p><strong>Licencia expira:</strong> @_customerInfo.ActiveLicense.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy")</p>
                                        @if (_customerInfo.ActiveLicense.DaysUntilExpiration <= 30)
                                        {
                                            <div class="alert alert-warning alert-sm">
                                                ⚠️ Su licencia expira en @_customerInfo.ActiveLicense.DaysUntilExpiration días
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_licenseMessage))
                        {
                            <div class="alert @(_licenseSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show">
                                @_licenseMessage
                                <button type="button" class="btn-close" @onclick="ClearLicenseMessage"></button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_customerInfo?.HasCustomer == true)
        {
            <!-- Tracker Management Section -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fas fa-satellite-dish me-2"></i>Gestión de Trackers
                            </h5>
                            <div>
                                <button class="btn btn-light btn-sm me-2" @onclick="DetectNewTrackers">
                                    <i class="fas fa-search me-1"></i>Detectar Nuevos
                                </button>
                                <button class="btn btn-outline-light btn-sm" @onclick="RefreshTrackers">
                                    <i class="fas fa-sync-alt"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body">

                            <!-- Tracker Tabs -->
                            <ul class="nav nav-tabs mb-3" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link @(_activeTab == "my-trackers" ? "active" : "")"
                                            @onclick="() => SetActiveTab(\"my-trackers\")">
                                        <i class="fas fa-list me-1"></i>
                                        Mis Trackers (@(_myTrackers?.Count ?? 0))
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link @(_activeTab == "available" ? "active" : "")"
                                            @onclick="() => SetActiveTab(\"available\")">
                                        <i class="fas fa-plus-circle me-1"></i>
                                        Disponibles (@(_availableTrackers?.Count ?? 0))
                                    </button>
                                </li>
                                @if (_newTrackers?.Any() == true)
                                {
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link @(_activeTab == "detected" ? "active" : "") text-warning"
                                                @onclick="() => SetActiveTab(\"detected\")">
                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                            Detectados (@_newTrackers.Count)
                                        </button>
                                    </li>
                                }
                            </ul>

                            <!-- Tab Content -->
                            <div class="tab-content">

                                @* My Trackers Tab *@
                                @if (_activeTab == "my-trackers")
                                {
                                    @if (_myTrackers?.Any() == true)
                                    {
                                        <div class="row g-3">
                                            @foreach (var tracker in _myTrackers)
                                            {
                                                <div class="col-md-6 col-lg-4">
                                                    <div class="card h-100 border-success">
                                                        <div class="card-header d-flex justify-content-between align-items-center">
                                                            <strong>@tracker.CustomName ?? tracker.TrackerName</strong>
                                                            <span class="badge @(tracker.IsOnline ? "bg-success" : "bg-secondary")">
                                                                @(tracker.IsOnline ? "En línea" : "Desconectado")
                                                            </span>
                                                        </div>
                                                        <div class="card-body">
                                                            <p class="card-text small">
                                                                <strong>Device ID:</strong> @tracker.DeviceId<br>
                                                                <strong>Modelo:</strong> @tracker.Model<br>
                                                                <strong>Batería:</strong> @tracker.BatteryLevel%<br>
                                                                <strong>Última señal:</strong> @tracker.LastSeen.ToLocalTime().ToString("dd/MM HH:mm")<br>
                                                                @if (!string.IsNullOrEmpty(tracker.Notes))
                                                                {
                                                                    <strong>Notas:</strong> @tracker.Notes<br>
                                                                }
                                                            </p>
                                                        </div>
                                                        <div class="card-footer">
                                                            <button class="btn btn-outline-danger btn-sm"
                                                                    @onclick="() => UnassignTracker(tracker.Id)">
                                                                <i class="fas fa-unlink me-1"></i>Desasignar
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-4">
                                            <i class="fas fa-satellite-dish fa-3x mb-3 opacity-50"></i>
                                            <h5>No hay trackers asignados</h5>
                                            <p>Agregue trackers desde la pestaña "Disponibles"</p>
                                        </div>
                                    }
                                }

                                @* Available Trackers Tab *@
                                @if (_activeTab == "available")
                                {
                                    @if (_customerInfo.Customer.CanAddMoreTrackers && _availableTrackers?.Any() == true)
                                    {
                                        <div class="row g-3">
                                            @foreach (var tracker in _availableTrackers)
                                            {
                                                <div class="col-md-6 col-lg-4">
                                                    <div class="card h-100">
                                                        <div class="card-header d-flex justify-content-between align-items-center">
                                                            <strong>@tracker.Name</strong>
                                                            <span class="badge @(tracker.IsOnline ? "bg-success" : "bg-secondary")">
                                                                @(tracker.IsOnline ? "En línea" : "Desconectado")
                                                            </span>
                                                        </div>
                                                        <div class="card-body">
                                                            <p class="card-text small">
                                                                <strong>Device ID:</strong> @tracker.DeviceId<br>
                                                                <strong>Modelo:</strong> @tracker.Model<br>
                                                                @if (!string.IsNullOrEmpty(tracker.Manufacturer))
                                                                {
                                                                    <strong>Fabricante:</strong> @tracker.Manufacturer<br>
                                                                }
                                                                <strong>Batería:</strong> @tracker.BatteryLevel%<br>
                                                                <strong>Última señal:</strong> @tracker.LastSeen.ToLocalTime().ToString("dd/MM HH:mm")
                                                            </p>
                                                        </div>
                                                        <div class="card-footer">
                                                            <button class="btn btn-primary btn-sm"
                                                                    @onclick="() => AssignTracker(tracker.Id, tracker.DeviceId)">
                                                                <i class="fas fa-plus me-1"></i>Asignar
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (!_customerInfo.Customer.CanAddMoreTrackers)
                                    {
                                        <div class="alert alert-warning">
                                            <h6>Límite alcanzado</h6>
                                            <p class="mb-0">Ha alcanzado el límite de @_customerInfo.Customer.TrackerLimit trackers para su plan actual.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-4">
                                            <i class="fas fa-search fa-3x mb-3 opacity-50"></i>
                                            <h5>No hay trackers disponibles</h5>
                                            <p>Use "Detectar Nuevos" para buscar trackers en la red</p>
                                        </div>
                                    }
                                }

                                @* Detected Trackers Tab *@
                                @if (_activeTab == "detected" && _newTrackers?.Any() == true)
                                {
                                    <div class="alert alert-info">
                                        <h6>Nuevos trackers detectados</h6>
                                        <p class="mb-0">Estos dispositivos están enviando señales pero no están registrados en el sistema.</p>
                                    </div>

                                    <div class="row g-3">
                                        @foreach (var tracker in _newTrackers)
                                        {
                                            <div class="col-md-6 col-lg-4">
                                                <div class="card h-100 border-warning">
                                                    <div class="card-header bg-warning">
                                                        <strong>@tracker.Name</strong>
                                                    </div>
                                                    <div class="card-body">
                                                        <p class="card-text small">
                                                            <strong>Device ID:</strong> @tracker.DeviceId<br>
                                                            <strong>Modelo:</strong> @tracker.Model<br>
                                                            <strong>Estado:</strong> @tracker.Status<br>
                                                            <strong>Última señal:</strong> @tracker.LastSeen.ToLocalTime().ToString("dd/MM HH:mm")
                                                        </p>
                                                    </div>
                                                    <div class="card-footer">
                                                        <button class="btn btn-warning btn-sm"
                                                                @onclick="() => RegisterTracker(tracker.DeviceId, tracker.Model)">
                                                            <i class="fas fa-plus-circle me-1"></i>Registrar y Asignar
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (!string.IsNullOrEmpty(_trackerMessage))
    {
        <div class="alert @(_trackerSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @_trackerMessage
            <button type="button" class="btn-close" @onclick="ClearTrackerMessage"></button>
        </div>
    }
</div>

@code {
    private bool _isLoading = true;
    private bool _isActivating = false;
    private string _activeTab = "my-trackers";

    // License Management
    private LicenseActivationModel _activationModel = new();
    private CustomerInfoDto? _customerInfo;
    private string? _licenseMessage;
    private bool _licenseSuccess = false;

    // Tracker Management
    private List<CustomerTrackerDto>? _myTrackers;
    private List<TrackerDiscoveryDto>? _availableTrackers;
    private List<TrackerDiscoveryDto>? _newTrackers;
    private string? _trackerMessage;
    private bool _trackerSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomerInfo();

        if (_customerInfo?.HasCustomer == true)
        {
            await LoadTrackerData();
        }

        _isLoading = false;
    }

    private async Task LoadCustomerInfo()
    {
        try
        {
            _customerInfo = await LicenseService.GetCustomerInfoAsync();
        }
        catch (Exception ex)
        {
            _licenseMessage = "Error cargando información del cliente";
            _licenseSuccess = false;
        }
    }

    private async Task LoadTrackerData()
    {
        try
        {
            var myTrackersTask = TrackerManagementService.GetMyTrackersAsync();
            var availableTrackersTask = TrackerManagementService.GetAvailableTrackersAsync();

            await Task.WhenAll(myTrackersTask, availableTrackersTask);

            _myTrackers = await myTrackersTask;
            var availableTrackerResults = await TrackerManagementService.GetDetectedTrackersAsync();
            _availableTrackers = availableTrackerResults;
        }
        catch (Exception ex)
        {
            _trackerMessage = "Error cargando información de trackers";
            _trackerSuccess = false;
        }
    }

    private async Task ActivateLicense()
    {
        _isActivating = true;

        try
        {
            var result = await LicenseService.ActivateLicenseAsync(_activationModel.LicenseKey);

            if (result.IsSuccess)
            {
                _licenseMessage = result.Message ?? "Licencia activada exitosamente";
                _licenseSuccess = true;
                _activationModel.LicenseKey = "";

                // Recargar información
                await LoadCustomerInfo();
                if (_customerInfo?.HasCustomer == true)
                {
                    await LoadTrackerData();
                }
            }
            else
            {
                _licenseMessage = result.Message ?? "Error activando la licencia";
                _licenseSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _licenseMessage = "Error interno activando la licencia";
            _licenseSuccess = false;
        }
        finally
        {
            _isActivating = false;
        }
    }

    private async Task DetectNewTrackers()
    {
        try
        {
            var result = await TrackerManagementService.DetectNewTrackersAsync();
            _newTrackers = result?.NewTrackers;

            if (_newTrackers?.Any() == true)
            {
                _activeTab = "detected";
                _trackerMessage = $"Se detectaron {_newTrackers.Count} nuevos trackers";
                _trackerSuccess = true;
            }
            else
            {
                _trackerMessage = "No se detectaron nuevos trackers";
                _trackerSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = "Error detectando nuevos trackers";
            _trackerSuccess = false;
        }
    }

    private async Task AssignTracker(int trackerId, string deviceId)
    {
        try
        {
            var result = await TrackerManagementService.AssignTrackerAsync(trackerId);

            if (result.IsSuccess)
            {
                _trackerMessage = $"Tracker {deviceId} asignado exitosamente";
                _trackerSuccess = true;
                await LoadTrackerData();
                _activeTab = "my-trackers";
            }
            else
            {
                _trackerMessage = result.Message ?? "Error asignando el tracker";
                _trackerSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = "Error interno asignando el tracker";
            _trackerSuccess = false;
        }
    }

    private async Task UnassignTracker(int customerTrackerId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro que desea desasignar este tracker?");
        if (!confirmed) return;

        try
        {
            var result = await TrackerManagementService.UnassignTrackerAsync(customerTrackerId);

            if (result.IsSuccess)
            {
                _trackerMessage = "Tracker desasignado exitosamente";
                _trackerSuccess = true;
                await LoadTrackerData();
            }
            else
            {
                _trackerMessage = result.Message ?? "Error desasignando el tracker";
                _trackerSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = "Error interno desasignando el tracker";
            _trackerSuccess = false;
        }
    }

    private async Task RegisterTracker(string deviceId, string? model)
    {
        try
        {
            var result = await TrackerManagementService.RegisterDetectedTrackerAsync(deviceId, model, true);

            if (result.IsSuccess)
            {
                _trackerMessage = result.Assigned
                    ? $"Tracker {deviceId} registrado y asignado automáticamente"
                    : $"Tracker {deviceId} registrado exitosamente";
                _trackerSuccess = true;

                await LoadTrackerData();
                await DetectNewTrackers(); // Refresh detected trackers
                _activeTab = "my-trackers";
            }
            else
            {
                _trackerMessage = result.Message ?? "Error registrando el tracker";
                _trackerSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = "Error interno registrando el tracker";
            _trackerSuccess = false;
        }
    }

    private async Task RefreshTrackers()
    {
        if (_customerInfo?.HasCustomer == true)
        {
            await LoadTrackerData();
        }
    }

    private async Task RefreshAll()
    {
        _isLoading = true;
        await LoadCustomerInfo();
        if (_customerInfo?.HasCustomer == true)
        {
            await LoadTrackerData();
        }
        _isLoading = false;
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    private void ClearLicenseMessage()
    {
        _licenseMessage = null;
    }

    private void ClearTrackerMessage()
    {
        _trackerMessage = null;
    }

    private double GetProgressPercentage(int current, int max)
    {
        if (max == 0) return 0;
        return Math.Min((double)current / max * 100, 100);
    }

    // Models
    public class LicenseActivationModel
    {
        [Required(ErrorMessage = "La clave de licencia es requerida")]
        public string LicenseKey { get; set; } = "";
    }

    // DTO Classes - from services
    public class CustomerInfoDto
    {
        public int Id { get; set; }
        public string? CompanyName { get; set; }
        public string? Plan { get; set; }
        public int TrackerLimit { get; set; }
        public string? Status { get; set; }
        public int CurrentTrackerCount { get; set; }
        public bool CanAddMoreTrackers { get; set; }
        public bool HasCustomer => Id > 0;
    }

    public class CustomerTrackerDto
    {
        public int Id { get; set; }
        public int TrackerId { get; set; }
        public string? TrackerName { get; set; }
        public string? DeviceId { get; set; }
        public int? FarmId { get; set; }
        public string? FarmName { get; set; }
        public string? AnimalName { get; set; }
        public string? Status { get; set; }
        public DateTime AssignedAt { get; set; }
    }

    public class TrackerDiscoveryDto
    {
        public string? DeviceId { get; set; }
        public DateTime FirstSeen { get; set; }
        public DateTime LastSeen { get; set; }
        public int SignalCount { get; set; }
        public double? LastLatitude { get; set; }
        public double? LastLongitude { get; set; }
    }
}

<style>
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .progress {
        background-color: #e9ecef;
    }

    .alert-sm {
        padding: 0.5rem 0.75rem;
        margin-bottom: 0.5rem;
    }

    .opacity-50 {
        opacity: 0.5;
    }

    .nav-tabs .nav-link {
        border: 1px solid transparent;
        border-bottom: none;
    }

    .nav-tabs .nav-link.active {
        background-color: #fff;
        border-color: #dee2e6 #dee2e6 #fff;
    }

    .badge {
        font-size: 0.75em;
    }
</style>