    private string GetRecordTypeBadgeColor(string recordType)
    {
        return recordType.ToLower() switch
        {
            "vaccination" => "success",
            "treatment" => "warning",
            "surgery" => "danger",
            "checkup" => "info",
            _ => "secondary"
        };
    }

    private string GetRecordTypeDisplayName(string recordType)
    {
        return recordType.ToLower() switch
        {
            "vaccination" => "Vacunación",
            "treatment" => "Tratamiento",
            "surgery" => "Cirugía",
            "checkup" => "Revisión",
            "other" => "Otro",
            _ => recordType
        };
    }
