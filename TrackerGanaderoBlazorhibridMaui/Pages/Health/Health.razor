@page "/health"
@using TrackerGanaderoBlazorHibridMaui.Models
@using TrackerGanaderoBlazorHibridMaui.Services
@using static TrackerGanaderoBlazorHibridMaui.Services.HealthService
@inject AnimalService AnimalService
@inject HealthService HealthService
@inject FarmService FarmService
@inject HttpService HttpService

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">🏥 Control Sanitario</h2>
                    <p class="text-muted">Gestión de registros veterinarios y tratamientos</p>
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select" @onchange="OnFarmFilterChanged">
                        <option value="">Todas las granjas</option>
                        @if (_farms != null)
                        {
                            @foreach (var farm in _farms)
                            {
                                <option value="@farm.Id">@farm.Name</option>
                            }
                        }
                    </select>
                    <select class="form-select" @onchange="OnAnimalFilterChanged">
                        <option value="">Todos los animales</option>
                        @if (_filteredAnimals != null)
                        {
                            @foreach (var animal in _filteredAnimals)
                            {
                                <option value="@animal.Id">@animal.Name (@animal.Tag)</option>
                            }
                        }
                    </select>
                    <button class="btn btn-primary" @onclick="ShowAddRecordModal">
                        <i class="fas fa-plus"></i> Nuevo Registro
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Health Overview Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_healthyCount</h4>
                            <p class="mb-0">Animales Saludables</p>
                        </div>
                        <i class="fas fa-heart fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_monitoringCount</h4>
                            <p class="mb-0">En Observación</p>
                        </div>
                        <i class="fas fa-eye fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_sickCount</h4>
                            <p class="mb-0">Requieren Atención</p>
                        </div>
                        <i class="fas fa-stethoscope fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_totalRecords</h4>
                            <p class="mb-0">Registros Totales</p>
                        </div>
                        <i class="fas fa-file-medical fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-3">
        <div class="col-md-4">
            <select class="form-select" @onchange="OnRecordTypeFilterChanged">
                <option value="">Todos los tipos</option>
                <option value="vaccination">Vacunación</option>
                <option value="treatment">Tratamiento</option>
                <option value="checkup">Revisión</option>
                <option value="surgery">Cirugía</option>
                <option value="other">Otro</option>
            </select>
        </div>
        <div class="col-md-4">
            <input type="date" class="form-control" @onchange="OnDateFilterChanged" />
        </div>
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Buscar en registros..."
                       @bind="_searchTerm" @oninput="OnSearchChanged" />
            </div>
        </div>
    </div>

    <!-- Health Records Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Registros Sanitarios (@_filteredRecords.Count)</h5>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshRecords">
                                <i class="fas fa-sync-alt"></i> Actualizar
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="ExportRecords">
                                <i class="fas fa-download"></i> Exportar
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (_isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3">Cargando registros...</p>
                        </div>
                    }
                    else if (_filteredRecords.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Animal</th>
                                        <th>Granja</th>
                                        <th>Tipo</th>
                                        <th>Descripción</th>
                                        <th>Veterinario</th>
                                        <th>Tratamiento</th>
                                        <th>Costo</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var record in _filteredRecords.OrderByDescending(r => r.RecordDate))
                                    {
                                        <tr>
                                            <td>
                                                <div>
                                                    <strong>@record.RecordDate.ToString("dd/MM/yyyy")</strong>
                                                    <br />
                                                    <small class="text-muted">@record.RecordDate.ToString("HH:mm")</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@record.AnimalTag</strong>
                                                    <br />
                                                    <small class="text-muted">@record.AnimalName</small>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@record.FarmName</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-@GetRecordTypeBadgeColor(record.RecordType)">
                                                    @GetRecordTypeDisplayName(record.RecordType)
                                                </span>
                                            </td>
                                            <td>
                                                <div title="@record.Description">
                                                    @(record.Description.Length > 50
                                                        ? record.Description.Substring(0, 50) + "..."
                                                        : record.Description)
                                                </div>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(record.VeterinarianName))
                                                {
                                                    <span>@record.VeterinarianName</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No especificado</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(record.Treatment))
                                                {
                                                    <div title="@record.Treatment">
                                                        @(record.Treatment.Length > 30
                                                            ? record.Treatment.Substring(0, 30) + "..."
                                                            : record.Treatment)
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (record.Cost.HasValue)
                                                {
                                                    <span class="fw-bold">$@record.Cost.Value.ToString("N2")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" @onclick="() => ViewRecordDetails(record)" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary" @onclick="() => EditRecord(record)" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => DeleteRecord(record)" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-file-medical fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No se encontraron registros</h5>
                            <p class="text-muted">Agrega el primer registro sanitario o ajusta los filtros</p>
                            <button class="btn btn-primary" @onclick="ShowAddRecordModal">
                                <i class="fas fa-plus"></i> Nuevo Registro
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Record Modal -->
<div class="modal fade @(_showModal ? "show d-block" : "")" tabindex="-1" style="@(_showModal ? "background: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(_editingRecord != null ? "Editar Registro Sanitario" : "Nuevo Registro Sanitario")
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <EditForm Model="@_recordForm" OnValidSubmit="@SaveRecord">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Animal *</label>
                                <InputSelect class="form-select" @bind-Value="_recordForm.AnimalId">
                                    <option value="0">Seleccionar animal</option>
                                    @if (_filteredAnimals != null)
                                    {
                                        @foreach (var animal in _filteredAnimals)
                                        {
                                            <option value="@animal.Id">@animal.Name (@animal.Tag)</option>
                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => _recordForm.AnimalId)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Tipo de Registro *</label>
                                <InputSelect class="form-select" @bind-Value="_recordForm.RecordType">
                                    <option value="">Seleccionar tipo</option>
                                    <option value="vaccination">Vacunación</option>
                                    <option value="treatment">Tratamiento</option>
                                    <option value="checkup">Revisión</option>
                                    <option value="surgery">Cirugía</option>
                                    <option value="other">Otro</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _recordForm.RecordType)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Fecha y Hora *</label>
                                <InputDate class="form-control" @bind-Value="_recordForm.RecordDate" />
                                <ValidationMessage For="@(() => _recordForm.RecordDate)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Veterinario</label>
                                <InputText class="form-control" @bind-Value="_recordForm.VeterinarianName" placeholder="Nombre del veterinario" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción *</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="_recordForm.Description" placeholder="Descripción detallada del procedimiento o condición" />
                        <ValidationMessage For="@(() => _recordForm.Description)" />
                    </div>

                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Tratamiento</label>
                                <InputTextArea class="form-control" rows="2" @bind-Value="_recordForm.Treatment" placeholder="Tratamiento aplicado o recomendado" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Costo</label>
                                <InputNumber class="form-control" @bind-Value="_recordForm.Cost" placeholder="0.00" step="0.01" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label class="form-label">Medicamento</label>
                                <InputText class="form-control" @bind-Value="_recordForm.Medication" placeholder="Medicamentos utilizados" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notas Adicionales</label>
                        <InputTextArea class="form-control" rows="2" @bind-Value="_recordForm.Notes" placeholder="Observaciones adicionales" />
                    </div>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">
                            @_errorMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(_editingRecord != null ? "Guardar Cambios" : "Guardar Registro")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<!-- Record Details Modal -->
<div class="modal fade @(_showDetailsModal ? "show d-block" : "")" tabindex="-1" style="@(_showDetailsModal ? "background: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            @if (_selectedRecord != null)
            {
                <div class="modal-header">
                    <h5 class="modal-title">
                        <span class="badge bg-@GetRecordTypeBadgeColor(_selectedRecord.RecordType) me-2">
                            @GetRecordTypeDisplayName(_selectedRecord.RecordType)
                        </span>
                        Registro Sanitario
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Información General</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Animal:</strong></td>
                                    <td>@_selectedRecord.AnimalName</td>
                                </tr>
                                <tr>
                                    <td><strong>Fecha:</strong></td>
                                    <td>@_selectedRecord.RecordDate.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <td><strong>Tipo:</strong></td>
                                    <td>@GetRecordTypeDisplayName(_selectedRecord.RecordType)</td>
                                </tr>
                                <tr>
                                    <td><strong>Veterinario:</strong></td>
                                    <td>@(_selectedRecord.VeterinarianName ?? "No especificado")</td>
                                </tr>
                                @if (_selectedRecord.Cost.HasValue)
                                {
                                    <tr>
                                        <td><strong>Costo:</strong></td>
                                        <td class="fw-bold">$@_selectedRecord.Cost.Value.ToString("N2")</td>
                                    </tr>
                                }
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6>Registro Creado</h6>
                            <p class="text-muted">@_selectedRecord.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</p>

                            @if (!string.IsNullOrEmpty(_selectedRecord.Medication))
                            {
                                <h6>Medicamento</h6>
                                <p>@_selectedRecord.Medication</p>
                            }
                        </div>
                    </div>

                    <h6>Descripción</h6>
                    <div class="alert alert-light">
                        @_selectedRecord.Description
                    </div>

                    @if (!string.IsNullOrEmpty(_selectedRecord.Treatment))
                    {
                        <h6>Tratamiento</h6>
                        <div class="alert alert-info">
                            @_selectedRecord.Treatment
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_selectedRecord.Notes))
                    {
                        <h6>Notas Adicionales</h6>
                        <div class="alert alert-secondary">
                            @_selectedRecord.Notes
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => EditRecord(_selectedRecord)">
                        <i class="fas fa-edit"></i> Editar
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetailsModal">Cerrar</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<AnimalDto> _animals = new();
    private List<AnimalDto> _filteredAnimals = new();
    private List<FarmDto> _farms = new();
    private List<HealthRecordDto> _healthRecords = new();
    private List<HealthRecordDto> _filteredRecords = new();

    private int? _farmFilter;
    private int? _animalFilter;
    private string _recordTypeFilter = "";
    private DateTime? _dateFilter;
    private string _searchTerm = "";
    private bool _isLoading = true;
    private bool _showModal = false;
    private bool _showDetailsModal = false;
    private bool _isSaving = false;
    private string _errorMessage = "";

    // Statistics
    private int _healthyCount = 0;
    private int _monitoringCount = 0;
    private int _sickCount = 0;
    private int _totalRecords = 0;

    private HealthRecordDto? _editingRecord;
    private HealthRecordDto? _selectedRecord;
    private CreateHealthRecordDto _recordForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadFarms();
        await LoadAnimals();
        await LoadHealthRecords();
        CalculateStatistics();
    }

    private async Task LoadFarms()
    {
        try
        {
            _farms = await FarmService.GetFarmsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading farms: {ex.Message}");
        }
    }

    private async Task LoadAnimals()
    {
        try
        {
            _animals = await AnimalService.GetAnimalsAsync(_farmFilter);
            FilterAnimalsByFarm();
            CalculateHealthStatistics();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading animals: {ex.Message}");
        }
    }

    private void FilterAnimalsByFarm()
    {
        if (_farmFilter.HasValue)
        {
            _filteredAnimals = _animals.Where(a => a.FarmId == _farmFilter.Value).ToList();
        }
        else
        {
            _filteredAnimals = _animals.ToList();
        }
    }

    private async Task OnFarmFilterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int farmId))
        {
            _farmFilter = farmId;
        }
        else
        {
            _farmFilter = null;
        }

        _animalFilter = null; // Reset animal filter when farm changes
        await LoadAnimals();
        await LoadHealthRecords();
    }

    private async Task LoadHealthRecords()
    {
        try
        {
            _isLoading = true;
            _healthRecords = await HealthService.GetHealthRecordsAsync(_animalFilter);
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading health records: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void CalculateHealthStatistics()
    {
        _healthyCount = _filteredAnimals.Count(a => a.Status.ToLower() == "healthy");
        _monitoringCount = _filteredAnimals.Count(a => a.Status.ToLower() == "monitoring");
        _sickCount = _filteredAnimals.Count(a => a.Status.ToLower() == "sick");
    }

    private void CalculateStatistics()
    {
        _totalRecords = _healthRecords.Count;
    }

    private void ApplyFilters()
    {
        _filteredRecords = _healthRecords.Where(record =>
        {
            // Animal filter
            if (_animalFilter.HasValue && record.AnimalId != _animalFilter.Value)
                return false;

            // Record type filter
            if (!string.IsNullOrEmpty(_recordTypeFilter) &&
                !record.RecordType.Equals(_recordTypeFilter, StringComparison.OrdinalIgnoreCase))
                return false;

            // Date filter
            if (_dateFilter.HasValue && record.RecordDate.Date != _dateFilter.Value.Date)
                return false;

            // Search filter
            if (!string.IsNullOrEmpty(_searchTerm))
            {
                var searchLower = _searchTerm.ToLower();
                if (!record.Description.ToLower().Contains(searchLower) &&
                    (string.IsNullOrEmpty(record.Treatment) || !record.Treatment.ToLower().Contains(searchLower)) &&
                    (string.IsNullOrEmpty(record.VeterinarianName) || !record.VeterinarianName.ToLower().Contains(searchLower)))
                {
                    return false;
                }
            }

            return true;
        }).ToList();

        StateHasChanged();
    }

    private async Task OnAnimalFilterChanged(ChangeEventArgs e)
    {
        var animalIdStr = e.Value?.ToString();
        _animalFilter = string.IsNullOrEmpty(animalIdStr) ? null : int.Parse(animalIdStr);
        await LoadHealthRecords();
    }

    private void OnRecordTypeFilterChanged(ChangeEventArgs e)
    {
        _recordTypeFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnDateFilterChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            _dateFilter = date;
        }
        else
        {
            _dateFilter = null;
        }
        ApplyFilters();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private async Task RefreshRecords()
    {
        await LoadHealthRecords();
    }

    private void ExportRecords()
    {
        // TODO: Implement export functionality
        Console.WriteLine("Export functionality to be implemented");
    }

    private void ShowAddRecordModal()
    {
        _editingRecord = null;
        _recordForm = new CreateHealthRecordDto
        {
            RecordDate = DateTime.Now,
            AnimalId = _animalFilter ?? 0
        };
        _errorMessage = "";
        _showModal = true;
    }

    private void EditRecord(HealthRecordDto record)
    {
        _editingRecord = record;
        _recordForm = new CreateHealthRecordDto
        {
            AnimalId = record.AnimalId,
            RecordType = record.RecordType,
            Description = record.Description,
            RecordDate = record.RecordDate,
            VeterinarianName = record.VeterinarianName,
            Treatment = record.Treatment,
            Medication = record.Medication,
            Cost = record.Cost,
            Notes = record.Notes
        };
        _errorMessage = "";
        _showModal = true;
        _showDetailsModal = false;
    }

    private async Task SaveRecord()
    {
        try
        {
            _isSaving = true;
            _errorMessage = "";

            if (_editingRecord != null)
            {
                await HealthService.UpdateHealthRecordAsync(_editingRecord.Id, _recordForm);
            }
            else
            {
                await HealthService.CreateHealthRecordAsync(_recordForm);
            }

            CloseModal();
            await LoadAnimals(); // Reload animals to update statistics
            await LoadHealthRecords();
        }
        catch (Exception ex)
        {
            _errorMessage = "Error al guardar el registro. Por favor, intenta nuevamente.";
            Console.WriteLine($"Error saving health record: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteRecord(HealthRecordDto record)
    {
        if (await ConfirmDelete($"¿Estás seguro de que deseas eliminar este registro sanitario?"))
        {
            try
            {
                await HealthService.DeleteHealthRecordAsync(record.Id);
                await LoadHealthRecords();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting health record: {ex.Message}");
            }
        }
    }

    private void ViewRecordDetails(HealthRecordDto record)
    {
        _selectedRecord = record;
        _showDetailsModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _errorMessage = "";
    }

    private void CloseDetailsModal()
    {
        _showDetailsModal = false;
        _selectedRecord = null;
    }

    private async Task<bool> ConfirmDelete(string message)
    {
