@page "/simple-register"
@using TrackerGanaderoBlazorHibridMaui.Models
@using TrackerGanaderoBlazorHibridMaui.Services
@using System.Net.Http
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Registro - Tracker Ganadero</PageTitle>

<div class="container-fluid vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="row w-100 justify-content-center">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h3 class="card-title text-center mb-4">Crear Cuenta</h3>

                    <div class="mb-3">
                        <label for="name" class="form-label">Nombre</label>
                        <input id="name" class="form-control" @bind="nameValue" placeholder="Ingresa tu nombre" />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input id="email" type="email" class="form-control" @bind="emailValue" placeholder="Ingresa tu email" />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Contraseña</label>
                        <input id="password" type="password" class="form-control" @bind="passwordValue" @oninput="CheckPasswords" placeholder="Ingresa tu contraseña" />
                    </div>

                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirmar Contraseña</label>
                        <input id="confirmPassword" type="password" class="form-control @(showPasswordMismatch ? "is-invalid" : (string.IsNullOrEmpty(confirmPasswordValue) ? "" : "is-valid"))" @bind="confirmPasswordValue" @oninput="CheckPasswords" placeholder="Confirma tu contraseña" />
                        @if (showPasswordMismatch)
                        {
                            <div class="text-danger small mt-1">Las contraseñas no coinciden</div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success" role="alert">
                            @successMessage
                        </div>
                    }

                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-primary btn-lg" @onclick="HandleRegister" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <text>Registrando...</text>
                            }
                            else
                            {
                                <text>Registrar</text>
                            }
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <p class="mb-0">¿Ya tienes cuenta? <a href="/login" class="text-primary text-decoration-none">Inicia sesión aquí</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string nameValue = "";
    private string emailValue = "";
    private string passwordValue = "";
    private string confirmPasswordValue = "";
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;
    private bool showPasswordMismatch = false;

    private void CheckPasswords()
    {
        if (!string.IsNullOrEmpty(confirmPasswordValue) && passwordValue != confirmPasswordValue)
        {
            showPasswordMismatch = true;
        }
        else
        {
            showPasswordMismatch = false;
        }
        StateHasChanged();
    }

    private async Task HandleRegister()
    {
        try
        {
            Console.WriteLine("=== SIMPLE REGISTER START ===");

            errorMessage = "";
            successMessage = "";
            isLoading = true;
            StateHasChanged();

            // Basic validation
            if (string.IsNullOrEmpty(nameValue) || string.IsNullOrEmpty(emailValue) ||
                string.IsNullOrEmpty(passwordValue) || string.IsNullOrEmpty(confirmPasswordValue))
            {
                errorMessage = "Todos los campos son requeridos";
                isLoading = false;
                StateHasChanged();
                return;
            }

            if (passwordValue != confirmPasswordValue)
            {
                errorMessage = "Las contraseñas no coinciden";
                isLoading = false;
                StateHasChanged();
                return;
            }

            if (passwordValue.Length < 6)
            {
                errorMessage = "La contraseña debe tener al menos 6 caracteres";
                isLoading = false;
                StateHasChanged();
                return;
            }

            // Create DTO
            var registerDto = new RegisterUserDto
            {
                Name = nameValue.Trim(),
                Email = emailValue.Trim().ToLower(),
                Password = passwordValue,
                ConfirmPassword = confirmPasswordValue
            };

            Console.WriteLine($"Sending registration: Name={registerDto.Name}, Email={registerDto.Email}");

            // Step 1: Try to register (will return null, but creates user in DB)
            try
            {
                await AuthService.RegisterAsync(registerDto);
                Console.WriteLine("Registration API call completed");
            }
            catch (HttpRequestException httpEx)
            {
                Console.WriteLine($"HTTP exception during registration: {httpEx.Message}");

                // Check if email already exists
                if (httpEx.Message.Contains("Email already exists") || httpEx.Message.Contains("400"))
                {
                    errorMessage = "Este email ya está registrado. Intenta con otro email o inicia sesión.";
                    return;
                }
                // For any other error, continue to auto-login
                Console.WriteLine("Ignoring registration error, will try login");
            }
            catch (Exception regEx)
            {
                Console.WriteLine($"Exception during registration: {regEx.Message}");
                // Ignore and try login anyway
            }

            // Step 2: Auto-login after registration
            try
            {
                Console.WriteLine("Starting auto-login...");
                var loginDto = new LoginDto
                {
                    Username = registerDto.Email, // Login uses email now
                    Password = registerDto.Password
                };

                var loginResult = await AuthService.LoginAsync(loginDto);

                if (loginResult != null)
                {
                    Console.WriteLine("Login successful, redirecting...");
                    successMessage = "¡Registro exitoso! Iniciando sesión...";
                    StateHasChanged();

                    await Task.Delay(1000);
                    Navigation.NavigateTo("/", forceLoad: true);
                    return;
                }
                else
                {
                    Console.WriteLine("Login returned null");
                    errorMessage = "Usuario creado. Por favor, inicia sesión manualmente.";
                }
            }
            catch (Exception loginEx)
            {
                Console.WriteLine($"Login exception: {loginEx.Message}");
                errorMessage = "Usuario registrado. Por favor, inicia sesión manualmente desde la pantalla de login.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Outer exception in HandleRegister: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            errorMessage = "Error al procesar el registro. Por favor, verifica que el servidor esté disponible.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}