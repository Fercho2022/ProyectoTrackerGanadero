@page "/farms"
@using TrackerGanaderoBlazorHibridMaui.Models
@using TrackerGanaderoBlazorHibridMaui.Services
@using TrackerGanaderoBlazorHibridMaui.Components
@using System.Linq
@inject FarmService FarmService
@inject TrackingService TrackingService
@inject FarmTrackerService FarmTrackerService
@inject IJSRuntime JSRuntime
@inject HttpService HttpService

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">🏡 Gestión de Granjas</h2>
                    <p class="text-muted">Configura las áreas de geofencing para tus granjas</p>
                </div>
                <div>
                    <button class="btn btn-primary" @onclick="ShowCreateFarmModal">
                        <i class="fas fa-plus me-2"></i>Nueva Granja
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Farms List -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">📍 Granjas Existentes</h5>
                </div>
                <div class="card-body">
                    @if (_farms?.Any() == true)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Descripción</th>
                                        <th>Coordenadas</th>
                                        <th>Área de Geofencing</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var farm in _farms)
                                    {
                                        <tr>
                                            <td><strong>@farm.Name</strong></td>
                                            <td>@farm.Description</td>
                                            <td>
                                                <small class="text-muted">
                                                    📍 @farm.Latitude.ToString("F6"), @farm.Longitude.ToString("F6")
                                                </small>
                                            </td>
                                            <td>
                                                @if (farm.BoundaryCoordinates?.Any() == true)
                                                {
                                                    <span class="badge bg-success">@farm.BoundaryCoordinates.Count puntos</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Sin configurar</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditFarm(farm)">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-info" @onclick="() => ViewFarmOnMap(farm)">
                                                        <i class="fas fa-map-marked-alt"></i>
                                                    </button>
                                                    @if (farm.BoundaryCoordinates?.Any() == true)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGeofencing(farm)" title="Eliminar Área de Geofencing">
                                                            <i class="fas fa-map-marked"></i>
                                                        </button>
                                                    }
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFarm(farm.Id)">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-map-marked-alt fa-3x mb-3"></i>
                            <p>No hay granjas registradas</p>
                            <button class="btn btn-primary" @onclick="ShowCreateFarmModal">
                                <i class="fas fa-plus me-2"></i>Crear Primera Granja
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Geofencing Configuration -->
    @if (_selectedFarm != null)
    {
        <div class="row">
            <div class="col-lg-8">
                <!-- Map for Drawing -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">🗺️ Configurar Área de Geofencing</h5>
                        <div>
                            <button class="btn btn-sm @(_isDrawingMode ? "btn-danger" : "btn-success") me-2" @onclick="ToggleDrawingMode">
                                <i class="fas @(_isDrawingMode ? "fa-times" : "fa-map-marker-alt") me-1"></i>@(_isDrawingMode ? "Finalizar" : "Marcar Puntos")
                            </button>
                            <button class="btn btn-sm btn-warning me-2" @onclick="ClearBoundaries" disabled="@_isDrawingMode">
                                <i class="fas fa-eraser me-1"></i>Limpiar
                            </button>
                            <button class="btn btn-sm btn-primary" @onclick="SaveBoundaries" disabled="@_isDrawingMode">
                                <i class="fas fa-save me-1"></i>Guardar
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div id="farmMap" style="height: 500px; width: 100%;"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Drawing Status -->
                @if (_isDrawingMode)
                {
                    <div class="card mb-4 border-success">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">🎯 Modo Dibujo Activo</h5>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-success mb-3">
                                <i class="fas fa-hand-pointer me-2"></i>
                                <strong>Haz clic en el mapa</strong> para marcar cada punto del geofencing.
                            </div>
                            <div class="alert alert-info mb-0">
                                <i class="fas fa-undo me-2"></i>
                                <strong>Doble clic en un punto</strong> para eliminarlo y retroceder a ese punto.
                            </div>
                        </div>
                    </div>
                }

                <!-- Current Point Coordinates -->
                @if (!string.IsNullOrEmpty(_currentPointCoordinates))
                {
                    <div class="card mb-4 border-info">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">📍 Último Punto Marcado</h5>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-info mb-0">
                                <strong>@_currentPointCoordinates</strong>
                            </div>
                        </div>
                    </div>
                }

                <!-- Manual Coordinate Entry -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">📝 Entrada Manual de Coordenadas</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label">Latitud:</label>
                                <input type="number" step="0.000001" @bind="_newCoordinate.Lat" class="form-control" placeholder="-34.123456" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Longitud:</label>
                                <input type="number" step="0.000001" @bind="_newCoordinate.Lng" class="form-control" placeholder="-58.123456" />
                            </div>
                        </div>
                        <button class="btn btn-outline-primary w-100 mb-3" @onclick="AddCoordinate">
                            <i class="fas fa-plus-circle me-2"></i>Agregar Coordenada
                        </button>

                        <!-- Coordinates List -->
                        @if (_selectedFarm.BoundaryCoordinates?.Any() == true)
                        {
                            <div class="border rounded p-2" style="max-height: 300px; overflow-y: auto;">
                                <small class="text-muted d-block mb-2">Puntos marcados (@_selectedFarm.BoundaryCoordinates.Count):</small>
                                @for (int i = 0; i < _selectedFarm.BoundaryCoordinates.Count; i++)
                                {
                                    var coord = _selectedFarm.BoundaryCoordinates[i];
                                    var index = i;
                                    <div class="d-flex justify-content-between align-items-center mb-2 @(index == _selectedFarm.BoundaryCoordinates.Count - 1 ? "border-success border-2 rounded p-1" : "")"
                                         style="@(index == _selectedFarm.BoundaryCoordinates.Count - 1 ? "background-color: #f8f9fa;" : "")">
                                        <div>
                                            <small class="@(index == _selectedFarm.BoundaryCoordinates.Count - 1 ? "text-success fw-bold" : "")">@(index + 1). </small>
                                            <small class="@(index == _selectedFarm.BoundaryCoordinates.Count - 1 ? "text-success fw-bold" : "text-muted")">Lat: @coord.Lat.ToString("F6")</small><br/>
                                            <small class="@(index == _selectedFarm.BoundaryCoordinates.Count - 1 ? "text-success fw-bold" : "text-muted")" style="margin-left: 20px;">Lng: @coord.Lng.ToString("F6")</small>
                                        </div>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCoordinate(index)" disabled="@_isDrawingMode">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                }
                                @if (_selectedFarm.BoundaryCoordinates.Count >= 3)
                                {
                                    <div class="mt-2 p-2 bg-light rounded">
                                        <small class="text-success">
                                            <i class="fas fa-check-circle me-1"></i>
                                            Área válida con @_selectedFarm.BoundaryCoordinates.Count puntos
                                        </small>
                                    </div>
                                }
                                else
                                {
                                    <div class="mt-2 p-2 bg-warning bg-opacity-10 rounded">
                                        <small class="text-warning">
                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                            Necesitas al menos 3 puntos para crear un área
                                        </small>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- File Import -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">📂 Importar desde Archivo</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Seleccionar archivo:</label>
                            <InputFile OnChange="ImportCoordinatesFromFile" accept=".csv,.json,.kml" class="form-control" />
                            <small class="text-muted">Formatos soportados: CSV, JSON, KML</small>
                        </div>

                        <div class="alert alert-info small">
                            <strong>Formato CSV:</strong><br/>
                            latitude,longitude<br/>
                            -34.123456,-58.123456<br/>
                            -34.124456,-58.124456
                        </div>

                        <div class="alert alert-info small">
                            <strong>Formato JSON:</strong><br/>
                            [{"latitude": -34.123456, "longitude": -58.123456}]
                        </div>

                        @if (!string.IsNullOrEmpty(_importMessage))
                        {
                            <div class="alert alert-@(_importSuccess ? "success" : "danger") small">
                                @_importMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<!-- Create/Edit Farm Modal -->
<div class="modal fade @(_showFarmModal ? "show d-block" : "")" tabindex="-1" style="@(_showFarmModal ? "background-color: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(_editingFarm?.Id > 0 ? "Editar" : "Crear") Granja</h5>
                <button type="button" class="btn-close" @onclick="CloseFarmModal"></button>
            </div>
            <div class="modal-body">
                @if (_editingFarm != null)
                {
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre:</label>
                            <input type="text" @bind="_editingFarm.Name" class="form-control" placeholder="Nombre de la granja" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Descripción:</label>
                            <input type="text" @bind="_editingFarm.Description" class="form-control" placeholder="Descripción opcional" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Latitud Central:</label>
                            <input type="number" step="0.000001" @bind="_editingFarm.Latitude" class="form-control" placeholder="-34.123456" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Longitud Central:</label>
                            <input type="number" step="0.000001" @bind="_editingFarm.Longitude" class="form-control" placeholder="-58.123456" />
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Después de crear la granja, podrás configurar el área de geofencing usando las herramientas de dibujo, entrada manual o importación de archivos.
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseFarmModal">Cancelar</button>
                <button type="button" class="btn btn-primary" @onclick="SaveFarm">
                    <i class="fas fa-save me-2"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
@if (_isLoading)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background-color: rgba(0,0,0,0.5); z-index: 9999;">
        <div class="card">
            <div class="card-body text-center">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <p class="mb-0">@_loadingMessage</p>
            </div>
        </div>
    </div>
}

@code {
    private List<FarmDto>? _farms = new();
    private FarmDto? _selectedFarm;
    private FarmDto? _editingFarm;
    private LatLngDto _newCoordinate = new();
    private bool _showFarmModal = false;
    private bool _isLoading = true;
    private string _loadingMessage = "Cargando granjas...";
    private string _importMessage = "";
    private bool _importSuccess = false;
    private bool _isDrawingMode = false;
    private string _currentPointCoordinates = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadFarms();
        _isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeMap();
        }
        else if (_selectedFarm != null)
        {
            try
            {
                // Check if map container exists but no map is initialized
                var mapExists = await JSRuntime.InvokeAsync<bool>("checkMapExists");
                if (!mapExists)
                {
                    Console.WriteLine("Map container found but map not initialized, reinitializing...");
                    // Clean up any remnants
                    await JSRuntime.InvokeVoidAsync("cleanupFarmMap");
                    await Task.Delay(200); // Small delay to ensure cleanup and DOM is ready
                    await InitializeMap();
                    if (_selectedFarm != null)
                    {
                        // Load animals and update map with both farm and animals
                        try
                        {
                            var farmAnimals = await TrackingService.GetFarmAnimalsLocationsAsync(_selectedFarm.Id);
                            Console.WriteLine($"Reinitializing with {farmAnimals.Count} animals for farm {_selectedFarm.Name}");
                            await UpdateMapWithFarmAndAnimals(_selectedFarm, farmAnimals);
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine($"Error loading animals during reinit for farm {_selectedFarm.Id}: {ex.Message}");
                            await UpdateMapWithFarm(_selectedFarm);
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error checking map existence: {ex.Message}");
                // Fallback: always try to initialize the map
                try
                {
                    await JSRuntime.InvokeVoidAsync("cleanupFarmMap");
                    await Task.Delay(200);
                    await InitializeMap();
                    if (_selectedFarm != null)
                    {
                        // Load animals and update map with both farm and animals
                        try
                        {
                            var farmAnimals = await TrackingService.GetFarmAnimalsLocationsAsync(_selectedFarm.Id);
                            Console.WriteLine($"Fallback reinitializing with {farmAnimals.Count} animals for farm {_selectedFarm.Name}");
                            await UpdateMapWithFarmAndAnimals(_selectedFarm, farmAnimals);
                        }
                        catch (Exception animalEx)
                        {
                            Console.WriteLine($"Error loading animals during fallback reinit for farm {_selectedFarm.Id}: {animalEx.Message}");
                            await UpdateMapWithFarm(_selectedFarm);
                        }
                    }
                }
                catch (Exception initEx)
                {
                    Console.WriteLine($"Error initializing map: {initEx.Message}");
                }
            }
        }
    }

    private async Task LoadFarms()
    {
        try
        {
            Console.WriteLine($"🔧 LoadFarms: Calling FarmService.GetFarmsAsync()...");
            _farms = await FarmService.GetFarmsAsync();

            Console.WriteLine($"🔧 LoadFarms: Received {_farms?.Count ?? 0} farms from API");
            if (_farms != null)
            {
                foreach (var farm in _farms)
                {
                    Console.WriteLine($"🔧   - {farm.Name} (ID: {farm.Id}): {farm.BoundaryCoordinates?.Count ?? 0} coordinates");
                    if (farm.BoundaryCoordinates?.Any() == true)
                    {
                        Console.WriteLine($"🔧     First coordinate: Lat={farm.BoundaryCoordinates.First().Lat}, Lng={farm.BoundaryCoordinates.First().Lng}");
                    }
                }
            }
            else
            {
                Console.WriteLine($"🚨 LoadFarms: _farms is null!");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading farms: {ex.Message}");
        }
    }

    private async Task InitializeMap()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("initializeFarmMap");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing map: {ex.Message}");
        }
    }

    private void ShowCreateFarmModal()
    {
        _editingFarm = new FarmDto
        {
            BoundaryCoordinates = new List<LatLngDto>()
        };
        _showFarmModal = true;
    }

    private void EditFarm(FarmDto farm)
    {
        _selectedFarm = new FarmDto
        {
            Id = farm.Id,
            Name = farm.Name,
            Description = farm.Description,
            Latitude = farm.Latitude,
            Longitude = farm.Longitude,
            BoundaryCoordinates = farm.BoundaryCoordinates?.ToList() ?? new List<LatLngDto>(),
            UserId = farm.UserId,
            CreatedAt = farm.CreatedAt,
            UpdatedAt = farm.UpdatedAt
        };

        _editingFarm = _selectedFarm;
        _showFarmModal = true;

        // Update map with farm boundaries
        InvokeAsync(async () => await UpdateMapWithFarm(_selectedFarm));
    }

    private async Task DeleteGeofencing(FarmDto farm)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"¿Estás seguro de que quieres eliminar el área de geofencing de {farm.Name}?"))
        {
            try
            {
                _isLoading = true;
                _loadingMessage = "Eliminando área de geofencing...";
                StateHasChanged();

                // Clear the farm's boundary coordinates in the API
                await FarmService.UpdateFarmBoundariesAsync(farm.Id, new List<LatLngDto>());

                // Reload farms to update the UI
                await LoadFarms();

                // Select this farm and show it on the map with animals
                _selectedFarm = _farms?.FirstOrDefault(f => f.Id == farm.Id);
                if (_selectedFarm != null)
                {
                    // Load the animals for this farm and show them on the map
                    var farmAnimals = await TrackingService.GetFarmAnimalsLocationsAsync(farm.Id);
                    Console.WriteLine($"Loaded {farmAnimals.Count} animals for farm {farm.Name} after deleting geofencing");

                    // Update map to show farm center and animals (no boundaries)
                    await UpdateMapWithFarmAndAnimals(_selectedFarm, farmAnimals);
                }

                _isLoading = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _isLoading = false;
                Console.WriteLine($"Error deleting geofencing: {ex.Message}");
                await JSRuntime.InvokeVoidAsync("alert", $"Error eliminando área de geofencing: {ex.Message}");
                StateHasChanged();
            }
        }
    }

    private async Task ViewFarmOnMap(FarmDto farm)
    {
        _selectedFarm = farm;

        // Load the animals for this farm to show their trackers on the map
        try
        {
            var farmAnimals = await TrackingService.GetFarmAnimalsLocationsAsync(farm.Id);
            Console.WriteLine($"Loaded {farmAnimals.Count} animals for farm {farm.Name} (ID: {farm.Id})");

            // Update map with farm boundaries and animal trackers
            await UpdateMapWithFarmAndAnimals(farm, farmAnimals);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading animals for farm {farm.Id}: {ex.Message}");
            // Fallback to showing just the farm boundary
            await UpdateMapWithFarm(farm);
        }
    }

    private async Task UpdateMapWithFarm(FarmDto farm)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("updateFarmMap", farm.Latitude, farm.Longitude, farm.BoundaryCoordinates?.ToArray() ?? Array.Empty<LatLngDto>());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating map: {ex.Message}");
        }
    }

    private async Task UpdateMapWithFarmAndAnimals(FarmDto farm, List<AnimalLocationDto> animals)
    {
        try
        {
            // Prepare animal data for JavaScript
            var animalData = animals.Where(a => a.Location != null).Select(a => new
            {
                id = a.AnimalId,
                name = a.AnimalName,
                tag = a.Tag,
                status = a.Status,
                latitude = a.Location!.Latitude,
                longitude = a.Location!.Longitude,
                timestamp = a.Location!.Timestamp,
                speed = a.Location!.Speed,
                temperature = a.Location!.Temperature == 0 ? 20.0 : a.Location!.Temperature,
                activityLevel = a.Location!.ActivityLevel == 0 ? 50 : a.Location!.ActivityLevel
            }).ToArray();

            Console.WriteLine($"Sending {animalData.Length} animals to map for farm {farm.Name}");

            await JSRuntime.InvokeVoidAsync("updateFarmMapWithAnimals",
                farm.Latitude,
                farm.Longitude,
                farm.BoundaryCoordinates?.ToArray() ?? Array.Empty<LatLngDto>(),
                animalData);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating map with animals: {ex.Message}");
            // Fallback to showing just the farm boundary
            await UpdateMapWithFarm(farm);
        }
    }

    private async Task ToggleDrawingMode()
    {
        try
        {
            _isDrawingMode = !_isDrawingMode;
            _currentPointCoordinates = "";

            if (_isDrawingMode)
            {
                await JSRuntime.InvokeVoidAsync("enablePointClickMode");
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("disablePointClickMode");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling drawing mode: {ex.Message}");
        }
    }

    private async Task ClearBoundaries()
    {
        if (_selectedFarm != null)
        {
            _selectedFarm.BoundaryCoordinates?.Clear();
            await JSRuntime.InvokeVoidAsync("clearPolygon");
            StateHasChanged();
        }
    }

    private void AddCoordinate()
    {
        if (_selectedFarm != null && _newCoordinate.Lat != 0 && _newCoordinate.Lng != 0)
        {
            _selectedFarm.BoundaryCoordinates ??= new List<LatLngDto>();
            _selectedFarm.BoundaryCoordinates.Add(new LatLngDto
            {
                Lat = _newCoordinate.Lat,
                Lng = _newCoordinate.Lng
            });

            _newCoordinate = new LatLngDto();

            // Update map
            InvokeAsync(async () => await UpdateMapWithFarm(_selectedFarm));
            StateHasChanged();
        }
    }

    private void RemoveCoordinate(int index)
    {
        if (_selectedFarm?.BoundaryCoordinates != null && index >= 0 && index < _selectedFarm.BoundaryCoordinates.Count)
        {
            _selectedFarm.BoundaryCoordinates.RemoveAt(index);

            // Update map
            InvokeAsync(async () => await UpdateMapWithFarm(_selectedFarm));
            StateHasChanged();
        }
    }

    private async Task ImportCoordinatesFromFile(InputFileChangeEventArgs e)
    {
        try
        {
            _importMessage = "";
            var file = e.File;

            if (file.Size > 1024 * 1024) // 1MB limit
            {
                _importMessage = "El archivo es demasiado grande. Máximo 1MB.";
                _importSuccess = false;
                return;
            }

            using var reader = new StreamReader(file.OpenReadStream());
            var content = await reader.ReadToEndAsync();

            var coordinates = new List<LatLngDto>();

            if (file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
            {
                coordinates = ParseCsvCoordinates(content);
            }
            else if (file.Name.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
            {
                coordinates = ParseJsonCoordinates(content);
            }
            else if (file.Name.EndsWith(".kml", StringComparison.OrdinalIgnoreCase))
            {
                coordinates = ParseKmlCoordinates(content);
            }
            else
            {
                _importMessage = "Formato de archivo no soportado.";
                _importSuccess = false;
                return;
            }

            if (coordinates.Any())
            {
                if (_selectedFarm != null)
                {
                    _selectedFarm.BoundaryCoordinates = coordinates;
                    await UpdateMapWithFarm(_selectedFarm);
                    _importMessage = $"Se importaron {coordinates.Count} coordenadas exitosamente.";
                    _importSuccess = true;
                }
                else
                {
                    _importMessage = "Selecciona una granja primero.";
                    _importSuccess = false;
                }
            }
            else
            {
                _importMessage = "No se encontraron coordenadas válidas en el archivo.";
                _importSuccess = false;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            _importMessage = $"Error al importar archivo: {ex.Message}";
            _importSuccess = false;
            StateHasChanged();
        }
    }

    private List<LatLngDto> ParseCsvCoordinates(string content)
    {
        var coordinates = new List<LatLngDto>();
        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);

        foreach (var line in lines.Skip(1)) // Skip header
        {
            var parts = line.Split(',');
            if (parts.Length >= 2 &&
                double.TryParse(parts[0].Trim(), out var lat) &&
                double.TryParse(parts[1].Trim(), out var lng))
            {
                coordinates.Add(new LatLngDto { Lat = lat, Lng = lng });
            }
        }

        return coordinates;
    }

    private List<LatLngDto> ParseJsonCoordinates(string content)
    {
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<LatLngDto>>(content) ?? new List<LatLngDto>();
        }
        catch
        {
            return new List<LatLngDto>();
        }
    }

    private List<LatLngDto> ParseKmlCoordinates(string content)
    {
        var coordinates = new List<LatLngDto>();
        // Simple KML parsing - in production, use a proper KML parser
        var coordinatesMatch = System.Text.RegularExpressions.Regex.Match(content, @"<coordinates>(.*?)</coordinates>", System.Text.RegularExpressions.RegexOptions.Singleline);
        if (coordinatesMatch.Success)
        {
            var coordsText = coordinatesMatch.Groups[1].Value.Trim();
            var coordPairs = coordsText.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);

            foreach (var coordPair in coordPairs)
            {
                var parts = coordPair.Split(',');
                if (parts.Length >= 2 &&
                    double.TryParse(parts[1], out var lat) &&
                    double.TryParse(parts[0], out var lng))
                {
                    coordinates.Add(new LatLngDto { Lat = lat, Lng = lng });
                }
            }
        }
        return coordinates;
    }

    private async Task SaveBoundaries()
    {
        if (_selectedFarm != null)
        {
            // Get coordinates directly from JavaScript
            try
            {
                var jsCoordinates = await JSRuntime.InvokeAsync<LatLngDto[]>("getMapCoordinates");
                if (jsCoordinates != null && jsCoordinates.Length > 0)
                {
                    _selectedFarm.BoundaryCoordinates = jsCoordinates.ToList();
                }
            }
            catch (Exception jsEx)
            {
                Console.WriteLine($"Error obtaining coordinates from JS: {jsEx.Message}");
                return;
            }

            try
            {
                _isLoading = true;
                _loadingMessage = "Guardando área de geofencing...";
                StateHasChanged();

                await FarmService.UpdateFarmBoundariesAsync(_selectedFarm.Id, _selectedFarm.BoundaryCoordinates ?? new List<LatLngDto>());

                Console.WriteLine($"🔧 API call completed, waiting 500ms before reloading farms...");
                await Task.Delay(500); // Small delay to ensure database is updated
                await LoadFarms();

                Console.WriteLine($"🔧 Farms reloaded, _farms count: {_farms?.Count ?? 0}");

                // Update the selected farm with the latest data from the reloaded farms list
                var updatedFarm = _farms?.FirstOrDefault(f => f.Id == _selectedFarm.Id);
                if (updatedFarm != null)
                {
                    Console.WriteLine($"🔧 Found updated farm: {updatedFarm.Name} with {updatedFarm.BoundaryCoordinates?.Count ?? 0} coordinates");
                    _selectedFarm = updatedFarm;
                    Console.WriteLine($"🔧 Updated selected farm {_selectedFarm.Name} with {_selectedFarm.BoundaryCoordinates?.Count ?? 0} coordinates");

                    // Force UI update
                    StateHasChanged();
                    Console.WriteLine($"🔧 Called StateHasChanged() to force UI update");
                }
                else
                {
                    Console.WriteLine($"🚨 ERROR: Could not find updated farm with ID {_selectedFarm.Id} in reloaded farms list");
                    if (_farms != null)
                    {
                        Console.WriteLine($"🚨 Available farm IDs: {string.Join(", ", _farms.Select(f => f.Id))}");
                    }
                }

                _importMessage = $"Área de geofencing guardada exitosamente para {_selectedFarm.Name}. Coordenadas: {_selectedFarm.BoundaryCoordinates?.Count ?? 0}";
                _importSuccess = true;
            }
            catch (Exception ex)
            {
                _importMessage = $"Error al guardar: {ex.Message}";
                _importSuccess = false;
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    private void CloseFarmModal()
    {
        _showFarmModal = false;
        _editingFarm = null;
    }

    private async Task SaveFarm()
    {
        if (_editingFarm != null)
        {
            try
            {
                _isLoading = true;
                _loadingMessage = _editingFarm.Id > 0 ? "Actualizando granja..." : "Creando granja...";
                StateHasChanged();

                Console.WriteLine($"Saving farm: {_editingFarm.Name}");
                Console.WriteLine($"Description: {_editingFarm.Description}");
                Console.WriteLine($"Latitude: {_editingFarm.Latitude}");
                Console.WriteLine($"Longitude: {_editingFarm.Longitude}");

                if (_editingFarm.Id > 0)
                {
                    Console.WriteLine("Updating existing farm...");
                    await FarmService.UpdateFarmAsync(_editingFarm);

                    // Limpiar trackers inactivos después de editar la granja
                    try
                    {
                        Console.WriteLine("Cleaning up inactive trackers from farm...");
                        var cleanupResult = await FarmTrackerService.CleanupInactiveTrackersAsync(_editingFarm.Id);
                        if (cleanupResult.success && cleanupResult.cleanedCount > 0)
                        {
                            Console.WriteLine($"Cleaned up {cleanupResult.cleanedCount} inactive trackers from farm");
                        }
                    }
                    catch (Exception cleanupEx)
                    {
                        Console.WriteLine($"Warning: Could not clean up inactive trackers: {cleanupEx.Message}");
                        // No interrumpir el flujo principal si falla la limpieza
                    }
                }
                else
                {
                    Console.WriteLine("Creating new farm...");
                    var createdFarm = await FarmService.CreateFarmAsync(_editingFarm);
                    Console.WriteLine($"Farm created with ID: {createdFarm?.Id}");
                    if (createdFarm != null)
                        _editingFarm.Id = createdFarm.Id;
                }

                await LoadFarms();
                CloseFarmModal();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error saving farm: {ex.Message}");
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task DeleteFarm(int farmId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "¿Estás seguro de que quieres eliminar esta granja?"))
        {
            try
            {
                _isLoading = true;
                _loadingMessage = "Eliminando granja...";
                StateHasChanged();

                await FarmService.DeleteFarmAsync(farmId);

                await LoadFarms();
                if (_selectedFarm?.Id == farmId)
                {
                    _selectedFarm = null;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting farm: {ex.Message}");
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    [JSInvokable("OnPolygonDrawn")]
    public async Task OnPolygonDrawn(LatLngDto[] coordinates)
    {
        if (_selectedFarm != null)
        {
            if (coordinates?.Length > 0)
            {
                _selectedFarm.BoundaryCoordinates = coordinates.ToList();
                Console.WriteLine($"🔧 Coordinates assigned to farm {_selectedFarm.Name}");

                // Update current point coordinates display for the last point
                if (coordinates.Length > 0 && _isDrawingMode)
                {
                    var lastPoint = coordinates.Last();
                    _currentPointCoordinates = $"Lat: {lastPoint.Lat:F6}, Lng: {lastPoint.Lng:F6}";
                    Console.WriteLine($"🔧 Updated current point display: {_currentPointCoordinates}");
                }
            }
            else
            {
                // Clear coordinates
                _selectedFarm.BoundaryCoordinates = new List<LatLngDto>();
                _currentPointCoordinates = "";
            }

            await InvokeAsync(StateHasChanged);
        }
    }

}

