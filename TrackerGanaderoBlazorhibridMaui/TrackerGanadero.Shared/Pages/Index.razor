@page "/"
@using TrackerGanadero.Shared.Models
@using TrackerGanadero.Shared.Services
@inject AnimalService AnimalService
@inject AlertService AlertService
@inject FarmService FarmService
@inject SignalRService SignalRService
@implements IDisposable

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">🐄 Dashboard Ganadero</h2>
                    <p class="text-muted">Monitoreo en tiempo real de tu ganado</p>
                </div>
                <div class="text-end">
                    <small class="text-muted">Última actualización: @DateTime.Now.ToString("HH:mm:ss")</small>
                    <br />
                    <span class="badge @(_signalRConnected ? "bg-success" : "bg-danger")">
                        @(_signalRConnected ? "Conectado" : "Desconectado")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_totalAnimals</h4>
                            <p class="mb-0">Total Animales</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-cow fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_activeAlerts</h4>
                            <p class="mb-0">Alertas Activas</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-exclamation-triangle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_animalsWithTrackers</h4>
                            <p class="mb-0">Con Trackers</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-satellite-dish fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_totalFarms</h4>
                            <p class="mb-0">Granjas</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-map-marked-alt fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions and Recent Activity -->
    <div class="row">
        <!-- Quick Actions -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">🚀 Acciones Rápidas</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <a href="/live-map" class="btn btn-outline-primary w-100">
                                <i class="fas fa-map-marked-alt mb-2 d-block"></i>
                                Mapa en Vivo
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="/animals" class="btn btn-outline-success w-100">
                                <i class="fas fa-plus-circle mb-2 d-block"></i>
                                Agregar Animal
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="/alerts" class="btn btn-outline-warning w-100">
                                <i class="fas fa-bell mb-2 d-block"></i>
                                Ver Alertas
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="/farms" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-home mb-2 d-block"></i>
                                Gestión de Granjas
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="/reports" class="btn btn-outline-info w-100">
                                <i class="fas fa-chart-bar mb-2 d-block"></i>
                                Reportes
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Alerts -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">⚠️ Alertas Recientes</h5>
                    <a href="/alerts" class="btn btn-sm btn-outline-primary">Ver Todas</a>
                </div>
                <div class="card-body">
                    @if (_recentAlerts?.Any() == true)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var alert in _recentAlerts.Take(5))
                            {
                                <div class="list-group-item border-0 px-0">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-@GetAlertBadgeColor(alert.Severity) me-2">
                                                    @alert.Severity
                                                </span>
                                                <small class="text-muted">@alert.CreatedAt.ToString("HH:mm")</small>
                                            </div>
                                            <p class="mb-1 fw-bold">@alert.Title</p>
                                            <p class="mb-0 text-muted small">@alert.Message</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-check-circle fa-3x mb-3"></i>
                            <p>No hay alertas recientes</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Animals Activity -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">🐄 Animales Recientes</h5>
                    <a href="/animals" class="btn btn-sm btn-outline-primary">Ver Todos</a>
                </div>
                <div class="card-body">
                    @if (_recentAnimals?.Any() == true)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Tag</th>
                                        <th>Raza</th>
                                        <th>Estado</th>
                                        <th>Tracker</th>
                                        <th>Última Ubicación</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var animal in _recentAnimals.Take(10))
                                    {
                                        <tr>
                                            <td>
                                                <strong>@animal.Name</strong>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@animal.Tag</span>
                                            </td>
                                            <td>@animal.Breed</td>
                                            <td>
                                                <span class="badge bg-@GetStatusBadgeColor(animal.Status)">
                                                    @TranslateStatus(animal.Status)
                                                </span>
                                            </td>
                                            <td>
                                                @if (animal.TrackerId.HasValue)
                                                {
                                                    <i class="fas fa-satellite-dish text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-times text-danger"></i>
                                                }
                                            </td>
                                            <td>
                                                @if (animal.CurrentLocation != null)
                                                {
                                                    <small class="text-muted">
                                                        @animal.CurrentLocation.Timestamp.ToString("dd/MM HH:mm")
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Sin datos</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-cow fa-3x mb-3"></i>
                            <p>No hay animales registrados</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int _totalAnimals = 0;
    private int _activeAlerts = 0;
    private int _animalsWithTrackers = 0;
    private int _totalFarms = 0;
    private bool _signalRConnected = false;
    private bool _disposed = false;

    private List<AlertDto>? _recentAlerts;
    private List<AnimalDto>? _recentAnimals;

    private System.Threading.Timer? _autoRefreshTimer;

    // Named handlers for proper unsubscription
    private Action<string>? _connectionStatusHandler;
    private Action<AlertDto>? _alertReceivedHandler;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
        InitializeSignalR();

        // Set up auto-refresh every 1 minute (first tick after 60s, not immediately)
        _autoRefreshTimer = new System.Threading.Timer(async _ =>
        {
            if (!_disposed) await RefreshData();
        }, null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
    }

    private async Task LoadDashboardData()
    {
        try
        {
            // Load stats
            var farms = await FarmService.GetFarmsAsync();
            _totalFarms = farms.Count;

            var animals = await AnimalService.GetAnimalsAsync();
            _totalAnimals = animals.Count;
            _animalsWithTrackers = animals.Count(a => a.TrackerId.HasValue);
            _recentAnimals = animals.OrderByDescending(a => a.Id).ToList();

            var alerts = await AlertService.GetActiveAlertsAsync();
            _activeAlerts = alerts.Count;
            _recentAlerts = alerts.OrderByDescending(a => a.CreatedAt).ToList();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
    }

    private void InitializeSignalR()
    {
        try
        {
            _connectionStatusHandler = (status) =>
            {
                if (_disposed) return;
                _signalRConnected = status == "Connected";
                InvokeAsync(StateHasChanged);
            };

            _alertReceivedHandler = (alert) =>
            {
                if (_disposed) return;
                _recentAlerts?.Insert(0, alert);
                _activeAlerts++;
                InvokeAsync(StateHasChanged);
            };

            SignalRService.ConnectionStatusChanged += _connectionStatusHandler;
            SignalRService.AlertReceived += _alertReceivedHandler;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing SignalR: {ex.Message}");
        }
    }

    private async Task RefreshData()
    {
        await LoadDashboardData();
    }

    private string GetAlertBadgeColor(string severity)
    {
        return severity.ToLower() switch
        {
            "high" => "danger",
            "medium" => "warning",
            "low" => "info",
            _ => "secondary"
        };
    }

    private string GetStatusBadgeColor(string status)
    {
        return status.ToLower() switch
        {
            "healthy" => "success",
            "sick" => "danger",
            "monitoring" => "warning",
            _ => "secondary"
        };
    }

    private string TranslateStatus(string status)
    {
        return status.ToLower() switch
        {
            "healthy" => "Saludable",
            "sick" => "Enfermo",
            "monitoring" => "En observación",
            _ => status
        };
    }

    public void Dispose()
    {
        _disposed = true;

        // Dispose timer
        _autoRefreshTimer?.Dispose();
        _autoRefreshTimer = null;

        // Unsubscribe SignalR event handlers to prevent memory leaks
        if (_connectionStatusHandler != null)
            SignalRService.ConnectionStatusChanged -= _connectionStatusHandler;
        if (_alertReceivedHandler != null)
            SignalRService.AlertReceived -= _alertReceivedHandler;
    }
}
