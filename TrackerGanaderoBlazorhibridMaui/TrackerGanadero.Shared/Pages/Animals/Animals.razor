@page "/animals"
@using TrackerGanadero.Shared.Models
@using TrackerGanadero.Shared.Services
@inject AnimalService AnimalService
@inject FarmService FarmService
@inject NavigationManager Navigation
@implements IDisposable

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">🐄 Gestión de Animales</h2>
                    <p class="text-muted">Administra tu ganado y su información</p>
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select" @onchange="OnFarmFilterChanged">
                        <option value="">Todas las granjas</option>
                        @if (_farms != null)
                        {
                            @foreach (var farm in _farms)
                            {
                                <option value="@farm.Id">@farm.Name</option>
                            }
                        }
                    </select>
                    <button class="btn btn-primary" @onclick="ShowAddAnimalModal">
                        <i class="fas fa-plus"></i> Agregar Animal
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Buscar por nombre o tag..."
                       @bind="_searchTerm" @oninput="OnSearchChanged" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="d-flex gap-2">
                <select class="form-select" @onchange="OnStatusFilterChanged">
                    <option value="">Todos los estados</option>
                    <option value="healthy">Saludable</option>
                    <option value="sick">Enfermo</option>
                    <option value="monitoring">En observación</option>
                </select>
                <select class="form-select" @onchange="OnTrackerFilterChanged">
                    <option value="">Todos</option>
                    <option value="with">Con tracker</option>
                    <option value="without">Sin tracker</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Animals Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <h5 class="mb-0">Animales (@_filteredAnimals.Count)</h5>
                            <div class="real-time-indicator">
                                <i class="fas fa-satellite-dish pulse-icon"></i>
                                <small class="text-muted">Auto-actualización</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshAnimals">
                                <i class="fas fa-sync-alt"></i> Actualizar
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="ExportData">
                                <i class="fas fa-download"></i> Exportar
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (_isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border" role="status"></div>
                            <p class="mt-2">Cargando animales...</p>
                        </div>
                    }
                    else if (_filteredAnimals.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Tag</th>
                                        <th>Raza</th>
                                        <th>Género</th>
                                        <th>Edad</th>
                                        <th>Peso</th>
                                        <th>Estado</th>
                                        <th>Tracker</th>
                                        <th>Última Ubicación</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var animal in _filteredAnimals)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@animal.Name</strong>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(animal.Tag))
                                                {
                                                    <span class="badge bg-secondary">@animal.Tag</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Sin tag</span>
                                                }
                                            </td>
                                            <td>@animal.Breed</td>
                                            <td>
                                                <i class="fas @(animal.Gender.ToLower() == "male" ? "fa-mars text-primary" : "fa-venus text-danger")"></i>
                                                @animal.Gender
                                            </td>
                                            <td>@GetAge(animal.BirthDate)</td>
                                            <td>@animal.Weight.ToString("F1") kg</td>
                                            <td>
                                                <span class="badge bg-@GetStatusBadgeColor(animal.Status)">
                                                    @TranslateStatus(animal.Status)
                                                </span>
                                            </td>
                                            <td>
                                                @if (animal.TrackerId.HasValue)
                                                {
                                                    @if (animal.TrackerIsOnline)
                                                    {
                                                        <i class="fas fa-satellite-dish text-success" title="Activo"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-satellite-dish text-danger" title="Sin señal"></i>
                                                    }
                                                }
                                                else
                                                {
                                                    <i class="fas fa-times text-muted" title="Sin tracker"></i>
                                                }
                                            </td>
                                            <td>
                                                @if (animal.CurrentLocation != null)
                                                {
                                                    <small class="@(animal.TrackerIsOnline ? "text-success" : "text-danger")">
                                                        @animal.CurrentLocation.Latitude.ToString("F5"), @animal.CurrentLocation.Longitude.ToString("F5")
                                                    </small>
                                                    <br />
                                                    <small class="text-muted">
                                                        @animal.CurrentLocation.Timestamp.ToString("dd/MM HH:mm:ss")
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Sin datos</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" @onclick="() => ViewAnimalDetails(animal.Id)" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary" @onclick="() => EditAnimal(animal)" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => DeleteAnimal(animal)" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-cow fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No se encontraron animales</h5>
                            <p class="text-muted">Agrega tu primer animal o ajusta los filtros de búsqueda</p>
                            <button class="btn btn-primary" @onclick="ShowAddAnimalModal">
                                <i class="fas fa-plus"></i> Agregar Animal
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Animal Modal -->
<div class="modal fade @(_showModal ? "show d-block" : "")" tabindex="-1" style="@(_showModal ? "background: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(_editingAnimal != null ? "Editar Animal" : "Agregar Nuevo Animal")
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <EditForm Model="@_animalForm" OnValidSubmit="@SaveAnimal">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Nombre *</label>
                                <InputText class="form-control" @bind-Value="_animalForm.Name" placeholder="Nombre del animal" />
                                <ValidationMessage For="@(() => _animalForm.Name)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Tag/Número</label>
                                <InputText class="form-control" @bind-Value="_animalForm.Tag" placeholder="Ej: 001, TAG-123" />
                                <ValidationMessage For="@(() => _animalForm.Tag)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Raza *</label>
                                <InputText class="form-control" @bind-Value="_animalForm.Breed" placeholder="Raza del animal" />
                                <ValidationMessage For="@(() => _animalForm.Breed)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Género *</label>
                                <InputSelect class="form-select" @bind-Value="_animalForm.Gender">
                                    <option value="">Seleccionar género</option>
                                    <option value="Male">Macho</option>
                                    <option value="Female">Hembra</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _animalForm.Gender)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Fecha de Nacimiento *</label>
                                <InputDate class="form-control" @bind-Value="_animalForm.BirthDate" />
                                <ValidationMessage For="@(() => _animalForm.BirthDate)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Peso (kg) *</label>
                                <InputNumber class="form-control" @bind-Value="_animalForm.Weight" placeholder="Peso en kilogramos" />
                                <ValidationMessage For="@(() => _animalForm.Weight)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Estado *</label>
                                <InputSelect class="form-select" @bind-Value="_animalForm.Status">
                                    <option value="">Seleccionar estado</option>
                                    <option value="Healthy">Saludable</option>
                                    <option value="Sick">Enfermo</option>
                                    <option value="Monitoring">En observación</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _animalForm.Status)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Granja *</label>
                                <InputSelect class="form-select" @bind-Value="_animalForm.FarmId">
                                    <option value="0">Seleccionar granja</option>
                                    @if (_farms != null)
                                    {
                                        @foreach (var farm in _farms)
                                        {
                                            <option value="@farm.Id">@farm.Name</option>
                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => _animalForm.FarmId)" />
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">
                            @_errorMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(_editingAnimal != null ? "Guardar Cambios" : "Agregar Animal")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private List<AnimalDto> _animals = new();
    private List<AnimalDto> _filteredAnimals = new();
    private List<FarmDto> _farms = new();
    private string _searchTerm = "";
    private string _statusFilter = "";
    private string _trackerFilter = "";
    private int? _farmFilter;
    private bool _isLoading = true;
    private bool _showModal = false;
    private bool _isSaving = false;
    private string _errorMessage = "";

    private AnimalDto? _editingAnimal;
    private CreateAnimalDto _animalForm = new();

    // Real-time update timer
    private Timer? _updateTimer;
    private readonly TimeSpan _updateInterval = TimeSpan.FromSeconds(5);

    protected override async Task OnInitializedAsync()
    {
        await LoadFarms();
        await LoadAnimals();
        StartAutoUpdate();
    }

    private async Task LoadFarms()
    {
        try
        {
            _farms = await FarmService.GetFarmsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading farms: {ex.Message}");
        }
    }

    private async Task LoadAnimals()
    {
        try
        {
            _isLoading = true;
            _animals = await AnimalService.GetAnimalsAsync(_farmFilter);
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading animals: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        _filteredAnimals = _animals.Where(animal =>
        {
            // Search filter
            if (!string.IsNullOrEmpty(_searchTerm))
            {
                var searchLower = _searchTerm.ToLower();
                if (!animal.Name.ToLower().Contains(searchLower) &&
                    (string.IsNullOrEmpty(animal.Tag) || !animal.Tag.ToLower().Contains(searchLower)))
                {
                    return false;
                }
            }

            // Status filter
            if (!string.IsNullOrEmpty(_statusFilter) &&
                !animal.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            // Tracker filter
            if (!string.IsNullOrEmpty(_trackerFilter))
            {
                if (_trackerFilter == "with" && !animal.TrackerId.HasValue)
                    return false;
                if (_trackerFilter == "without" && animal.TrackerId.HasValue)
                    return false;
            }

            return true;
        }).ToList();

        StateHasChanged();
    }

    private async Task OnFarmFilterChanged(ChangeEventArgs e)
    {
        var farmIdStr = e.Value?.ToString();
        _farmFilter = string.IsNullOrEmpty(farmIdStr) ? null : int.Parse(farmIdStr);
        await LoadAnimals();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnStatusFilterChanged(ChangeEventArgs e)
    {
        _statusFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnTrackerFilterChanged(ChangeEventArgs e)
    {
        _trackerFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private async Task RefreshAnimals()
    {
        await LoadAnimals();
    }

    private void ShowAddAnimalModal()
    {
        _editingAnimal = null;
        _animalForm = new CreateAnimalDto
        {
            BirthDate = DateTime.Now.AddYears(-1),
            FarmId = _farms.FirstOrDefault()?.Id ?? 1 // Use 1 instead of 0 as default
        };
        _errorMessage = "";

        // Validar que tenemos granjas disponibles
        if (!_farms.Any())
        {
            _errorMessage = "No hay granjas disponibles. Por favor, crea una granja primero.";
            return;
        }

        _showModal = true;
    }

    private void EditAnimal(AnimalDto animal)
    {
        _editingAnimal = animal;
        _animalForm = new CreateAnimalDto
        {
            Name = animal.Name,
            Tag = animal.Tag,
            BirthDate = animal.BirthDate,
            Gender = animal.Gender,
            Breed = animal.Breed,
            Weight = animal.Weight,
            Status = animal.Status,
            FarmId = animal.FarmId,
            TrackerId = animal.TrackerId
        };
        _errorMessage = "";
        _showModal = true;
    }

    private async Task SaveAnimal()
    {
        try
        {
            _isSaving = true;
            _errorMessage = "";

            // Validar datos antes de enviar
            if (string.IsNullOrEmpty(_animalForm.Name))
            {
                _errorMessage = "El nombre del animal es requerido.";
                return;
            }

            if (string.IsNullOrEmpty(_animalForm.Gender))
            {
                _errorMessage = "El género es requerido.";
                return;
            }

            if (string.IsNullOrEmpty(_animalForm.Breed))
            {
                _errorMessage = "La raza es requerida.";
                return;
            }

            if (string.IsNullOrEmpty(_animalForm.Status))
            {
                _errorMessage = "El estado es requerido.";
                return;
            }

            if (_animalForm.FarmId <= 0)
            {
                _errorMessage = "Debe seleccionar una granja válida.";
                return;
            }

            if (_animalForm.Weight <= 0)
            {
                _errorMessage = "El peso debe ser mayor a 0.";
                return;
            }

            Console.WriteLine($"Saving animal: Name={_animalForm.Name}, Gender={_animalForm.Gender}, Breed={_animalForm.Breed}, Status={_animalForm.Status}, FarmId={_animalForm.FarmId}, Weight={_animalForm.Weight}");

            if (_editingAnimal != null)
            {
                await AnimalService.UpdateAnimalAsync(_editingAnimal.Id, _animalForm);
            }
            else
            {
                await AnimalService.CreateAnimalAsync(_animalForm);
            }

            CloseModal();
            await LoadAnimals();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al guardar el animal: {ex.Message}";
            Console.WriteLine($"Error saving animal: {ex}");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAnimal(AnimalDto animal)
    {
        if (await ConfirmDelete($"¿Estás seguro de que deseas eliminar el animal '{animal.Name}'?"))
        {
            try
            {
                await AnimalService.DeleteAnimalAsync(animal.Id);
                await LoadAnimals();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting animal: {ex.Message}");
            }
        }
    }

    private void ViewAnimalDetails(int animalId)
    {
        Navigation.NavigateTo($"/animals/{animalId}");
    }

    private void CloseModal()
    {
        _showModal = false;
        _errorMessage = "";
    }

    private void ExportData()
    {
        // TODO: Implement export functionality
        Console.WriteLine("Export functionality to be implemented");
    }

    private async Task<bool> ConfirmDelete(string message)
    {
        // Simple confirmation for now - could be enhanced with a proper modal
        return true; // In a real app, show a confirmation dialog
    }

    private string GetAge(DateTime birthDate)
    {
        var age = DateTime.Now.Year - birthDate.Year;
        if (DateTime.Now.DayOfYear < birthDate.DayOfYear)
            age--;

        return $"{age} años";
    }

    private string GetStatusBadgeColor(string status)
    {
        return status.ToLower() switch
        {
            "saludable" => "success",        // Verde para saludable
            "healthy" => "success",          // Verde para healthy (compatibilidad)
            "enfermo" => "danger",           // Rojo para enfermo
            "sick" => "danger",              // Rojo para sick (compatibilidad)
            "en observación" => "warning",   // Amarillo para en observación
            "monitoring" => "warning",       // Amarillo para monitoring (compatibilidad)
            _ => "secondary"                 // Gris para estados desconocidos
        };
    }

    private string TranslateStatus(string status)
    {
        return status.ToLower() switch
        {
            "healthy" => "Saludable",
            "sick" => "Enfermo",
            "monitoring" => "En observación",
            _ => status  // Si ya está en español o es otro estado, devolver tal como está
        };
    }

    /// <summary>
    /// Starts the automatic update timer
    /// </summary>
    private void StartAutoUpdate()
    {
        StopAutoUpdate(); // Stop any existing timer
        _updateTimer = new Timer(async _ => await UpdateAnimalData(), null, _updateInterval, _updateInterval);
    }

    /// <summary>
    /// Stops the automatic update timer
    /// </summary>
    private void StopAutoUpdate()
    {
        _updateTimer?.Dispose();
        _updateTimer = null;
    }

    /// <summary>
    /// Updates animal data in the background - optimized for real-time updates
    /// </summary>
    private async Task UpdateAnimalData()
    {
        if (_isLoading || _showModal)
            return;

        try
        {
            // Update animals data without showing loading indicator
            var updatedAnimals = await AnimalService.GetAnimalsAsync(_farmFilter);

            // Update the animal list while preserving filters
            _animals = updatedAnimals;
            ApplyFilters();

            // Update the UI on the main thread
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            // Log error but don't break the update cycle
            Console.WriteLine($"Error updating animal data: {ex.Message}");
        }
    }

    /// <summary>
    /// Implements IDisposable to clean up the timer
    /// </summary>
    public void Dispose()
    {
        StopAutoUpdate();
    }
}

<style>
    /* Real-time update indicators */
    .real-time-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pulse-icon {
        animation: pulse 2s infinite;
        color: #28a745;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.7; transform: scale(1.1); }
    }
</style>