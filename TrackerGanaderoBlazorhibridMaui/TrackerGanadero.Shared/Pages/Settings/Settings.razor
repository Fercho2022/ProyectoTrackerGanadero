@page "/settings"
@using TrackerGanadero.Shared.Services
@using TrackerGanadero.Shared.Models
@using TrackerGanadero.Shared.Components
@using System.ComponentModel.DataAnnotations
@inject TrackerManagementService TrackerManagementService
@inject LicenseService LicenseService
@inject SettingsStateService StateService
@inject FarmService FarmService
@inject AuthService AuthService
@inject FarmTrackerService FarmTrackerService
@inject IJSRuntime JSRuntime
@inject NotificationSettingsService NotificationSettingsService
@implements IDisposable

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h4 mb-0">
                    <i class="fas fa-cog me-2"></i>
                    Configuración de Trackers
                </h2>
                @if (StateService.CustomerInfo != null)
                {
                    <div class="badge bg-success">
                        <i class="fas fa-check-circle me-1"></i>
                        Licencia Activa
                    </div>
                }
            </div>

            @if (_isLoading)
            {
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            }
            else
            {
                <!-- Navigation Tabs -->
                <ul class="nav nav-tabs mb-4" id="settingsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(StateService.ActiveTab == "license" ? "active" : "")"
                                @onclick="@(async () => await SetActiveTab("license"))"
                                type="button" role="tab">
                            <i class="fas fa-key me-2"></i>
                            Activación de Licencia
                        </button>
                    </li>

                    @if (StateService.CustomerInfo != null)
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(StateService.ActiveTab == "my-trackers" ? "active" : "")"
                                    @onclick="@(async () => await SetActiveTab("my-trackers"))"
                                    type="button" role="tab">
                                <i class="fas fa-satellite-dish me-2"></i>
                                Mis Trackers
                                @if (StateService.MyTrackers?.Count > 0)
                                {
                                    <span class="badge bg-primary ms-1">@StateService.MyTrackers.Count</span>
                                }
                            </button>
                        </li>

                        @* SECURITY FIX: Tab "Descubrir Trackers" ocultado porque la asignación se hace desde Panel Admin *@
                        @* <li class="nav-item" role="presentation">
                            <button class="nav-link @(StateService.ActiveTab == "discovery" ? "active" : "")"
                                    @onclick="@(async () => await SetActiveTab("discovery"))"
                                    type="button" role="tab">
                                <i class="fas fa-search me-2"></i>
                                Descubrir Trackers
                                @if (StateService.ScannedTrackers?.Count > 0)
                                {
                                    <span class="badge bg-warning ms-1">@StateService.ScannedTrackers.Count</span>
                                }
                            </button>
                        </li> *@

                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(StateService.ActiveTab == "assignment" ? "active" : "")"
                                    @onclick="@(async () => await SetActiveTab("assignment"))"
                                    type="button" role="tab">
                                <i class="fas fa-link me-2"></i>
                                Asignar Trackers
                                @if (_farms?.Count > 0)
                                {
                                    <span class="badge bg-info ms-1">@_farms.Count</span>
                                }
                            </button>
                        </li>

                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(StateService.ActiveTab == "notifications" ? "active" : "")"
                                    @onclick="@(async () => await SetActiveTab("notifications"))"
                                    type="button" role="tab">
                                <i class="fas fa-bell me-2"></i>
                                Notificaciones
                            </button>
                        </li>
                    }
                </ul>

                <!-- Loading indicator for tab switching -->
                @if (_loadingTab)
                {
                    <div class="d-flex justify-content-center align-items-center py-5">
                        <div class="spinner-border text-primary me-3" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                        <span>Cargando datos...</span>
                    </div>
                }
                else
                {
                    <!-- Tab Content -->
                    <div class="tab-content">
                    <!-- License Activation Tab -->
                    @if (StateService.ActiveTab == "license")
                    {
                        <div class="tab-pane fade show active">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="card">
                                        <div class="card-header">
                                            <h5 class="card-title mb-0">
                                                <i class="fas fa-key me-2"></i>
                                                Activación de Licencia
                                            </h5>
                                        </div>
                                        <div class="card-body">
                                            @if (StateService.CustomerInfo == null)
                                            {
                                                <EditForm Model="_activationModel" OnValidSubmit="ActivateLicense">
                                                    <DataAnnotationsValidator />

                                                    <div class="mb-3">
                                                        <label for="licenseKey" class="form-label">Clave de Licencia</label>
                                                        <InputText @bind-Value="_activationModel.LicenseKey"
                                                                   class="form-control"
                                                                   id="licenseKey"
                                                                   placeholder="TG-2024-XXXX-XXXX-XXXX"
                                                                   autocomplete="off"
                                                                   disabled="@_isActivating" />
                                                        <ValidationMessage For="() => _activationModel.LicenseKey" class="text-danger" />
                                                        <div class="form-text">
                                                            Ingrese la clave de licencia proporcionada por el proveedor del software.
                                                        </div>
                                                    </div>

                                                    <button type="submit" class="btn btn-primary" disabled="@_isActivating">
                                                        @if (_isActivating)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                            <span>Activando...</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="fas fa-unlock me-2"></i>
                                                            <span>Activar Licencia</span>
                                                        }
                                                    </button>
                                                </EditForm>
                                            }
                                            else
                                            {
                                                <div class="alert alert-success">
                                                    <h6 class="alert-heading">
                                                        <i class="fas fa-check-circle me-2"></i>
                                                        Licencia Activada
                                                    </h6>
                                                    <p class="mb-0">Su licencia está activa y funcionando correctamente.</p>
                                                </div>
                                            }

                                            @* IMPORTANTE: Solo mostrar mensajes de activación cuando NO hay licencia activa *@
                                            @* Si ya hay licencia, el mensaje fijo de arriba es suficiente *@
                                            @if (!string.IsNullOrEmpty(_licenseMessage) && StateService.CustomerInfo == null)
                                            {
                                                <div class="alert @(_licenseSuccess ? "alert-success" : "alert-danger") mt-3">
                                                    @_licenseMessage
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    @if (StateService.CustomerInfo != null)
                                    {
                                        <div class="card">
                                            <div class="card-header">
                                                <h6 class="card-title mb-0">
                                                    <i class="fas fa-info-circle me-2"></i>
                                                    Información del Cliente
                                                </h6>
                                            </div>
                                            <div class="card-body">
                                                <div class="mb-2">
                                                    <strong>Empresa:</strong> @StateService.CustomerInfo.CompanyName
                                                </div>
                                                <div class="mb-2">
                                                    <strong>Plan:</strong> @StateService.CustomerInfo.Plan
                                                </div>
                                                <div class="mb-2">
                                                    <strong>Estado:</strong>
                                                    <span class="badge bg-success">@StateService.CustomerInfo.Status</span>
                                                </div>
                                                <div class="mb-3">
                                                    <strong>Trackers:</strong> @StateService.CustomerInfo.CurrentTrackerCount / @StateService.CustomerInfo.TrackerLimit

                                                    <div class="progress mt-2">
                                                        <div class="progress-bar"
                                                             style="width: @(GetProgressPercentage(StateService.CustomerInfo.CurrentTrackerCount, StateService.CustomerInfo.TrackerLimit))%">
                                                        </div>
                                                    </div>
                                                </div>
                                                @if (!StateService.CustomerInfo.CanAddMoreTrackers)
                                                {
                                                    <div class="alert alert-warning alert-sm">
                                                        <i class="fas fa-exclamation-triangle me-1"></i>
                                                        Límite de trackers alcanzado
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- My Trackers Tab -->
                    @if (StateService.ActiveTab == "my-trackers" && StateService.CustomerInfo != null)
                    {
                        <div class="tab-pane fade show active">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5>
                                    <i class="fas fa-satellite-dish me-2"></i>
                                    Mis Trackers Asignados
                                </h5>
                                <button class="btn btn-outline-primary btn-sm" @onclick="RefreshTrackerData">
                                    <i class="fas fa-sync-alt me-1"></i>
                                    Actualizar
                                </button>
                            </div>

                            @if (StateService.MyTrackers == null || !StateService.MyTrackers.Any())
                            {
                                <div class="text-center p-4">
                                    <i class="fas fa-satellite-dish fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">No hay trackers asignados</h5>
                                    <p class="text-muted">Comience descubriendo y asignando trackers desde las otras pestañas.</p>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <thead>
                                            <tr>
                                                <th>Nombre</th>
                                                <th>Device ID</th>
                                                <th>Estado</th>
                                                <th>Granja</th>
                                                <th>Animal</th>
                                                <th>Fecha Asignación</th>
                                                <th>Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var tracker in StateService.MyTrackers)
                                            {
                                                <tr>
                                                    <td><strong>@tracker.TrackerName</strong></td>
                                                    <td>@tracker.DeviceId</td>
                                                    <td><span class="badge bg-success">@tracker.Status</span></td>
                                                    <td>@tracker.FarmName</td>
                                                    <td>@(string.IsNullOrEmpty(tracker.AnimalName) ? "N/A" : tracker.AnimalName)</td>
                                                    <td>@tracker.AssignedAt.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        <button class="btn btn-outline-danger btn-sm"
                                                                @onclick="() => ConfirmDeleteTracker(tracker)"
                                                                disabled="@(_deletingTrackerId == tracker.TrackerId)">
                                                            @if (_deletingTrackerId == tracker.TrackerId)
                                                            {
                                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                            }
                                                            else
                                                            {
                                                                <i class="fas fa-trash-alt me-1"></i>
                                                            }
                                                            Eliminar
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    }

                    @* SECURITY FIX: Tab "Descubrir Trackers" deshabilitado - asignación solo desde Panel Admin *@
                    @* <!-- Discovery Tab -->
                    @if (StateService.ActiveTab == "discovery" && StateService.CustomerInfo != null)
                    {
                        <div class="tab-pane fade show active">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="d-flex align-items-center gap-3">
                                    <h5 class="mb-0">
                                        <i class="fas fa-search me-2"></i>
                                        Descubrir Nuevos Trackers
                                    </h5>
                                    <div class="real-time-indicator">
                                        <i class="fas fa-satellite-dish pulse-icon"></i>
                                        <small class="text-muted">Actualización en tiempo real</small>
                                    </div>
                                </div>
                                <button class="btn btn-primary" @onclick="ScanForNewTrackers">
                                    <i class="fas fa-satellite me-1"></i>
                                    Escanear Señales GPS
                                </button>
                            </div>

                            @if (_unregisteredTrackers == null || !_unregisteredTrackers.Any())
                            {
                                <div class="text-center p-4">
                                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">No se encontraron nuevos trackers</h5>
                                    <p class="text-muted">Haga clic en "Escanear Señales GPS" para buscar dispositivos transmitiendo.</p>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Se encontraron <strong>@_unregisteredTrackers.Count</strong> dispositivos nuevos transmitiendo señales GPS.
                                </div>

                                <div class="row">
                                    @foreach (var tracker in _unregisteredTrackers)
                                    {
                                        <div class="col-md-6 col-lg-4 mb-3">
                                            <div class="card @(tracker.Id > 0 ? "border-success" : "")">
                                                <div class="card-header @(tracker.Id > 0 ? "bg-light-success" : "")">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <h6 class="card-title mb-0">Device: @tracker.DeviceId</h6>
                                                        @if (tracker.Id > 0)
                                                        {
                                                            <span class="badge bg-success">Registrado</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning">Nuevo</span>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="card-body">
                                                    @if (tracker.Id > 0)
                                                    {
                                                        <div class="mb-2">
                                                            <strong>Nombre:</strong> @tracker.Name
                                                        </div>
                                                        <div class="mb-2">
                                                            <strong>Modelo:</strong> @tracker.Model
                                                        </div>
                                                        <div class="mb-2">
                                                            <strong>Estado:</strong>
                                                            <span class="badge @(tracker.IsOnline ? "bg-success" : "bg-secondary")">
                                                                @(tracker.IsOnline ? "En línea" : "Desconectado")
                                                            </span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="mb-2">
                                                            <strong>Primera señal:</strong> @tracker.FirstSeen.ToString("dd/MM/yyyy HH:mm")
                                                        </div>
                                                        <div class="mb-2">
                                                            <strong>Reportes:</strong> @tracker.SignalCount
                                                        </div>
                                                    }

                                                    <div class="mb-2">
                                                        <strong>Última señal:</strong> @tracker.LastSeen.ToString("dd/MM/yyyy HH:mm")
                                                    </div>

                                                    @if (tracker.LastLatitude.HasValue && tracker.LastLongitude.HasValue)
                                                    {
                                                        <div class="mb-2">
                                                            <strong>Ubicación:</strong> @tracker.LastLatitude.Value.ToString("F6"), @tracker.LastLongitude.Value.ToString("F6")
                                                        </div>
                                                    }
                                                </div>
                                                <div class="card-footer">
                                                    @if (tracker.Id > 0)
                                                    {
                                                        <button class="btn btn-outline-success w-100" disabled>
                                                            <i class="fas fa-check me-1"></i>
                                                            Ya Registrado
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-success w-100" @onclick="() => RegisterTracker(tracker.DeviceId)">
                                                            <i class="fas fa-plus-circle me-1"></i>
                                                            Registrar Tracker
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    } *@

                    <!-- Assignment Tab -->
                    @if (StateService.ActiveTab == "assignment" && StateService.CustomerInfo != null)
                    {
                        <div class="tab-pane fade show active">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5>
                                    <i class="fas fa-link me-2"></i>
                                    Asignar Trackers a Animales
                                </h5>
                                @if (_selectedFarm != null)
                                {
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _selectedFarm = null">
                                        <i class="fas fa-arrow-left me-1"></i>
                                        Volver a Lista
                                    </button>
                                }
                            </div>

                            @if (_selectedFarm == null)
                            {
                                <!-- Farm Selection -->
                                @if (_farms == null || !_farms.Any())
                                {
                                    <div class="text-center p-4">
                                        <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
                                        <h5 class="text-muted">No hay granjas disponibles</h5>
                                        <p class="text-muted">Cree primero una granja desde "Gestión de Granjas".</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Seleccione una granja para asignar trackers a sus animales.
                                    </div>

                                    <div class="row">
                                        @foreach (var farm in _farms)
                                        {
                                            <div class="col-md-6 col-lg-4 mb-3">
                                                <div class="card h-100 cursor-pointer" @onclick="() => SelectFarmForAssignment(farm)">
                                                    <div class="card-header">
                                                        <h6 class="card-title mb-0">@farm.Name</h6>
                                                    </div>
                                                    <div class="card-body">
                                                        @if (!string.IsNullOrEmpty(farm.Description))
                                                        {
                                                            <div class="mb-2">
                                                                <small><strong>Descripción:</strong> @farm.Description</small>
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="card-footer">
                                                        <div class="btn btn-outline-primary w-100">
                                                            <i class="fas fa-link me-1"></i>
                                                            Gestionar Trackers
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <!-- Tracker Assignment Section -->
                                <div class="row">
                                    <div class="col-12">
                                        <TrackerAssignment Farm="_selectedFarm" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    </div>

                    @if (!string.IsNullOrEmpty(_trackerMessage))
                    {
                        <div class="alert @(_trackerSuccess ? "alert-success" : "alert-danger") mt-3">
                            @_trackerMessage
                        </div>
                    }
                }

                @* ======================== TAB: NOTIFICACIONES ======================== *@
                @if (StateService.ActiveTab == "notifications")
                {
                    <div class="tab-pane fade show active">
                        <h5 class="mb-4">
                            <i class="fas fa-bell me-2 text-warning"></i>
                            Preferencias de Notificaciones
                        </h5>

                        @if (_notificationSettings == null)
                        {
                            <div class="text-center p-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Cargando...</span>
                                </div>
                                <p class="mt-2 text-muted">Cargando preferencias...</p>
                            </div>
                        }
                        else
                        {
                            <EditForm Model="_notificationSettings" OnValidSubmit="SaveNotificationSettings">
                                <DataAnnotationsValidator />

                                @* --- Informacion de Contacto --- *@
                                <div class="card mb-4">
                                    <div class="card-header bg-primary text-white">
                                        <h6 class="mb-0"><i class="fas fa-address-book me-2"></i>Informacion de Contacto</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Celular / WhatsApp</label>
                                                <InputText @bind-Value="_notificationSettings.PhoneNumber"
                                                           class="form-control" placeholder="+54 9 11 1234-5678" />
                                                <small class="text-muted">Numero con codigo de pais para WhatsApp</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Email de Notificaciones</label>
                                                <InputText @bind-Value="_notificationSettings.NotificationEmail"
                                                           class="form-control" placeholder="alertas@ejemplo.com" />
                                                <ValidationMessage For="() => _notificationSettings.NotificationEmail" />
                                                <small class="text-muted">Dejar vacio para usar el email de tu cuenta</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @* --- Canales de Notificacion --- *@
                                <div class="card mb-4">
                                    <div class="card-header bg-info text-white">
                                        <h6 class="mb-0"><i class="fas fa-paper-plane me-2"></i>Canales de Notificacion</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="form-check form-switch mb-3">
                                            <InputCheckbox @bind-Value="_notificationSettings.EnableEmailNotifications"
                                                           class="form-check-input" id="chkEmail" />
                                            <label class="form-check-label" for="chkEmail">
                                                <i class="fas fa-envelope me-1 text-primary"></i>
                                                Notificaciones por Email
                                            </label>
                                        </div>
                                        <div class="form-check form-switch mb-3">
                                            <InputCheckbox @bind-Value="_notificationSettings.EnableWhatsAppNotifications"
                                                           class="form-check-input" id="chkWhatsApp" />
                                            <label class="form-check-label" for="chkWhatsApp">
                                                <i class="fab fa-whatsapp me-1 text-success"></i>
                                                Notificaciones por WhatsApp
                                            </label>
                                            <br />
                                            <small class="text-muted">Requiere configurar la API de WhatsApp Business</small>
                                        </div>
                                    </div>
                                </div>

                                @* --- Tipos de Alerta --- *@
                                <div class="card mb-4">
                                    <div class="card-header bg-warning text-dark">
                                        <h6 class="mb-0"><i class="fas fa-sliders-h me-2"></i>Tipos de Alerta a Recibir</h6>
                                    </div>
                                    <div class="card-body">

                                        @* Conectividad *@
                                        <h6 class="text-primary mb-2"><i class="fas fa-wifi me-1"></i> Conectividad</h6>
                                        <div class="ms-3 mb-3">
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertNoSignal"
                                                               class="form-check-input" id="chkNoSignal" />
                                                <label class="form-check-label" for="chkNoSignal">Sin Senal de Tracker</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertWeakSignal"
                                                               class="form-check-input" id="chkWeakSignal" />
                                                <label class="form-check-label" for="chkWeakSignal">Senal Debil</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertAbruptDisconnection"
                                                               class="form-check-input" id="chkAbruptDisc" />
                                                <label class="form-check-label" for="chkAbruptDisc">Desconexion Abrupta</label>
                                            </div>
                                        </div>

                                        @* Seguridad *@
                                        <h6 class="text-danger mb-2"><i class="fas fa-shield-alt me-1"></i> Seguridad</h6>
                                        <div class="ms-3 mb-3">
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertNightMovement"
                                                               class="form-check-input" id="chkNight" />
                                                <label class="form-check-label" for="chkNight">Movimiento Nocturno</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertSuddenExit"
                                                               class="form-check-input" id="chkSuddenExit" />
                                                <label class="form-check-label" for="chkSuddenExit">Salida Subita del Area</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertUnusualSpeed"
                                                               class="form-check-input" id="chkUnusualSpeed" />
                                                <label class="form-check-label" for="chkUnusualSpeed">Velocidad Anormal</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertTrackerManipulation"
                                                               class="form-check-input" id="chkManipulation" />
                                                <label class="form-check-label" for="chkManipulation">Manipulacion de Tracker</label>
                                            </div>
                                        </div>

                                        @* Ubicacion *@
                                        <h6 class="text-warning mb-2"><i class="fas fa-map-marker-alt me-1"></i> Ubicacion y Geofencing</h6>
                                        <div class="ms-3 mb-3">
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertOutOfBounds"
                                                               class="form-check-input" id="chkOutOfBounds" />
                                                <label class="form-check-label" for="chkOutOfBounds">Animal Fuera del Area</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertImmobility"
                                                               class="form-check-input" id="chkImmobility" />
                                                <label class="form-check-label" for="chkImmobility">Animal Inmovil</label>
                                            </div>
                                        </div>

                                        @* Actividad *@
                                        <h6 class="text-success mb-2"><i class="fas fa-running me-1"></i> Actividad</h6>
                                        <div class="ms-3 mb-3">
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertLowActivity"
                                                               class="form-check-input" id="chkLowActivity" />
                                                <label class="form-check-label" for="chkLowActivity">Baja Actividad</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertHighActivity"
                                                               class="form-check-input" id="chkHighActivity" />
                                                <label class="form-check-label" for="chkHighActivity">Alta Actividad</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertPossibleHeat"
                                                               class="form-check-input" id="chkHeat" />
                                                <label class="form-check-label" for="chkHeat">Posible Celo</label>
                                            </div>
                                        </div>

                                        @* Bateria *@
                                        <h6 class="text-info mb-2"><i class="fas fa-battery-half me-1"></i> Bateria</h6>
                                        <div class="ms-3 mb-3">
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertBatteryLow"
                                                               class="form-check-input" id="chkBatteryLow" />
                                                <label class="form-check-label" for="chkBatteryLow">Bateria Baja</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertBatteryCritical"
                                                               class="form-check-input" id="chkBatteryCrit" />
                                                <label class="form-check-label" for="chkBatteryCrit">Bateria Critica</label>
                                            </div>
                                        </div>

                                        @* Hardware *@
                                        <h6 class="text-secondary mb-2"><i class="fas fa-microchip me-1"></i> Hardware / Precision</h6>
                                        <div class="ms-3 mb-3">
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertInvalidCoordinates"
                                                               class="form-check-input" id="chkInvalidCoords" />
                                                <label class="form-check-label" for="chkInvalidCoords">Coordenadas Invalidas</label>
                                            </div>
                                            <div class="form-check mb-2">
                                                <InputCheckbox @bind-Value="_notificationSettings.AlertLocationJump"
                                                               class="form-check-input" id="chkLocationJump" />
                                                <label class="form-check-label" for="chkLocationJump">Salto de Ubicacion</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @* --- Boton Guardar --- *@
                                <div class="d-flex justify-content-end">
                                    <button type="submit" class="btn btn-primary btn-lg" disabled="@_isSavingNotifications">
                                        @if (_isSavingNotifications)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            <text>Guardando...</text>
                                        }
                                        else
                                        {
                                            <i class="fas fa-save me-2"></i>
                                            <text>Guardar Preferencias</text>
                                        }
                                    </button>
                                </div>
                            </EditForm>

                            @if (!string.IsNullOrEmpty(_notificationMessage))
                            {
                                <div class="alert @(_notificationSuccess ? "alert-success" : "alert-danger") mt-3">
                                    <i class="fas @(_notificationSuccess ? "fa-check-circle" : "fa-exclamation-circle") me-2"></i>
                                    @_notificationMessage
                                </div>
                            }
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* Modal de confirmacion de eliminacion de tracker *@
    @if (_showDeleteModal && _trackerToDelete != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            Eliminar Tracker
                        </h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CancelDeleteTracker"></button>
                    </div>
                    <div class="modal-body">
                        <p>Va a eliminar el siguiente tracker:</p>
                        <div class="card bg-light mb-3">
                            <div class="card-body py-2">
                                <strong>@_trackerToDelete.TrackerName</strong><br />
                                <small class="text-muted">Device ID: @_trackerToDelete.DeviceId</small>
                                @if (!string.IsNullOrEmpty(_trackerToDelete.AnimalName))
                                {
                                    <br /><small class="text-warning">
                                        <i class="fas fa-exclamation-circle me-1"></i>
                                        Asignado al animal: @_trackerToDelete.AnimalName
                                    </small>
                                }
                            </div>
                        </div>
                        <p class="text-danger mb-0">
                            <i class="fas fa-warning me-1"></i>
                            Esta accion no se puede deshacer.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CancelDeleteTracker">Cancelar</button>
                        <button type="button" class="btn btn-danger" @onclick="ExecuteDeleteTracker">
                            <i class="fas fa-trash-alt me-1"></i>
                            Eliminar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // State variables
    private bool _isLoading = true;
    private bool _isActivating = false;

    // License Management
    private ActivateLicenseRequest _activationModel = new();
    private string? _licenseMessage;
    private bool _licenseSuccess = false;

    // Tracker Management
    private string? _trackerMessage;
    private bool _trackerSuccess = false;

    // Delete Tracker
    private bool _showDeleteModal = false;
    private CustomerTrackerDto? _trackerToDelete;
    private int _deletingTrackerId = -1;


    // Farm Management for Tracker Assignment
    private List<FarmDto>? _farms = new();
    private FarmDto? _selectedFarm;
    private List<TrackerDiscoveryDto> _unregisteredTrackers = new();
    private bool _loadingTab = false;

    // Notification Settings
    private NotificationSettingsModel? _notificationSettings;
    private bool _isSavingNotifications = false;
    private string? _notificationMessage;
    private bool _notificationSuccess = false;

    // Real-time update timer
    private Timer? _updateTimer;
    private readonly TimeSpan _updateInterval = TimeSpan.FromSeconds(7); // Slightly slower for discovery

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        if (string.IsNullOrEmpty(StateService.ActiveTab))
        {
            StateService.ActiveTab = "license";
        }

        // IMPORTANTE: Siempre recargar CustomerInfo desde el API para obtener datos frescos
        // Esto asegura que si un admin revocó la licencia, el usuario lo vea inmediatamente
        await LoadCustomerInfo();

        if (StateService.CustomerInfo != null)
        {
            await LoadMyTrackers();

            if (StateService.ActiveTab == "license")
            {
                StateService.ActiveTab = "my-trackers";
            }

            // Cargar datos del tab activo si es necesario
            if (StateService.ActiveTab == "notifications")
            {
                await LoadNotificationSettings();
            }

            StartAutoUpdate();
        }

        _isLoading = false;
    }

    private async Task LoadCustomerInfo()
    {
        try
        {
            StateService.CustomerInfo = await LicenseService.GetCustomerInfoAsync();

            // IMPORTANTE: Si ya hay licencia activa, limpiar mensajes de activación anteriores
            // para evitar mostrar mensajes redundantes como "Licencia ya activada anteriormente"
            if (StateService.CustomerInfo != null)
            {
                _licenseMessage = null;
                _licenseSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _licenseMessage = "Error cargando información del cliente";
            _licenseSuccess = false;
        }
    }

    private async Task LoadTrackerData()
    {
        try
        {
            StateService.MyTrackers = await TrackerManagementService.GetMyTrackersAsync();
        }
        catch (Exception ex)
        {
            _trackerMessage = "Error cargando información de trackers";
            _trackerSuccess = false;
        }
    }

    private async Task ActivateLicense()
    {
        _isActivating = true;
        ClearMessages();

        try
        {
            _licenseMessage = "Conectando con servidor...";
            _licenseSuccess = false;
            StateHasChanged();

            var result = await LicenseService.ActivateLicenseAsync(_activationModel.LicenseKey);

            System.Diagnostics.Debug.WriteLine($"[Settings] License activation result: IsSuccess={result.IsSuccess}, Message={result.Message}");

            if (result.IsSuccess)
            {
                System.Diagnostics.Debug.WriteLine("[Settings] License activation successful, updating UI...");
                _licenseMessage = result.Message;
                _licenseSuccess = true;
                StateService.CustomerInfo = result.Customer;
                // No cambiar el tab automáticamente - mantener el tab actual del usuario

                System.Diagnostics.Debug.WriteLine($"[Settings] Customer info: {(StateService.CustomerInfo != null ? "loaded" : "null")}");
                System.Diagnostics.Debug.WriteLine($"[Settings] Active tab changed to: {StateService.ActiveTab}");

                await LoadTrackerData();
            }
            else
            {
                System.Diagnostics.Debug.WriteLine("[Settings] License activation failed");
                _licenseMessage = result.Message;
                _licenseSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _licenseMessage = $"Error activating license: {ex.Message}";
            _licenseSuccess = false;
        }
        finally
        {
            _isActivating = false;
            StateHasChanged();
        }
    }

    private async Task ScanForNewTrackers()
    {
        ClearMessages();

        try
        {
            // Obtener todos los trackers transmitiendo (registrados y no registrados)
            var scannedTrackers = await TrackerManagementService.GetDetectedTrackersAsync();

            if (scannedTrackers?.Any() == true)
            {
                // Filtrar solo los trackers NO registrados para mostrar en "Descubrir Trackers"
                _unregisteredTrackers = scannedTrackers.Where(t => t.Id == 0).ToList();
                var registeredCount = scannedTrackers.Count(t => t.Id > 0);

                string message;
                if (_unregisteredTrackers.Any())
                {
                    message = $"Se encontraron {_unregisteredTrackers.Count} dispositivos nuevos para registrar";
                    if (registeredCount > 0)
                    {
                        message += $" (y {registeredCount} ya registrados)";
                    }
                }
                else
                {
                    message = registeredCount > 0
                        ? $"Todos los dispositivos encontrados ({registeredCount}) ya están registrados"
                        : "No se encontraron dispositivos transmitiendo";
                }

                // Actualizar estado del servicio con todos los trackers para referencia
                StateService.UpdateScanState(scannedTrackers, message, true);

                _trackerMessage = message;
                _trackerSuccess = true;
            }
            else
            {
                _trackerMessage = "No se encontraron dispositivos transmitiendo señales GPS";
                _trackerSuccess = false;
                _unregisteredTrackers = new List<TrackerDiscoveryDto>();

                // Limpiar estado si no hay trackers
                StateService.ScannedTrackers = new List<TrackerDiscoveryDto>();
                StateService.LastScanTime = DateTime.UtcNow;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = $"Error durante el escaneo: {ex.Message}";
            _trackerSuccess = false;
            _unregisteredTrackers = new List<TrackerDiscoveryDto>();
        }
    }

    private async Task RegisterTracker(string deviceId)
    {
        ClearMessages();

        try
        {
            var success = await TrackerManagementService.RegisterDetectedTrackerAsync(deviceId);

            if (success)
            {
                _trackerMessage = "Tracker registrado exitosamente";
                _trackerSuccess = true;

                // Remover el tracker de la lista de no registrados
                _unregisteredTrackers = _unregisteredTrackers.Where(t => t.DeviceId != deviceId).ToList();

                // Refresh "Mis Trackers" data
                await LoadMyTrackers();

                // Update scanned trackers list - mark as registered
                if (StateService.ScannedTrackers != null)
                {
                    var tracker = StateService.ScannedTrackers.FirstOrDefault(t => t.DeviceId == deviceId);
                    if (tracker != null)
                    {
                        tracker.Id = 1; // Mark as registered
                        tracker.Status = "Registered";
                    }
                }

                StateHasChanged();
            }
            else
            {
                _trackerMessage = "Error registrando el tracker";
                _trackerSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = $"Error: {ex.Message}";
            _trackerSuccess = false;
        }
    }


    private async Task LoadMyTrackers()
    {
        try
        {
            _trackerMessage = "Cargando mis trackers...";
            StateService.MyTrackers = await TrackerManagementService.GetMyTrackersAsync();
            _trackerMessage = $"Cargados {StateService.MyTrackers?.Count ?? 0} trackers";
            _trackerSuccess = true;
        }
        catch (Exception ex)
        {
            _trackerMessage = $"Error cargando mis trackers: {ex.Message}";
            _trackerSuccess = false;
        }
    }

    private async Task RefreshTrackerData()
    {
        ClearMessages();
        await LoadMyTrackers();
        StateHasChanged();
    }

    private void ConfirmDeleteTracker(CustomerTrackerDto tracker)
    {
        _trackerToDelete = tracker;
        _showDeleteModal = true;
    }

    private void CancelDeleteTracker()
    {
        _showDeleteModal = false;
        _trackerToDelete = null;
    }

    private async Task ExecuteDeleteTracker()
    {
        if (_trackerToDelete == null) return;

        _showDeleteModal = false;
        _deletingTrackerId = _trackerToDelete.TrackerId;
        ClearMessages();
        StateHasChanged();

        try
        {
            var result = await FarmTrackerService.DeleteTrackerAsync(_trackerToDelete.TrackerId);
            if (result.success)
            {
                _trackerMessage = $"Tracker '{_trackerToDelete.TrackerName}' eliminado correctamente";
                _trackerSuccess = true;
                await LoadMyTrackers();
            }
            else
            {
                _trackerMessage = $"Error eliminando tracker: {result.message}";
                _trackerSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _trackerMessage = $"Error: {ex.Message}";
            _trackerSuccess = false;
        }
        finally
        {
            _deletingTrackerId = -1;
            _trackerToDelete = null;
            StateHasChanged();
        }
    }

    private async Task SetActiveTab(string tab)
    {
        _loadingTab = true;
        StateService.ActiveTab = tab;
        ClearMessages();
        StateHasChanged(); // Forzar actualización de UI inmediata

        try
        {
            // Lazy loading: Solo cargar datos cuando realmente se necesiten
            if (tab == "assignment" && (_farms == null || !_farms.Any()))
            {
                await LoadFarms();
            }
            else if (tab == "my-trackers")
            {
                // Siempre cargar "Mis Trackers" para asegurar datos actualizados
                await LoadMyTrackers();
            }
            else if (tab == "discovery")
            {
                // Reset unregistered trackers when switching to discovery tab
                _unregisteredTrackers = new List<TrackerDiscoveryDto>();
            }
            else if (tab == "notifications")
            {
                await LoadNotificationSettings();
            }
        }
        finally
        {
            _loadingTab = false;
            StateHasChanged();
        }
    }


    private void ClearMessages()
    {
        _licenseMessage = null;
        _trackerMessage = null;
        _notificationMessage = null;
    }

    private async Task LoadNotificationSettings()
    {
        try
        {
            _notificationSettings = await NotificationSettingsService.GetSettingsAsync()
                                    ?? new NotificationSettingsModel();
        }
        catch (Exception ex)
        {
            _notificationMessage = "Error cargando preferencias de notificacion";
            _notificationSuccess = false;
            _notificationSettings = new NotificationSettingsModel();
        }
    }

    private async Task SaveNotificationSettings()
    {
        if (_notificationSettings == null) return;

        _isSavingNotifications = true;
        _notificationMessage = null;
        StateHasChanged();

        try
        {
            var success = await NotificationSettingsService.UpdateSettingsAsync(_notificationSettings);
            _notificationMessage = success
                ? "Preferencias guardadas correctamente"
                : "Error al guardar las preferencias";
            _notificationSuccess = success;
        }
        catch (Exception ex)
        {
            _notificationMessage = $"Error: {ex.Message}";
            _notificationSuccess = false;
        }
        finally
        {
            _isSavingNotifications = false;
            StateHasChanged();
        }
    }

    private double GetProgressPercentage(int current, int max)
    {
        if (max == 0) return 0;
        return Math.Min((double)current / max * 100, 100);
    }

    /// <summary>
    /// Starts the automatic update timer for real-time tracker discovery updates
    /// </summary>
    private void StartAutoUpdate()
    {
        StopAutoUpdate(); // Stop any existing timer
        _updateTimer = new Timer(async _ => await UpdateTrackerDiscoveryData(), null, _updateInterval, _updateInterval);
    }

    /// <summary>
    /// Stops the automatic update timer
    /// </summary>
    private void StopAutoUpdate()
    {
        _updateTimer?.Dispose();
        _updateTimer = null;
    }

    /// <summary>
    /// Updates tracker discovery data in the background - optimized for real-time updates
    /// </summary>
    private async Task UpdateTrackerDiscoveryData()
    {
        // Only poll when discovery tab is active (tab is commented out, so this rarely runs)
        if (_isLoading || StateService.CustomerInfo == null || StateService.ActiveTab != "discovery")
            return;

        try
        {
            var scannedTrackers = await TrackerManagementService.GetDetectedTrackersAsync();

            if (scannedTrackers?.Any() == true)
            {
                var unregisteredCount = scannedTrackers.Count(t => t.Id == 0);
                var registeredCount = scannedTrackers.Count(t => t.Id > 0);

                string message = unregisteredCount > 0
                    ? $"Se encontraron {unregisteredCount} dispositivos nuevos y {registeredCount} ya registrados"
                    : $"Se encontraron {registeredCount} dispositivos registrados transmitiendo";

                StateService.UpdateScanState(scannedTrackers, message, true);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating tracker discovery data: {ex.Message}");
        }
    }

    /// <summary>
    /// Implements IDisposable to clean up the timer
    /// </summary>
    public void Dispose()
    {
        StopAutoUpdate();
    }

    // Geofencing and Farm Management Methods

    private async Task LoadFarms()
    {
        try
        {
            _farms = await FarmService.GetFarmsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading farms: {ex.Message}");
            _farms = new List<FarmDto>();
        }
    }

    private void SelectFarmForAssignment(FarmDto farm)
    {
        _selectedFarm = farm;
        ClearMessages();
    }


}

