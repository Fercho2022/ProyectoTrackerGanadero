@page "/inventory"
@using TrackerGanadero.Shared.Models
@using TrackerGanadero.Shared.Services
@inject AnimalService AnimalService
@inject HttpService HttpService

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">📦 Inventario y Finanzas</h2>
                    <p class="text-muted">Control de compras, ventas y transacciones</p>
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select" @onchange="OnPeriodChanged">
                        <option value="30">Últimos 30 días</option>
                        <option value="90">Últimos 3 meses</option>
                        <option value="365">Último año</option>
                    </select>
                    <button class="btn btn-success" @onclick="ShowAddTransactionModal">
                        <i class="fas fa-plus"></i> Nueva Transacción
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Financial Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">$@_totalSales.ToString("N0")</h4>
                            <p class="mb-0">Total Ventas</p>
                        </div>
                        <i class="fas fa-arrow-up fa-2x"></i>
                    </div>
                    <div class="mt-2">
                        <small>@_salesCount transacciones</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">$@_totalPurchases.ToString("N0")</h4>
                            <p class="mb-0">Total Compras</p>
                        </div>
                        <i class="fas fa-arrow-down fa-2x"></i>
                    </div>
                    <div class="mt-2">
                        <small>@_purchasesCount transacciones</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">$@_netProfit.ToString("N0")</h4>
                            <p class="mb-0">Ganancia Neta</p>
                        </div>
                        <i class="fas @(_netProfit >= 0 ? "fa-chart-line" : "fa-chart-line-down") fa-2x"></i>
                    </div>
                    <div class="mt-2">
                        <small>@(_netProfit >= 0 ? "Ganancia" : "Pérdida")</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@_averageAnimalPrice.ToString("C0")</h4>
                            <p class="mb-0">Precio Promedio</p>
                        </div>
                        <i class="fas fa-calculator fa-2x"></i>
                    </div>
                    <div class="mt-2">
                        <small>Por animal vendido</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Weight and Price Analysis -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">📊 Análisis de Peso vs Precio</h5>
                </div>
                <div class="card-body">
                    @if (_weightRecords?.Any() == true)
                    {
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-center">
                                    <div class="display-6 text-primary">@_averageWeight.ToString("F1")</div>
                                    <small class="text-muted">Peso Promedio (kg)</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center">
                                    <div class="display-6 text-success">@_averagePricePerKg.ToString("C2")</div>
                                    <small class="text-muted">Precio por kg</small>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                    <span>Peso mínimo:</span>
                                    <span class="fw-bold">@_minWeight.ToString("F1") kg</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                    <span>Peso máximo:</span>
                                    <span class="fw-bold">@_maxWeight.ToString("F1") kg</span>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-weight fa-2x mb-2"></i>
                            <p>No hay datos de peso disponibles</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">🐄 Inventario de Animales</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                <div>
                                    <div class="fw-bold">Total Animales</div>
                                    <small class="text-muted">En inventario</small>
                                </div>
                                <div class="text-end">
                                    <div class="fs-4 fw-bold">@_totalAnimals</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                <div>
                                    <div class="fw-bold">Machos</div>
                                    <small class="text-muted">Reproductores</small>
                                </div>
                                <div class="text-end">
                                    <div class="fs-4 fw-bold text-primary">@_maleCount</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                <div>
                                    <div class="fw-bold">Hembras</div>
                                    <small class="text-muted">Reproductoras</small>
                                </div>
                                <div class="text-end">
                                    <div class="fs-4 fw-bold text-danger">@_femaleCount</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                                <div>
                                    <div class="fw-bold">Valor Estimado</div>
                                    <small class="text-muted">Total inventario</small>
                                </div>
                                <div class="text-end">
                                    <div class="fs-5 fw-bold text-success">@_estimatedInventoryValue.ToString("C0")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters and Search -->
    <div class="row mb-3">
        <div class="col-md-3">
            <select class="form-select" @onchange="OnTransactionTypeChanged">
                <option value="">Todos los tipos</option>
                <option value="sale">Ventas</option>
                <option value="purchase">Compras</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="date" class="form-control" @onchange="OnDateFilterChanged" />
        </div>
        <div class="col-md-3">
            <select class="form-select" @onchange="OnAnimalFilterChanged">
                <option value="">Todos los animales</option>
                @if (_animals != null)
                {
                    @foreach (var animal in _animals)
                    {
                        <option value="@animal.Id">@animal.Name (@animal.Tag)</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Buscar transacciones..."
                       @bind="_searchTerm" @oninput="OnSearchChanged" />
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">💰 Transacciones (@_filteredTransactions.Count)</h5>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshTransactions">
                                <i class="fas fa-sync-alt"></i> Actualizar
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="ExportTransactions">
                                <i class="fas fa-download"></i> Exportar
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (_isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3">Cargando transacciones...</p>
                        </div>
                    }
                    else if (_filteredTransactions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Tipo</th>
                                        <th>Animal</th>
                                        <th>Comprador/Vendedor</th>
                                        <th>Peso</th>
                                        <th>Precio/kg</th>
                                        <th>Monto Total</th>
                                        <th>Factura</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var transaction in _filteredTransactions.OrderByDescending(t => t.TransactionDate))
                                    {
                                        <tr>
                                            <td>
                                                <div>
                                                    <strong>@transaction.TransactionDate.ToString("dd/MM/yyyy")</strong>
                                                    <br />
                                                    <small class="text-muted">@transaction.TransactionDate.ToString("HH:mm")</small>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-@GetTransactionTypeBadgeColor(transaction.Type)">
                                                    <i class="fas @GetTransactionTypeIcon(transaction.Type)"></i>
                                                    @GetTransactionTypeDisplayName(transaction.Type)
                                                </span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(transaction.AnimalName))
                                                {
                                                    <div>
                                                        <strong>@transaction.AnimalName</strong>
                                                        <br />
                                                        <small class="text-muted">ID: @transaction.AnimalId</small>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No especificado</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(transaction.BuyerSeller))
                                                {
                                                    <span>@transaction.BuyerSeller</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No especificado</span>
                                                }
                                            </td>
                                            <td>
                                                @if (transaction.Weight.HasValue)
                                                {
                                                    <span>@transaction.Weight.Value.ToString("F1") kg</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (transaction.PricePerKg.HasValue)
                                                {
                                                    <span>@transaction.PricePerKg.Value.ToString("C2")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="fw-bold text-@(transaction.Type == "sale" ? "success" : "danger")">
                                                    @(transaction.Type == "sale" ? "+" : "-")@transaction.Amount.ToString("C0")
                                                </span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(transaction.InvoiceNumber))
                                                {
                                                    <span class="badge bg-secondary">@transaction.InvoiceNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Sin factura</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" @onclick="() => ViewTransactionDetails(transaction)" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary" @onclick="() => EditTransaction(transaction)" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => DeleteTransaction(transaction)" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-receipt fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No se encontraron transacciones</h5>
                            <p class="text-muted">Agrega la primera transacción o ajusta los filtros</p>
                            <button class="btn btn-success" @onclick="ShowAddTransactionModal">
                                <i class="fas fa-plus"></i> Nueva Transacción
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Transaction Modal -->
<div class="modal fade @(_showModal ? "show d-block" : "")" tabindex="-1" style="@(_showModal ? "background: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(_editingTransaction != null ? "Editar Transacción" : "Nueva Transacción")
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <EditForm Model="@_transactionForm" OnValidSubmit="@SaveTransaction">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Tipo de Transacción *</label>
                                <InputSelect class="form-select" @bind-Value="_transactionForm.Type">
                                    <option value="">Seleccionar tipo</option>
                                    <option value="sale">Venta</option>
                                    <option value="purchase">Compra</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _transactionForm.Type)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Fecha *</label>
                                <InputDate class="form-control" @bind-Value="_transactionForm.TransactionDate" />
                                <ValidationMessage For="@(() => _transactionForm.TransactionDate)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Animal</label>
                                <InputSelect class="form-select" @bind-Value="_transactionForm.AnimalId">
                                    <option value="">Seleccionar animal (opcional)</option>
                                    @if (_animals != null)
                                    {
                                        @foreach (var animal in _animals)
                                        {
                                            <option value="@animal.Id">@animal.Name (@animal.Tag)</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Comprador/Vendedor</label>
                                <InputText class="form-control" @bind-Value="_transactionForm.BuyerSeller" placeholder="Nombre del comprador o vendedor" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Peso (kg)</label>
                                <InputNumber class="form-control" @bind-Value="_transactionForm.Weight" placeholder="0.0" step="0.1" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Precio por kg</label>
                                <InputNumber class="form-control" @bind-Value="_transactionForm.PricePerKg" placeholder="0.00" step="0.01" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Monto Total *</label>
                                <InputNumber class="form-control" @bind-Value="_transactionForm.Amount" placeholder="0.00" step="0.01" />
                                <ValidationMessage For="@(() => _transactionForm.Amount)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Número de Factura</label>
                                <InputText class="form-control" @bind-Value="_transactionForm.InvoiceNumber" placeholder="Número de factura" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Granja</label>
                                <InputSelect class="form-select" @bind-Value="_transactionForm.FarmId">
                                    <option value="0">Seleccionar granja</option>
                                    @if (_farms != null)
                                    {
                                        @foreach (var farm in _farms)
                                        {
                                            <option value="@farm.Id">@farm.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="_transactionForm.Description" placeholder="Descripción adicional de la transacción" />
                    </div>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">
                            @_errorMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button type="submit" class="btn btn-success" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(_editingTransaction != null ? "Guardar Cambios" : "Guardar Transacción")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private List<AnimalDto> _animals = new();
    private List<FarmDto> _farms = new();
    private List<TransactionDto> _transactions = new();
    private List<TransactionDto> _filteredTransactions = new();
    private List<WeightRecordDto> _weightRecords = new();

    private int _daysPeriod = 30;
    private string _transactionTypeFilter = "";
    private DateTime? _dateFilter;
    private int? _animalFilter;
    private string _searchTerm = "";
    private bool _isLoading = true;
    private bool _showModal = false;
    private bool _isSaving = false;
    private string _errorMessage = "";

    // Financial Statistics
    private decimal _totalSales = 0;
    private decimal _totalPurchases = 0;
    private decimal _netProfit = 0;
    private decimal _averageAnimalPrice = 0;
    private int _salesCount = 0;
    private int _purchasesCount = 0;

    // Inventory Statistics
    private int _totalAnimals = 0;
    private int _maleCount = 0;
    private int _femaleCount = 0;
    private decimal _estimatedInventoryValue = 0;
    private decimal _averageWeight = 0;
    private decimal _minWeight = 0;
    private decimal _maxWeight = 0;
    private decimal _averagePricePerKg = 0;

    private TransactionDto? _editingTransaction;
    private CreateTransactionDto _transactionForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            await LoadAnimals();
            await LoadFarms();
            await LoadTransactions();
            await LoadWeightRecords();

            CalculateStatistics();
            ApplyFilters();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAnimals()
    {
        try
        {
            _animals = await AnimalService.GetAnimalsAsync();
            CalculateInventoryStatistics();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading animals: {ex.Message}");
        }
    }

    private async Task LoadFarms()
    {
        try
        {
            // In a real implementation: _farms = await FarmService.GetFarmsAsync();
            _farms = new List<FarmDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading farms: {ex.Message}");
        }
    }

    private async Task LoadTransactions()
    {
        try
        {
            // In a real implementation: _transactions = await TransactionService.GetTransactionsAsync();
            _transactions = new List<TransactionDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading transactions: {ex.Message}");
        }
    }

    private async Task LoadWeightRecords()
    {
        try
        {
            // In a real implementation: _weightRecords = await WeightService.GetWeightRecordsAsync();
            _weightRecords = new List<WeightRecordDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading weight records: {ex.Message}");
        }
    }

    private void CalculateInventoryStatistics()
    {
        _totalAnimals = _animals.Count;
        _maleCount = _animals.Count(a => a.Gender.ToLower() == "male");
        _femaleCount = _animals.Count(a => a.Gender.ToLower() == "female");

        if (_animals.Any())
        {
            _averageWeight = (decimal)_animals.Average(a => (double)a.Weight);
            _minWeight = _animals.Min(a => a.Weight);
            _maxWeight = _animals.Max(a => a.Weight);
        }

        // Estimate inventory value based on average market price
        var estimatedPricePerKg = 5.50m; // Example price
        _estimatedInventoryValue = _animals.Sum(a => a.Weight * estimatedPricePerKg);
    }

    private void CalculateStatistics()
    {
        var periodStart = DateTime.Now.AddDays(-_daysPeriod);
        var periodTransactions = _transactions.Where(t => t.TransactionDate >= periodStart).ToList();

        var sales = periodTransactions.Where(t => t.Type == "sale").ToList();
        var purchases = periodTransactions.Where(t => t.Type == "purchase").ToList();

        _totalSales = sales.Sum(s => s.Amount);
        _totalPurchases = purchases.Sum(p => p.Amount);
        _netProfit = _totalSales - _totalPurchases;
        _salesCount = sales.Count;
        _purchasesCount = purchases.Count;

        if (_salesCount > 0)
        {
            _averageAnimalPrice = _totalSales / _salesCount;
        }

        // Calculate average price per kg from transactions
        var transactionsWithPrice = periodTransactions.Where(t => t.PricePerKg.HasValue).ToList();
        if (transactionsWithPrice.Any())
        {
            _averagePricePerKg = transactionsWithPrice.Average(t => t.PricePerKg!.Value);
        }
    }

    private void ApplyFilters()
    {
        _filteredTransactions = _transactions.Where(transaction =>
        {
            // Type filter
            if (!string.IsNullOrEmpty(_transactionTypeFilter) &&
                transaction.Type != _transactionTypeFilter)
                return false;

            // Date filter
            if (_dateFilter.HasValue && transaction.TransactionDate.Date != _dateFilter.Value.Date)
                return false;

            // Animal filter
            if (_animalFilter.HasValue && transaction.AnimalId != _animalFilter.Value)
                return false;

            // Search filter
            if (!string.IsNullOrEmpty(_searchTerm))
            {
                var searchLower = _searchTerm.ToLower();
                if (!transaction.Description?.ToLower().Contains(searchLower) == true &&
                    !transaction.BuyerSeller?.ToLower().Contains(searchLower) == true &&
                    !transaction.InvoiceNumber?.ToLower().Contains(searchLower) == true)
                {
                    return false;
                }
            }

            return true;
        }).ToList();

        StateHasChanged();
    }

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var days))
        {
            _daysPeriod = days;
            CalculateStatistics();
        }
    }

    private void OnTransactionTypeChanged(ChangeEventArgs e)
    {
        _transactionTypeFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnDateFilterChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            _dateFilter = date;
        }
        else
        {
            _dateFilter = null;
        }
        ApplyFilters();
    }

    private void OnAnimalFilterChanged(ChangeEventArgs e)
    {
        var animalIdStr = e.Value?.ToString();
        _animalFilter = string.IsNullOrEmpty(animalIdStr) ? null : int.Parse(animalIdStr);
        ApplyFilters();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

