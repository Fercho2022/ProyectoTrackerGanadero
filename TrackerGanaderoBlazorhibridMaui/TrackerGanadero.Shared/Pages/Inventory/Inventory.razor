    private string GetTransactionTypeBadgeColor(string type)
    {
        return type.ToLower() switch
        {
            "sale" => "success",
            "purchase" => "danger",
            _ => "secondary"
        };
    }

    private string GetTransactionTypeIcon(string type)
    {
        return type.ToLower() switch
        {
            "sale" => "fa-arrow-up",
            "purchase" => "fa-arrow-down",
            _ => "fa-exchange-alt"
        };
    }

    private string GetTransactionTypeDisplayName(string type)
    {
        return type.ToLower() switch
        {
            "sale" => "Venta",
            "purchase" => "Compra",
            _ => type
        };
    }

