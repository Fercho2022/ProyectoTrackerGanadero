        console.log("- Markers count:", Object.keys(markers).length);
        console.log("- Leaflet available:", typeof L !== 'undefined');
        console.log("- Farm boundaries count:", farmBoundaries ? farmBoundaries.length : 0);
    };

    // Variables for farm boundaries
    let farmBoundaries = [];

    // Function to add farm boundary to map
    window.addFarmBoundary = function(farmId, farmName, coordinates) {
        console.log(`Adding boundary for farm ${farmName} (ID: ${farmId}) with ${coordinates.length} points`);

        if (!map || !mapInitialized) {
            console.warn("Map not ready for adding boundaries");
            return;
        }

        try {
            // Convert coordinates to Leaflet format
            const latlngs = coordinates.map(coord => [coord.lat, coord.lng]);

            // Create polygon
            const polygon = L.polygon(latlngs, {
                color: '#3388ff',
                weight: 3,
                opacity: 0.8,
                fillColor: '#3388ff',
                fillOpacity: 0.1
            }).addTo(map);

            // Add popup with farm name
            polygon.bindPopup(`
                <div style="text-align: center; padding: 5px;">
                    <strong>🏛️ ${farmName}</strong><br>
                    <small>Área de Geofencing</small><br>
                    <small>${coordinates.length} puntos</small>
                </div>
            `);

            // Store boundary reference
            farmBoundaries.push({
                farmId: farmId,
                farmName: farmName,
                polygon: polygon
            });

            console.log(`✅ Boundary added for farm ${farmName}`);
        } catch (error) {
            console.error(`Error adding boundary for farm ${farmName}:`, error);
        }
    };

    // Function to clear all farm boundaries
    window.clearAllBoundaries = function() {
        console.log("Clearing all farm boundaries");

        if (!map) {
            console.warn("Map not available for clearing boundaries");
            return;
        }

        // Remove all polygons from map
        farmBoundaries.forEach(boundary => {
            try {
                map.removeLayer(boundary.polygon);
            } catch (error) {
                console.error("Error removing boundary:", error);
            }
        });

        // Clear the array
        farmBoundaries = [];
        console.log("✅ All farm boundaries cleared");
    };

    // ==================== GPS NAVIGATION FUNCTIONS ====================

    // Draws a route on the map between user location and animal
    // routeData: Route data with coordinates, distance, duration
    window.drawRoute = function(routeData) {
        console.log("drawRoute called with data:", routeData);
        window.clearRoute(); // Clear any existing route first

        if (!map || !mapInitialized) {
            console.warn("Map not initialized");
            return;
        }

        try {
            // Convert coordinates and get start/end points
            const latlngs = routeData.coordinates.map(coord => [coord.latitude, coord.longitude]);
            if (latlngs.length < 2) {
                console.warn("Route has less than 2 points, cannot draw.");
                return;
            }
            const startPoint = latlngs[0];
            const endPoint = latlngs[latlngs.length - 1];

            // Create route polyline
            routeLayer = L.polyline(latlngs, {
                color: '#0d6efd', weight: 6, opacity: 0.8, lineJoin: 'round'
            }).addTo(map);

            // --- Start marker (user location) ---
            const startIcon = L.divIcon({
                className: 'location-marker',
                html: '<div class="pulse"></div><div class="dot"></div>',
                iconSize: [20, 20],
                iconAnchor: [10, 10]
            });
            routeStartMarker = L.marker(startPoint, { icon: startIcon }).addTo(map).bindPopup("Tu ubicación");

            // --- End marker (destination) ---
            const endIcon = L.divIcon({
                className: 'destination-pin-marker',
                html: '<div><i class="fas fa-map-marker-alt fa-3x" style="color: #dc3545;"></i></div>',
                iconSize: [30, 42],
                iconAnchor: [15, 42] // bottom center of the icon
            });
            routeEndMarker = L.marker(endPoint, { icon: endIcon }).addTo(map).bindPopup(routeData.animalName || "Destino");

            // Fit map to route
            map.fitBounds(routeLayer.getBounds(), { padding: [60, 60], maxZoom: 17 });

            console.log("✅ Route drawn successfully");
        } catch (error) {
            console.error("Error drawing route:", error);
        }
    };

    /**
     * Clears the active route from the map
     */
    window.clearRoute = function() {
        console.log("clearRoute called");

        if (routeLayer) {
            map.removeLayer(routeLayer);
            routeLayer = null;
        }

        if (routeStartMarker) {
            map.removeLayer(routeStartMarker);
            routeStartMarker = null;
        }

        if (routeEndMarker) {
            map.removeLayer(routeEndMarker);
            routeEndMarker = null;
        }

        console.log("✅ Route cleared");
    };

    /**
     * Updates only the end marker position when animal moves slightly
     * @@param {number} lat - New latitude
     * @@param {number} lng - New longitude
     */
    window.updateRouteEndMarker = function(lat, lng) {
        console.log(`📍 Updating route end marker to (${lat}, ${lng})`);

        if (!routeEndMarker) {
            console.warn("No route end marker to update");
            return;
        }

        try {
            const newLatLng = [lat, lng];
            routeEndMarker.setLatLng(newLatLng);
            routeEndMarker.setPopupContent("Destino (actualizado)");
            console.log("✅ Route end marker updated successfully");
        } catch (error) {
            console.error("Error updating route end marker:", error);
        }
    };

    /**
     * Updates the start marker position (user location) during movement simulation
     * @@param {number} lat - New latitude
     * @@param {number} lng - New longitude
     */
    window.updateRouteStartMarker = function(lat, lng) {
        console.log(`🚶 Updating user position marker to (${lat}, ${lng})`);

        if (!routeStartMarker) {
            console.warn("No route start marker to update");
            return;
        }

        try {
            // Update marker position with smooth animation
            const newLatLng = [lat, lng];
            routeStartMarker.setLatLng(newLatLng);

            // Update popup content with current position
            routeStartMarker.setPopupContent(`Tu ubicación actual<br><small>${lat.toFixed(6)}, ${lng.toFixed(6)}</small>`);

            if (routeStartMarker && routeEndMarker) {
                const group = new L.featureGroup([routeStartMarker, routeEndMarker]);
                map.fitBounds(group.getBounds(), { padding: [70, 70], maxZoom: 18, animate: true });
            }


            console.log("✅ User position marker updated successfully");
        } catch (error) {
            console.error("Error updating user position marker:", error);
        }
    };

    /**
     * Updates the route polyline to show only remaining path (removes traveled segments)
     * @@param {Array} remainingCoordinates - Array of {latitude, longitude} for remaining route
     */
    window.updateRemainingRoute = function(remainingCoordinates) {
        console.log(`🛣️ Updating route - showing ${remainingCoordinates.length} remaining points`);

        if (!routeLayer) {
            console.warn("No route layer to update");
            return;
        }

        try {
            // Convert coordinates to Leaflet format
            const latLngs = remainingCoordinates.map(coord => [coord.latitude, coord.longitude]);

            // Update the polyline with remaining coordinates
            routeLayer.setLatLngs(latLngs);

            console.log("✅ Route updated - traveled segments removed");
        } catch (error) {
            console.error("Error updating remaining route:", error);
        }
    };
</script>

<!-- Leaflet Decorators for Directional Arrows on Route -->
<script src="https://unpkg.com/leaflet-polylinedecorator@1.6.0/dist/leaflet.polylineDecorator.js"></script>

<script>
    // Store decorator for cleanup
    let routeDecorator = null;

    /**
     * Enhanced drawRoute with directional arrows
     */
    const originalDrawRoute = window.drawRoute;
    window.drawRoute = function(routeData) {
        // Call original draw function
        originalDrawRoute(routeData);

        try {
            // Remove existing decorator if any
            if (routeDecorator) {
                map.removeLayer(routeDecorator);
                routeDecorator = null;
            }

            // Add directional arrows along the route
            if (routeLayer) {
                routeDecorator = L.polylineDecorator(routeLayer, {
                    patterns: [
                        {
                            offset: '10%',
                            repeat: 100, // Arrow every 100 pixels
                            symbol: L.Symbol.arrowHead({
                                pixelSize: 15,
                                pathOptions: {
                                    fillOpacity: 1,
                                    weight: 0,
                                    color: '#2196F3'
                                }
                            })
                        }
                    ]
                }).addTo(map);

                console.log("✅ Directional arrows added to route");
            }
        } catch (error) {
            console.error("Error adding route decorators:", error);
        }

        // Note: Panel is now draggable by user, no auto-repositioning
        console.log("✅ Route drawn - panel can be dragged to desired position");
    };

    /**
     * Enhanced clearRoute to also remove decorators
     */
    const originalClearRoute = window.clearRoute;
    window.clearRoute = function() {
        // Remove decorator first
        if (routeDecorator) {
            try {
                map.removeLayer(routeDecorator);
                routeDecorator = null;
                console.log("✅ Route decorators cleared");
            } catch (error) {
                console.error("Error clearing decorators:", error);
            }
        }

        // Call original clear function
        originalClearRoute();
    };

    // Helper function to check if a point is inside a polygon using ray casting
    function isPointInsidePolygon(point, polygon) {
        let x = point[0], y = point[1];
        let inside = false;
        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            let xi = polygon[i][0], yi = polygon[i][1];
            let xj = polygon[j][0], yj = polygon[j][1];
            if (((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) {
                inside = !inside;
            }
        }
        return inside;
    }

    // Helper function to generate a random point inside a polygon
    window.generatePointInsidePolygon = function(boundaries) {
        if (!boundaries || boundaries.length < 3) {
            console.warn("Invalid polygon boundaries");
            return null;
        }

        // Convert boundaries to format [lat, lng]
        // boundaries viene de C# como {lat, lng} (camelCase por JSON.NET)
        const polygon = boundaries.map(coord => [coord.lat, coord.lng]);

        // Get bounding box
        const lats = polygon.map(p => p[0]);
        const lngs = polygon.map(p => p[1]);
        const minLat = Math.min(...lats);
        const maxLat = Math.max(...lats);
        const minLng = Math.min(...lngs);
        const maxLng = Math.max(...lngs);

        // Try to find a random point inside the polygon (max 100 attempts)
        for (let i = 0; i < 100; i++) {
            const randomLat = minLat + Math.random() * (maxLat - minLat);
            const randomLng = minLng + Math.random() * (maxLng - minLng);
            const point = [randomLat, randomLng];

            if (isPointInsidePolygon(point, polygon)) {
                console.log(`✅ Generated point inside polygon: (${randomLat}, ${randomLng})`);
                // Return with PascalCase for C# interop
                return { Latitude: randomLat, Longitude: randomLng };
            }
        }

        // Fallback: return center of polygon if we couldn't find a point inside
        const centerLat = (minLat + maxLat) / 2;
        const centerLng = (minLng + maxLng) / 2;
        console.warn(`⚠️ Could not generate point inside polygon, using center: (${centerLat}, ${centerLng})`);
        // Return with PascalCase for C# interop
        return { Latitude: centerLat, Longitude: centerLng };
    };

    // ==================== DRAGGABLE ROUTE INFO PANEL ====================
    (function() {
        let isDragging = false;
        let currentX = 0;
        let currentY = 0;
        let initialX = 0;
        let initialY = 0;
        let xOffset = 0;
        let yOffset = 0;

        // Initialize drag functionality when the panel appears
        function initDraggable() {
            const container = document.getElementById('route-info-container');
            const header = document.querySelector('.route-info-header');

            if (!container || !header) {
                // Panel not available yet, try again in 100ms
                setTimeout(initDraggable, 100);
                return;
            }

            // Reset any previous listeners
            header.removeEventListener('mousedown', dragStart);
            header.removeEventListener('touchstart', dragStart);

            // Add event listeners
            header.addEventListener('mousedown', dragStart, false);
            header.addEventListener('touchstart', dragStart, false);

            console.log('✅ Route info panel is now draggable');
        }

        function dragStart(e) {
            const container = document.getElementById('route-info-container');
            const panel = document.querySelector('.route-info-panel');
            if (!container) return;

            // Prevent default to avoid text selection
            if (e.type === 'touchstart') {
                initialX = e.touches[0].clientX - xOffset;
                initialY = e.touches[0].clientY - yOffset;
            } else {
                initialX = e.clientX - xOffset;
                initialY = e.clientY - yOffset;
            }

            // Only start dragging if clicking on the header (not buttons)
            if (e.target.closest('.btn-close')) return;

            isDragging = true;

            // Add dragging class for visual feedback
            if (container) container.classList.add('dragging');
            if (panel) panel.classList.add('dragging');

            // Add move and end listeners
            document.addEventListener('mousemove', drag, false);
            document.addEventListener('mouseup', dragEnd, false);
            document.addEventListener('touchmove', drag, false);
            document.addEventListener('touchend', dragEnd, false);
        }

        function drag(e) {
            if (!isDragging) return;

            e.preventDefault();

            const container = document.getElementById('route-info-container');
            if (!container) return;

            if (e.type === 'touchmove') {
                currentX = e.touches[0].clientX - initialX;
                currentY = e.touches[0].clientY - initialY;
            } else {
                currentX = e.clientX - initialX;
                currentY = e.clientY - initialY;
            }

            xOffset = currentX;
            yOffset = currentY;

            // Apply transform to move the panel
            setTranslate(currentX, currentY, container);
        }

        function dragEnd(e) {
            isDragging = false;

            // Remove dragging class
            const container = document.getElementById('route-info-container');
            const panel = document.querySelector('.route-info-panel');
            if (container) container.classList.remove('dragging');
            if (panel) panel.classList.remove('dragging');

            // Remove move and end listeners
            document.removeEventListener('mousemove', drag);
            document.removeEventListener('mouseup', dragEnd);
            document.removeEventListener('touchmove', drag);
            document.removeEventListener('touchend', dragEnd);
        }

        function setTranslate(xPos, yPos, el) {
            el.style.transform = `translate(${xPos}px, ${yPos}px)`;
        }

        // Reset position when route is cleared
        const originalClearRouteFunc = window.clearRoute;
        window.clearRoute = function() {
            xOffset = 0;
            yOffset = 0;
            const container = document.getElementById('route-info-container');
            if (container) {
                container.style.transform = 'translate(0px, 0px)';
            }
            originalClearRouteFunc();
        };

        // Initialize when the page loads
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initDraggable);
        } else {
            initDraggable();
        }

        // Also re-initialize when a new route is drawn
        const originalDrawRouteFunc = window.drawRoute;
        window.drawRoute = function(routeData) {
            originalDrawRouteFunc(routeData);
            // Reset position when new route is drawn
            xOffset = 0;
            yOffset = 0;
            setTimeout(initDraggable, 200);
        };
    })();
</script>