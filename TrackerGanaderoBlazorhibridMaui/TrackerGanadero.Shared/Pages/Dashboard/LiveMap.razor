                    maxZoom: 19
                });

                osmLayer.addTo(map);

                // Wait for map to render completely
                map.whenReady(() => {
                    console.log("Fresh map is ready and rendered");
                    mapInitialized = true;

                    // Invalidate size to ensure proper rendering
                    setTimeout(() => {
                        map.invalidateSize();
