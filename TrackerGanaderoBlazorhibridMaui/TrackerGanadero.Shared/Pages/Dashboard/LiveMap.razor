            }

            // Clear markers
            markers = {};

            // Clear center marker
            if (window.centerMarker) {
                window.centerMarker = null;
            }

            mapInitialized = false;

            console.log("Map cleanup completed");
        } catch (error) {
            console.error("Error during map cleanup:", error);
        }
    };

