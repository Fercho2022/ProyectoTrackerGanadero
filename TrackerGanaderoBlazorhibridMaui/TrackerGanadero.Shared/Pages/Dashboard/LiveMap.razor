@page "/live-map"
@using TrackerGanadero.Shared.Models
@using TrackerGanadero.Shared.Services
@inject TrackingService TrackingService
@inject FarmService FarmService
@inject SignalRService SignalRService
@inject NavigationService NavigationService
@inject VoiceNavigationService VoiceNavigationService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">🗺️ Mapa en Tiempo Real</h2>
                    <p class="text-muted">Ubicación en vivo de todos los animales</p>
                </div>
                <div class="d-flex gap-2 map-header-controls">
                    <select class="form-select" @onchange="OnFarmSelected">
                        <option value="">Todas las granjas</option>
                        @if (_farms != null)
                        {
                            @foreach (var farm in _farms)
                            {
                                <option value="@farm.Id">@farm.Name</option>
                            }
                        }
                    </select>
                    <button class="btn @(_showGeofencing ? "btn-success" : "btn-outline-success")"
                            @onclick="ToggleGeofencing"
                            title="@(_selectedFarmId.HasValue ? "Mostrar/Ocultar Área de Geofencing de la granja seleccionada" : "Selecciona una granja para mostrar su área")"
                            disabled="@(!_selectedFarmId.HasValue)">
                        <i class="fas @(_showGeofencing ? "fa-eye" : "fa-eye-slash")"></i>
                        @(_showGeofencing ? "Ocultar Área" : "Mostrar Área")
                    </button>
                    @if (_selectedAnimalId.HasValue)
                    {
                        <button class="btn btn-success" @onclick="ShowAllAnimals">
                            <i class="fas fa-eye"></i> Ver Todos
                        </button>
                    }
                    <button class="btn btn-outline-primary" @onclick="RefreshMap">
                        <i class="fas fa-sync-alt"></i> Actualizar
                    </button>
                    <button class="btn @(VoiceNavigationService.IsEnabled ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="ToggleVoiceNavigation"
                            title="@(VoiceNavigationService.IsEnabled ? "Desactivar voz guiada" : "Activar voz guiada")">
                        <i class="fas @(VoiceNavigationService.IsEnabled ? "fa-volume-up" : "fa-volume-mute")"></i>
                        @(VoiceNavigationService.IsEnabled ? "Voz ON" : "Voz OFF")
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Map Container -->
    <div class="row">
        <div class="col-lg-9">
            <div class="card">
                <div class="card-body p-0">
                    <div id="map" style="height: calc(100vh - 200px); width: 100%; min-height: 500px;"></div>

                    <!-- Route Info Panel -->
                    @if (_currentRoute != null)
                    {
                        <div id="route-info-container">
                            <div class="route-info-panel">
                                <div class="route-info-header">
                                    <h6><i class="fas fa-route me-2"></i>Ruta Activa</h6>
                                    <button type="button" class="btn-close btn-sm" @onclick="ClearRoute" aria-label="Cerrar"></button>
                                </div>
                                <div class="route-info-body">
                                    <div class="mb-2">
                                        <strong>Destino:</strong> @_currentRoute.AnimalName
                                    </div>
                                    <div class="mb-2">
                                        <i class="fas fa-road me-2 text-primary"></i>
                                        <strong>Distancia:</strong> @FormatDistance(_currentRoute.DistanceMeters)
                                    </div>
                                    @if (_currentRoute.DistanceToNextTurn.HasValue)
                                    {
                                        <div class="mb-2">
                                            <i class="fas fa-map-signs me-2 text-info"></i>
                                            <strong>Próximo giro:</strong> @FormatDistance(_currentRoute.DistanceToNextTurn.Value)
                                        </div>
                                    }
                                    <div class="mb-2">
                                        <i class="fas fa-clock me-2 text-success"></i>
                                        <strong>Tiempo estimado:</strong> @FormatDuration(_currentRoute.DurationSeconds)
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm w-100 mt-2" @onclick="ClearRoute">
                                        <i class="fas fa-times me-1"></i>Limpiar Ruta
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar with Animals List -->
        <div class="col-lg-3">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">🐄 Animales (@_animalLocations.Count)</h5>
                        @if (_selectedAnimalId.HasValue)
                        {
                            <small class="text-muted">
                                <i class="fas fa-eye"></i> Seguimiento individual
                            </small>
                        }
                        else
                        {
                            <small class="text-success">
                                <i class="fas fa-eye"></i> Vista completa
                            </small>
                        }
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" style="max-height: calc(100vh - 200px); min-height: 500px; overflow-y: auto;">
                        @if (_animalLocations.Any())
                        {
                            @foreach (var animal in _animalLocations)
                            {
                                <div class="list-group-item @(animal.AnimalId == _selectedAnimalId ? "active" : "")"
                                     style="cursor: pointer;"
                                     @onclick="() => SelectAnimal(animal.AnimalId)">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@animal.AnimalName</h6>
                                            @if (!string.IsNullOrEmpty(animal.Tag))
                                            {
                                                <small class="text-muted">Tag: @animal.Tag</small>
                                            }
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-@GetStatusBadgeColor(animal.Status) mb-1">
                                                @TranslateStatus(animal.Status)
                                            </span>
                                            @if (animal.Location != null)
                                            {
                                                <br />
                                                <span class="badge bg-@GetConnectionBadgeColor(animal) mb-1">
                                                    @GetConnectionStatus(animal)
                                                </span>
                                                <br />
                                                <small class="text-muted">
                                                    @animal.Location.Timestamp.ToString("HH:mm:ss")
                                                </small>
                                            }
                                        </div>
                                    </div>
                                    @if (animal.Location != null)
                                    {
                                        <div class="mt-2">
                                            <small class="text-muted">
                                                📍 @animal.Location.Latitude.ToString("F6"), @animal.Location.Longitude.ToString("F6")
                                                @if (animal.Location.Speed.HasValue)
                                                {
                                                    <br />
                                                    <text>Velocidad: @animal.Location.Speed.Value.ToString("F1") km/h</text>
                                                }
                                            </small>
                                        </div>

                                        <!-- Navigation Button -->
                                        <button class="btn btn-primary btn-sm w-100 mt-2"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => NavigateToAnimal(animal.AnimalId)"
                                                disabled="@_isCalculatingRoute">
                                            @if (_isCalculatingRoute && _selectedAnimalForRoute == animal.AnimalId)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                                <text>Calculando ruta...</text>
                                            }
                                            else
                                            {
                                                <i class="fas fa-route me-1"></i>
                                                <text>Navegar a este animal</text>
                                            }
                                        </button>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <i class="fas fa-map-marked-alt fa-3x mb-3"></i>
                                <p>No hay animales con ubicación disponible</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Loading Overlay -->
@if (_isLoading)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background-color: rgba(0,0,0,0.5); z-index: 9999;">
        <div class="card">
            <div class="card-body text-center">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <p class="mb-0">Cargando mapa...</p>
            </div>
        </div>
    </div>
}

@code {
    private List<FarmDto> _farms = new();
    private List<AnimalLocationDto> _animalLocations = new();
    private int? _selectedFarmId;
    private int? _selectedAnimalId;
    private bool _isLoading = true;
    private bool _signalRConnected = false;
    private bool _showGeofencing = false;
    private DateTime? _lastUpdate;
    private Timer? _autoRefreshTimer;
    private Timer? _selectedAnimalTrackingTimer;
    private bool _disposed = false;
    private bool _mapInitialized = false;
    private bool _isTrackingSelectedAnimal = false;

    // Route-related state
    private RouteDto? _currentRoute = null;
    private bool _isCalculatingRoute = false;
    private string? _alertMessage;
    private int? _selectedAnimalForRoute = null;
    private int? _navigatingToAnimalId = null; // Animal being actively navigated to
    private Timer? _navigationTrackingTimer = null;
    private LocationDto? _lastNavigationTargetLocation = null; // Track last known location

    // User movement simulation
    private Timer? _userMovementSimulationTimer = null;
    private int _currentRoutePointIndex = 0;
    private CoordinateDto? _currentUserPosition = null; // Track exact current position for smooth movement
    private double _traveledDistance = 0; // Total distance traveled in meters
    private const double SIMULATION_SPEED_MPS = 3; // meters per second (10.8 km/h - fast walking/light jogging)

    protected override async Task OnInitializedAsync()
    {
        await LoadFarms();
        await LoadAnimalLocations();
        await InitializeSignalR();
        InitializeAutoRefresh();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Always try to initialize the map when the component renders
        // This handles both first render and navigation back to this page
        if (!_mapInitialized)
        {
            await InitializeMap();
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadFarms()
    {
        try
        {
            _farms = await FarmService.GetFarmsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading farms: {ex.Message}");
        }
    }

    private async Task LoadAnimalLocations()
    {
        try
        {
            Console.WriteLine($"🔍 LoadAnimalLocations called - Selected Farm ID: {_selectedFarmId}");
            Console.WriteLine($"🏠 Available farms: {string.Join(", ", _farms?.Select(f => $"{f.Name} (ID: {f.Id})") ?? new[] {"None"})}");

            if (_selectedFarmId.HasValue)
            {
                var selectedFarm = _farms?.FirstOrDefault(f => f.Id == _selectedFarmId.Value);
                Console.WriteLine($"🎯 Loading animals for farm {_selectedFarmId.Value} ({selectedFarm?.Name ?? "Unknown"})");
                _animalLocations = await TrackingService.GetFarmAnimalsLocationsAsync(_selectedFarmId.Value);
                Console.WriteLine($"✅ Loaded {_animalLocations.Count} animals from farm {_selectedFarmId.Value} ({selectedFarm?.Name ?? "Unknown"})");
            }
            else
            {
                // Load animals from all farms with a single API call - MUCH FASTER!
                Console.WriteLine("🌐 Loading animals from all farms (optimized single call)");
                _animalLocations = await TrackingService.GetAllAnimalsLocationsAsync();
                Console.WriteLine($"🚀 Loaded {_animalLocations.Count} animals from all farms with single API call");
            }

            // Debug: Print animal details with farm information
            foreach (var animal in _animalLocations)
            {
                var farmName = _farms?.FirstOrDefault(f => f.Id == animal.FarmId)?.Name ?? "Unknown";
                Console.WriteLine($"🐄 Animal: {animal.Name} (Farm: {farmName}, ID: {animal.FarmId}), Location: {animal.Location?.Latitude}, {animal.Location?.Longitude}");
            }

            _lastUpdate = DateTime.Now;
            await UpdateMapMarkers();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading animal locations: {ex.Message}");
            Console.WriteLine($"Exception details: {ex}");
        }
    }

    private async Task InitializeSignalR()
    {
        try
        {
            // Simplified SignalR initialization without authentication for now
            Console.WriteLine("SignalR initialization disabled temporarily due to authentication requirements");
            _signalRConnected = false;

            // TODO: Re-enable SignalR when authentication is properly implemented
            /*
            SignalRService.ConnectionStatusChanged += (status) =>
            {
                _signalRConnected = status == "Connected";
                InvokeAsync(StateHasChanged);
            };

            SignalRService.LocationUpdated += async (location) =>
            {
                // Update or add the animal location
                var existingIndex = _animalLocations.FindIndex(a => a.AnimalId == location.AnimalId);
                if (existingIndex >= 0)
                {
                    _animalLocations[existingIndex] = location;
                }
                else
                {
                    _animalLocations.Add(location);
                }

                _lastUpdate = DateTime.Now;
                await InvokeAsync(async () =>
                {
                    await UpdateMapMarkers();
                    StateHasChanged();
                });
            };
            */
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing SignalR: {ex.Message}");
        }
    }

    private async Task InitializeMap()
    {
        try
        {
            // Reset map initialization state
            _mapInitialized = false;

            // Force map re-initialization on each call
            await JSRuntime.InvokeVoidAsync("reinitializeMap");

            _mapInitialized = true;
            await UpdateMapMarkers();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing map: {ex.Message}");
            _mapInitialized = false;
        }
    }

    private async Task UpdateMapMarkers()
    {
        try
        {
            Console.WriteLine($"UpdateMapMarkers called with {_animalLocations.Count} animals");

            var markersData = _animalLocations
                .Where(a => a.Location != null)
                .Select(a => new
                {
                    id = a.AnimalId,
                    name = a.AnimalName,
                    tag = a.Tag,
                    status = a.Status,
                    currentLocation = new
                    {
                        latitude = a.Location!.Latitude,
                        longitude = a.Location.Longitude,
                        altitude = a.Location.Altitude,
                        speed = a.Location.Speed ?? 0,
                        temperature = a.Location.Temperature,
                        activityLevel = a.Location.ActivityLevel,
                        timestamp = a.Location.Timestamp.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")
                    }
                })
                .ToArray();

            Console.WriteLine($"Sending {markersData.Length} markers to JavaScript");
            foreach (var marker in markersData)
            {
                Console.WriteLine($"Marker: {marker.name} at {marker.currentLocation.latitude}, {marker.currentLocation.longitude}");
            }

            // Llamar a la función JavaScript con el parámetro para abrir todos los popups
            // openAllPopups = true significa que queremos mostrar todos los popups cuando se selecciona una granja
            bool openAllPopups = !_selectedAnimalId.HasValue; // Solo abrir todos si no hay animal seleccionado
            await JSRuntime.InvokeVoidAsync("updateMapMarkers", markersData, openAllPopups);
            Console.WriteLine($"JavaScript updateMapMarkers call completed with openAllPopups={openAllPopups}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating map markers: {ex.Message}");
            Console.WriteLine($"Exception details: {ex}");
        }
    }

    private async Task OnFarmSelected(ChangeEventArgs e)
    {
        var farmIdStr = e.Value?.ToString();
        _selectedFarmId = string.IsNullOrEmpty(farmIdStr) ? null : int.Parse(farmIdStr);

        // Reset la selección de animal individual cuando se cambia de granja
        _selectedAnimalId = null;
        StopSelectedAnimalTracking();

        // Hide any currently displayed geofencing area when changing farms
        if (_showGeofencing)
        {
            _showGeofencing = false;
            await JSRuntime.InvokeVoidAsync("clearAllBoundaries");
        }

        // Reset del estado del mapa para permitir reajuste de zoom inicial
        await JSRuntime.InvokeVoidAsync("resetMapState");

        await LoadAnimalLocations();
    }

    private async Task RefreshMap()
    {
        _isLoading = true;
        StateHasChanged();

        await LoadAnimalLocations();

        _isLoading = false;
        StateHasChanged();
    }

    private async Task ShowAllAnimals()
    {
        // Resetear la selección de animal individual
        _selectedAnimalId = null;

        // Persistir que ya no hay animal seleccionado

        // Parar el tracking del animal específico
        StopSelectedAnimalTracking();

        // Recargar y mostrar todos los animales con sus popups
        await UpdateMapMarkers(); // Esto ahora llamará updateMapMarkers con openAllPopups=true

        StateHasChanged();
    }

    private async Task SelectAnimal(int animalId)
    {
        _selectedAnimalId = animalId;

        // Persistir la selección de animal

        var animal = _animalLocations.FirstOrDefault(a => a.AnimalId == animalId);

        if (animal?.Location != null)
        {
            // Mostrar solo este animal específico
            await JSRuntime.InvokeVoidAsync("showSingleAnimal", animalId);

            // También crear el marcador central detallado
            await JSRuntime.InvokeVoidAsync("centerMapOnAnimalWithDetails",
                animalId,
                animal.Location.Latitude,
                animal.Location.Longitude,
                animal.AnimalName,
                animal.Tag ?? "Sin Tag",
                animal.Status ?? "Healthy",
                animal.Location.Speed ?? 0);

            // Start real-time tracking for this animal
            await StartSelectedAnimalTracking(animalId);
        }

        StateHasChanged();
    }

    private async Task StartSelectedAnimalTracking(int animalId)
    {
        try
        {
            // Stop any existing tracking
            StopSelectedAnimalTracking();

            _isTrackingSelectedAnimal = true;

            // Persistir el estado de tracking

            Console.WriteLine($"Starting real-time tracking for animal {animalId}");

            // Create a timer that updates every 5 seconds for the selected animal
            _selectedAnimalTrackingTimer = new Timer(async _ =>
            {
                if (!_disposed && _isTrackingSelectedAnimal && _selectedAnimalId == animalId)
                {
                    await InvokeAsync(async () =>
                    {
                        await UpdateSelectedAnimalPosition(animalId);
                    });
                }
            }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));

            Console.WriteLine($"Real-time tracking started for animal {animalId} - updates every 5 seconds");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting animal tracking: {ex.Message}");
        }
    }

    private void StopSelectedAnimalTracking()
    {
        try
        {
            if (_selectedAnimalTrackingTimer != null)
            {
                _selectedAnimalTrackingTimer.Dispose();
                _selectedAnimalTrackingTimer = null;
                Console.WriteLine("Stopped real-time animal tracking");
            }

            _isTrackingSelectedAnimal = false;

            // Persistir el estado de tracking
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error stopping animal tracking: {ex.Message}");
        }
    }

    private async Task UpdateSelectedAnimalPosition(int animalId)
    {
        try
        {
            Console.WriteLine($"Updating position for selected animal {animalId}");

            // Get updated location for the specific animal
            var updatedAnimals = await TrackingService.GetFarmAnimalsLocationsAsync(_selectedFarmId ?? 0);
            var updatedAnimal = updatedAnimals.FirstOrDefault(a => a.AnimalId == animalId);

            if (updatedAnimal?.Location != null)
            {
                // Update the animal in our local list
                var existingIndex = _animalLocations.FindIndex(a => a.AnimalId == animalId);
                if (existingIndex >= 0)
                {
                    _animalLocations[existingIndex] = updatedAnimal;
                }

                // Update the map marker position and popup in real-time
                await JSRuntime.InvokeVoidAsync("updateSelectedAnimalPosition",
                    animalId,
                    updatedAnimal.Location.Latitude,
                    updatedAnimal.Location.Longitude,
                    updatedAnimal.AnimalName,
                    updatedAnimal.Tag ?? "Sin Tag",
                    updatedAnimal.Status ?? "Healthy",
                    updatedAnimal.Location.Speed ?? 0);

                // Save location history to database
                await SaveLocationToDatabase(updatedAnimal);

                _lastUpdate = DateTime.Now;
                StateHasChanged();

                Console.WriteLine($"Updated animal {updatedAnimal.AnimalName} position to {updatedAnimal.Location.Latitude}, {updatedAnimal.Location.Longitude} at speed {updatedAnimal.Location.Speed} km/h");
            }
            else
            {
                Console.WriteLine($"No updated location found for animal {animalId}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating selected animal position: {ex.Message}");
        }
    }

    private async Task SaveLocationToDatabase(dynamic animalLocationData)
    {
        try
        {
            // Extract data from the animal location object
            var animalId = (int)animalLocationData.AnimalId;
            var trackerId = animalLocationData.TrackerId ?? 0;
            var location = animalLocationData.Location;

            if (location != null && trackerId > 0)
            {
                var locationHistoryData = new TrackerGanadero.Shared.Services.SaveLocationHistoryDto
                {
                    AnimalId = animalId,
                    TrackerId = trackerId,
                    Latitude = location.Latitude,
                    Longitude = location.Longitude,
                    Altitude = location.Altitude ?? 0,
                    Speed = location.Speed ?? 0,
                    ActivityLevel = location.ActivityLevel ?? 50,
                    Temperature = location.Temperature ?? 20,
                    SignalStrength = 100, // Default good signal
                    Timestamp = location.Timestamp,
                    Source = "Frontend-RealTime"
                };

                await TrackingService.SaveLocationHistoryAsync(locationHistoryData);
                Console.WriteLine($"✅ Saved location history for animal {animalId} at {location.Latitude}, {location.Longitude}");
            }
            else
            {
                Console.WriteLine($"⚠️ Cannot save location history: missing data for animal {animalId}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error saving location to database: {ex.Message}");
            // Don't throw - continue with tracking even if save fails
        }
    }

    private string GetStatusBadgeColor(string status)
    {
        return status.ToLower() switch
        {
            "saludable" => "success",        // Verde para saludable
            "healthy" => "success",          // Verde para healthy (compatibilidad)
            "enfermo" => "danger",           // Rojo para enfermo
            "sick" => "danger",              // Rojo para sick (compatibilidad)
            "en observación" => "warning",   // Amarillo para en observación
            "monitoring" => "warning",       // Amarillo para monitoring (compatibilidad)
            _ => "secondary"                 // Gris para estados desconocidos
        };
    }

    private string TranslateStatus(string status)
    {
        return status.ToLower() switch
        {
            "healthy" => "Saludable",
            "sick" => "Enfermo",
            "monitoring" => "En observación",
            _ => status  // Si ya está en español o es otro estado, devolver tal como está
        };
    }

    private bool IsAnimalConnected(AnimalLocationDto animal)
    {
        if (animal.Location == null) return false;

        // Considera conectado si las coordenadas se actualizaron en los últimos 2 minutos
        var timeDifference = DateTime.UtcNow - animal.Location.Timestamp.ToUniversalTime();
        return timeDifference.TotalMinutes <= 2;
    }

    private string GetConnectionStatus(AnimalLocationDto animal)
    {
        return IsAnimalConnected(animal) ? "🟢 Conectado" : "🔴 Desconectado";
    }

    private string GetConnectionBadgeColor(AnimalLocationDto animal)
    {
        return IsAnimalConnected(animal) ? "success" : "danger";
    }

    private void InitializeAutoRefresh()
    {
        try
        {
            // Auto-refresh every 15 seconds for better real-time experience
            _autoRefreshTimer = new Timer(async _ =>
            {
                if (!_disposed)
                {
                    Console.WriteLine("Auto-refresh timer triggered for all farm animals");
                    await InvokeAsync(async () =>
                    {
                        await LoadAnimalLocations();
                    });
                }
            }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));

            Console.WriteLine("Auto-refresh timer initialized - will update all farm animals every 15 seconds");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing auto-refresh: {ex.Message}");
        }
    }

    private void ToggleVoiceNavigation()
    {
        VoiceNavigationService.IsEnabled = !VoiceNavigationService.IsEnabled;
        System.Diagnostics.Debug.WriteLine($"🔊 Voice navigation {(VoiceNavigationService.IsEnabled ? "enabled" : "disabled")}");
        StateHasChanged();
    }

    private async Task ToggleGeofencing()
    {
        // Only allow toggle if a farm is selected
        if (!_selectedFarmId.HasValue)
        {
            Console.WriteLine("No farm selected - cannot toggle geofencing");
            return;
        }

        _showGeofencing = !_showGeofencing;

        // Persistir el estado de geofencing

        try
        {
            if (_showGeofencing)
            {
                // Show geofencing area ONLY for the selected farm
                var selectedFarm = _farms?.FirstOrDefault(f => f.Id == _selectedFarmId.Value);
                if (selectedFarm?.BoundaryCoordinates?.Any() == true)
                {
                    Console.WriteLine($"Showing geofencing area for selected farm: {selectedFarm.Name}");
                    await JSRuntime.InvokeVoidAsync("addFarmBoundary", selectedFarm.Id, selectedFarm.Name, selectedFarm.BoundaryCoordinates.ToArray());
                }
                else
                {
                    Console.WriteLine($"Selected farm '{selectedFarm?.Name}' has no geofencing area configured");
                    _showGeofencing = false; // Reset the toggle since there's nothing to show
                            }
            }
            else
            {
                // Hide the selected farm's geofencing area
                Console.WriteLine($"Hiding geofencing area for selected farm");
                await JSRuntime.InvokeVoidAsync("clearAllBoundaries");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling geofencing: {ex.Message}");
        }
    }

    // ==================== GPS NAVIGATION METHODS ====================

    /// <summary>
    /// Calculates and displays route to selected animal
    /// </summary>
    private async Task NavigateToAnimal(int animalId)
    {
        try
        {
            System.Diagnostics.Debug.WriteLine($"🎯 NavigateToAnimal called for animal ID: {animalId}");
            _isCalculatingRoute = true;
            _selectedAnimalForRoute = animalId;
            StateHasChanged();

            // Find animal location
            var animal = _animalLocations.FirstOrDefault(a => a.AnimalId == animalId);
            if (animal?.Location == null)
            {
                System.Diagnostics.Debug.WriteLine($"❌ Animal {animalId} has no location");
                await ShowAlert("Error", "No se pudo obtener la ubicación del animal. Asegúrate de que el tracker esté transmitiendo.");
                return;
            }

            System.Diagnostics.Debug.WriteLine($"✅ Animal found: {animal.AnimalName} at ({animal.Location.Latitude}, {animal.Location.Longitude})");

            // IMPORTANTE: Si estamos en modo mock Y el animal tiene granja con geofencing,
            // generar un punto de inicio dentro del geofence ANTES de obtener la ubicación
            if (NavigationService.USE_MOCK_LOCATION && animal.FarmId > 0)
            {
                try
                {
                    System.Diagnostics.Debug.WriteLine($"🔧 MOCK MODE: Trying to get geofence boundaries for farm {animal.FarmId}");
                    var farm = await FarmService.GetFarmAsync(animal.FarmId);

                    if (farm?.BoundaryCoordinates != null && farm.BoundaryCoordinates.Count >= 3)
                    {
                        System.Diagnostics.Debug.WriteLine($"✅ Farm has {farm.BoundaryCoordinates.Count} boundary coordinates");

                        // Call JavaScript to generate a random point inside the polygon
                        var generatedPoint = await JSRuntime.InvokeAsync<CoordinateDto>("generatePointInsidePolygon", farm.BoundaryCoordinates);

                        if (generatedPoint != null)
                        {
                            System.Diagnostics.Debug.WriteLine($"✅ Generated starting position inside geofence: ({generatedPoint.Latitude}, {generatedPoint.Longitude})");

                            // CRÍTICO: Actualizar la ubicación mock ANTES de llamar a GetUserLocationAsync()
                            NavigationService.UpdateMockLocation(generatedPoint.Latitude, generatedPoint.Longitude);
                        }
                    }
                    else
                    {
                        System.Diagnostics.Debug.WriteLine("⚠️ Farm has no geofence boundaries, using default mock location");
                    }
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"⚠️ Could not get geofence boundaries: {ex.Message}. Using default mock location");
                }
            }

            // Get user's current GPS location (ahora con la ubicación mock actualizada si corresponde)
            System.Diagnostics.Debug.WriteLine("📍 Getting user location...");
            var userLocation = await NavigationService.GetUserLocationAsync();

            if (userLocation == null)
            {
                System.Diagnostics.Debug.WriteLine("❌ User location is null");
                await ShowAlert("Ubicación requerida",
                    "No se pudo obtener tu ubicación. Verifica que:\n" +
                    "• GPS esté activado en tu dispositivo\n" +
                    "• La app tenga permiso para acceder a ubicación");
                return;
            }

            System.Diagnostics.Debug.WriteLine($"✅ User location obtained: ({userLocation.Latitude}, {userLocation.Longitude})");

            // Calculate route via GraphHopper
            System.Diagnostics.Debug.WriteLine("🗺️ Calculating route...");
            var route = await NavigationService.CalculateRouteAsync(
                new CoordinateDto
                {
                    Latitude = userLocation.Latitude,
                    Longitude = userLocation.Longitude
                },
                new CoordinateDto
                {
                    Latitude = animal.Location.Latitude,
                    Longitude = animal.Location.Longitude
                }
            );

            if (route == null)
            {
                System.Diagnostics.Debug.WriteLine("❌ Route calculation returned null");
                await ShowAlert("Error de ruta",
                    "No se pudo calcular la ruta. Verifica tu conexión a internet e intenta nuevamente.");
                return;
            }

            System.Diagnostics.Debug.WriteLine($"✅ Route calculated successfully: {route.DistanceMeters}m, {route.DurationSeconds}s, {route.Coordinates.Count} points");

            // FIX: The routing engine snaps to the nearest road. Replace the last point of the
            // route with the precise animal location to draw a correct line to the target.
            if (route.Coordinates.Any())
            {
                var preciseAnimalLocation = new CoordinateDto
                {
                    Latitude = animal.Location.Latitude,
                    Longitude = animal.Location.Longitude
                };
                route.Coordinates[route.Coordinates.Count - 1] = preciseAnimalLocation;
                System.Diagnostics.Debug.WriteLine("🔧 Corrected route's final coordinate to precise animal location.");
            }

            // Store route and draw on map
            _currentRoute = route;
            _currentRoute.AnimalName = animal.AnimalName;

            System.Diagnostics.Debug.WriteLine("🎨 Drawing route on map...");
            await JSRuntime.InvokeVoidAsync("drawRoute", route);


            // Generate voice navigation instructions
            System.Diagnostics.Debug.WriteLine("🔊 Generating voice navigation instructions...");
            VoiceNavigationService.GenerateInstructions(route);

            // Start tracking the animal's movement to update route automatically
            _navigatingToAnimalId = animalId;
            _lastNavigationTargetLocation = animal.Location;
            StartNavigationTracking();

            // Start user movement simulation if enabled
            if (NavigationService.SIMULATE_USER_MOVEMENT && route.Coordinates.Count > 0)
            {
                _currentRoutePointIndex = 0;
                _currentUserPosition = route.Coordinates[0]; // Initialize to start position
                _traveledDistance = 0; // Reset traveled distance
                StartUserMovementSimulation();
            }

            System.Diagnostics.Debug.WriteLine("✅ Navigation completed successfully - tracking animal movement");
            StateHasChanged();
        }
        catch (UnauthorizedAccessException ex)
        {
            System.Diagnostics.Debug.WriteLine($"Permission denied: {ex.Message}");
            await ShowAlert("Permiso denegado",
                "Tracker Ganadero necesita acceso a tu ubicacion para calcular la ruta. " +
                "Por favor, habilita el permiso de ubicacion en la configuracion.");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error navigating to animal: {ex.Message}");
            System.Diagnostics.Debug.WriteLine($"Stack trace: {ex.StackTrace}");
            await ShowAlert("Error",
                $"Ocurrió un error al calcular la ruta: {ex.Message}\n\nIntenta nuevamente.");
        }
        finally
        {
            System.Diagnostics.Debug.WriteLine("🏁 NavigateToAnimal finally block - cleaning up");
            _isCalculatingRoute = false;
            _selectedAnimalForRoute = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Clears the active route from the map
    /// </summary>
    private async Task ClearRoute()
    {
        System.Diagnostics.Debug.WriteLine("🧹 Clearing route and stopping navigation tracking");
        _currentRoute = null;
        _navigatingToAnimalId = null;
        _lastNavigationTargetLocation = null;
        VoiceNavigationService.Reset();
        StopNavigationTracking();
        StopUserMovementSimulation();
        await JSRuntime.InvokeVoidAsync("clearRoute");
        StateHasChanged();
    }

    /// <summary>
    /// Formats distance in meters to human-readable string
    /// </summary>
    private string FormatDistance(double meters)
    {
        if (meters < 1000)
            return $"{meters:F0} m";
        return $"{(meters / 1000):F1} km";
    }

    /// <summary>
    /// Formats duration in seconds to human-readable string
    /// </summary>
    private string FormatDuration(double seconds)
    {
        var duration = TimeSpan.FromSeconds(seconds);
        if (duration.TotalHours >= 1)
            return $"{duration.Hours}h {duration.Minutes}m";
        return $"{duration.Minutes}m";
    }

    /// <summary>
    /// Shows platform-specific alert dialog
    /// </summary>
    private async Task ShowAlert(string title, string message)
    {
        try
        {
            _alertMessage = $"{title}: {message}";
            StateHasChanged();
            await Task.Delay(5000);
            _alertMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error showing alert: {ex.Message}");
        }
    }

    // ==================== NAVIGATION TRACKING ====================

    /// <summary>
    /// Starts tracking the target animal's movement to update route automatically
    /// </summary>
    private void StartNavigationTracking()
    {
        try
        {
            // Stop any existing tracking first
            StopNavigationTracking();

            System.Diagnostics.Debug.WriteLine($"📍 Starting navigation tracking for animal {_navigatingToAnimalId}");

            // Create a timer that checks animal position every 5 seconds
            _navigationTrackingTimer = new Timer(async _ =>
            {
                if (!_disposed && _navigatingToAnimalId.HasValue)
                {
                    await InvokeAsync(async () =>
                    {
                        await UpdateNavigationTarget();
                    });
                }
            }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));

            System.Diagnostics.Debug.WriteLine("✅ Navigation tracking started - will update route if animal moves");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error starting navigation tracking: {ex.Message}");
        }
    }

    /// <summary>
    /// Stops tracking the target animal's movement
    /// </summary>
    private void StopNavigationTracking()
    {
        try
        {
            if (_navigationTrackingTimer != null)
            {
                _navigationTrackingTimer.Dispose();
                _navigationTrackingTimer = null;
                System.Diagnostics.Debug.WriteLine("⏹️ Navigation tracking stopped");
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error stopping navigation tracking: {ex.Message}");
        }
    }

    /// <summary>
    /// Checks if the target animal has moved and updates the route if necessary
    /// </summary>
    private async Task UpdateNavigationTarget()
    {
        try
        {
            if (!_navigatingToAnimalId.HasValue || _lastNavigationTargetLocation == null)
            {
                System.Diagnostics.Debug.WriteLine("⚠️ No active navigation target");
                return;
            }

            // Get updated animal location
            var animal = _animalLocations.FirstOrDefault(a => a.AnimalId == _navigatingToAnimalId.Value);
            if (animal?.Location == null)
            {
                System.Diagnostics.Debug.WriteLine($"⚠️ Animal {_navigatingToAnimalId} no longer has location");
                return;
            }

            // Calculate distance between last known position and current position
            var distance = CalculateDistance(
                _lastNavigationTargetLocation.Latitude,
                _lastNavigationTargetLocation.Longitude,
                animal.Location.Latitude,
                animal.Location.Longitude
            );

            System.Diagnostics.Debug.WriteLine($"📏 Animal {animal.AnimalName} moved {distance:F1}m from last route calculation");

            // If animal moved more than 10 meters, recalculate route
            if (distance > 10)
            {
                System.Diagnostics.Debug.WriteLine($"🔄 Animal moved significantly ({distance:F1}m) - recalculating route");

                // Get user's current GPS location
                var userLocation = await NavigationService.GetUserLocationAsync();
                if (userLocation == null)
                {
                    System.Diagnostics.Debug.WriteLine("⚠️ Could not get user location for route update");
                    return;
                }

                // Calculate new route
                var route = await NavigationService.CalculateRouteAsync(
                    new CoordinateDto
                    {
                        Latitude = userLocation.Latitude,
                        Longitude = userLocation.Longitude
                    },
                    new CoordinateDto
                    {
                        Latitude = animal.Location.Latitude,
                        Longitude = animal.Location.Longitude
                    }
                );

                if (route != null && route.Coordinates.Count > 0)
                {
                    // Update route
                    _currentRoute = route;
                    _currentRoute.AnimalName = animal.AnimalName;
                    _lastNavigationTargetLocation = animal.Location;

                    // CRITICAL: Reset simulation state for new route
                    _currentRoutePointIndex = 0;
                    _currentUserPosition = route.Coordinates[0]; // Reset to new starting position (user's current location)
                    _traveledDistance = 0; // Reset traveled distance

                    // Regenerate voice navigation instructions for updated route (skip "Iniciando navegación")
                    VoiceNavigationService.GenerateInstructions(route, isUpdate: true);

                    // Redraw route on map
                    await JSRuntime.InvokeVoidAsync("drawRoute", route);

                    StateHasChanged();
                    System.Diagnostics.Debug.WriteLine($"✅ Route updated - new distance: {route.DistanceMeters}m, simulation state reset");
                }
                else
                {
                    System.Diagnostics.Debug.WriteLine("⚠️ Failed to recalculate route");
                }
            }
            else
            {
                // Animal moved less than threshold, just update the end marker position
                System.Diagnostics.Debug.WriteLine($"📍 Minor movement ({distance:F1}m) - updating destination marker only");
                await JSRuntime.InvokeVoidAsync("updateRouteEndMarker",
                    animal.Location.Latitude,
                    animal.Location.Longitude);
                _lastNavigationTargetLocation = animal.Location;
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error updating navigation target: {ex.Message}");
        }
    }

    /// <summary>
    /// Calculates distance between two GPS coordinates in meters using Haversine formula
    /// </summary>
    private double CalculateDistance(double lat1, double lon1, double lat2, double lon2)
    {
        const double R = 6371000; // Earth's radius in meters

        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;

        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) *
                Math.Sin(dLon / 2) * Math.Sin(dLon / 2);

        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));

        return R * c; // Distance in meters
    }

    // ==================== USER MOVEMENT SIMULATION ====================

    /// <summary>
    /// Starts simulating user movement along the calculated route
    /// </summary>
    private void StartUserMovementSimulation()
    {
        try
        {
            StopUserMovementSimulation();

            if (_currentRoute == null || _currentRoute.Coordinates.Count < 2)
            {
                System.Diagnostics.Debug.WriteLine("⚠️ Cannot start simulation - no valid route");
                return;
            }

            System.Diagnostics.Debug.WriteLine($"🚶 Starting user movement simulation at {SIMULATION_SPEED_MPS}m/s");

            // Update every 1 second to simulate smooth movement
            _userMovementSimulationTimer = new Timer(async _ =>
            {
                if (!_disposed && _currentRoute != null)
                {
                    await InvokeAsync(async () =>
                    {
                        await SimulateUserMovementStep();
                    });
                }
            }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

            System.Diagnostics.Debug.WriteLine("✅ User movement simulation started");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error starting user movement simulation: {ex.Message}");
        }
    }

    /// <summary>
    /// Stops the user movement simulation
    /// </summary>
    private void StopUserMovementSimulation()
    {
        try
        {
            if (_userMovementSimulationTimer != null)
            {
                _userMovementSimulationTimer.Dispose();
                _userMovementSimulationTimer = null;
                _currentRoutePointIndex = 0;
                _currentUserPosition = null;
                System.Diagnostics.Debug.WriteLine("⏹️ User movement simulation stopped");
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error stopping user movement simulation: {ex.Message}");
        }
    }

    /// <summary>
    /// Simulates one step of user movement along the route
    /// </summary>
    private async Task SimulateUserMovementStep()
    {
        try
        {
            if (_currentRoute == null || _currentRoute.Coordinates.Count == 0 || _currentUserPosition == null)
            {
                System.Diagnostics.Debug.WriteLine("⚠️ No route or position for simulation");
                StopUserMovementSimulation();
                return;
            }

            // Distance to move in this step
            var distanceToMove = SIMULATION_SPEED_MPS * 1.0; // 1 second interval
            var remainingDistance = distanceToMove;
            var previousPosition = new CoordinateDto { Latitude = _currentUserPosition.Latitude, Longitude = _currentUserPosition.Longitude };

            // Keep moving until we've covered the distance or reached the end
            while (remainingDistance > 0.01 && _currentRoutePointIndex < _currentRoute.Coordinates.Count - 1)
            {
                var nextWaypoint = _currentRoute.Coordinates[_currentRoutePointIndex + 1];

                var distanceToNextWaypoint = CalculateDistance(
                    _currentUserPosition.Latitude, _currentUserPosition.Longitude,
                    nextWaypoint.Latitude, nextWaypoint.Longitude
                );

                if (distanceToNextWaypoint <= remainingDistance)
                {
                    // We can reach the next waypoint, move to it
                    _currentUserPosition = new CoordinateDto
                    {
                        Latitude = nextWaypoint.Latitude,
                        Longitude = nextWaypoint.Longitude
                    };
                    remainingDistance -= distanceToNextWaypoint;
                    _currentRoutePointIndex++;
                    System.Diagnostics.Debug.WriteLine($"🚶 Reached waypoint {_currentRoutePointIndex}/{_currentRoute.Coordinates.Count}");
                }
                else
                {
                    // Move partially toward the next waypoint
                    var fraction = remainingDistance / distanceToNextWaypoint;
                    var newLat = _currentUserPosition.Latitude + (nextWaypoint.Latitude - _currentUserPosition.Latitude) * fraction;
                    var newLon = _currentUserPosition.Longitude + (nextWaypoint.Longitude - _currentUserPosition.Longitude) * fraction;

                    _currentUserPosition = new CoordinateDto { Latitude = newLat, Longitude = newLon };
                    remainingDistance = 0; // Used up all movement
                    System.Diagnostics.Debug.WriteLine($"🚶 Moving toward waypoint {_currentRoutePointIndex + 1} ({fraction:P0} of segment)");
                }
            }

            // Update traveled distance
            var stepDistance = CalculateDistance(
                previousPosition.Latitude, previousPosition.Longitude,
                _currentUserPosition.Latitude, _currentUserPosition.Longitude
            );
            _traveledDistance += stepDistance;

            // Check for voice navigation instructions
            await VoiceNavigationService.CheckAndAnnounceInstructions(_currentUserPosition, _traveledDistance);

            // Check if we reached the final destination
            if (_currentRoutePointIndex >= _currentRoute.Coordinates.Count - 1)
            {
                var finalDestination = _currentRoute.Coordinates[_currentRoute.Coordinates.Count - 1];
                var distanceToEnd = CalculateDistance(
                    _currentUserPosition.Latitude, _currentUserPosition.Longitude,
                    finalDestination.Latitude, finalDestination.Longitude
                );

                if (distanceToEnd < 5) // Within 5 meters of destination
                {
                    System.Diagnostics.Debug.WriteLine("🎉 Simulation completed - reached destination!");
                    await VoiceNavigationService.AnnounceArrival();
                    StopUserMovementSimulation();
                    await ShowAlert("Destino Alcanzado", $"Has llegado a {_currentRoute.AnimalName}!");
                    return;
                }
            }

            // Update mock GPS location
            NavigationService.UpdateMockLocation(_currentUserPosition.Latitude, _currentUserPosition.Longitude);

            // Update start marker on map
            await JSRuntime.InvokeVoidAsync("updateRouteStartMarker",
                _currentUserPosition.Latitude,
                _currentUserPosition.Longitude);

            // Update route to show only remaining path (remove traveled segments)
            var remainingCoordinates = new List<CoordinateDto> { _currentUserPosition };
            remainingCoordinates.AddRange(_currentRoute.Coordinates.Skip(_currentRoutePointIndex + 1));
            await JSRuntime.InvokeVoidAsync("updateRemainingRoute", remainingCoordinates);

            // Calculate remaining distance to destination
            var totalRemainingDistance = 0.0;
            var distanceToNextTurn = 0.0;

            // Add distance from current position to next waypoint
            if (_currentRoutePointIndex < _currentRoute.Coordinates.Count - 1)
            {
                var nextWaypoint = _currentRoute.Coordinates[_currentRoutePointIndex + 1];
                distanceToNextTurn = CalculateDistance(
                    _currentUserPosition.Latitude, _currentUserPosition.Longitude,
                    nextWaypoint.Latitude, nextWaypoint.Longitude
                );
                totalRemainingDistance += distanceToNextTurn;
            }

            // Add distance for remaining waypoints
            for (int i = _currentRoutePointIndex + 1; i < _currentRoute.Coordinates.Count - 1; i++)
            {
                var p1 = _currentRoute.Coordinates[i];
                var p2 = _currentRoute.Coordinates[i + 1];
                totalRemainingDistance += CalculateDistance(p1.Latitude, p1.Longitude, p2.Latitude, p2.Longitude);
            }

            _currentRoute.DistanceMeters = totalRemainingDistance;
            _currentRoute.DistanceToNextTurn = distanceToNextTurn;

            System.Diagnostics.Debug.WriteLine($"📍 User position: ({_currentUserPosition.Latitude:F6}, {_currentUserPosition.Longitude:F6}) - {totalRemainingDistance:F0}m remaining, {distanceToNextTurn:F0}m to next turn");

            // Note: Route recalculation when animal moves is handled by UpdateNavigationTarget()
            // which runs every 5 seconds via _navigationTrackingTimer

            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Error in simulation step: {ex.Message}");
        }
    }

    // ==================== DISPOSE ====================

    public void Dispose()
    {
        _disposed = true;
        _autoRefreshTimer?.Dispose();

        // Stop selected animal tracking
        StopSelectedAnimalTracking();

        // Stop navigation tracking
        StopNavigationTracking();

        // Stop user movement simulation
        StopUserMovementSimulation();

        // Clean up map when component is disposed
        try
        {
            JSRuntime.InvokeVoidAsync("cleanupMap");
            _mapInitialized = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cleaning up map: {ex.Message}");
        }
    }
}

