@using TrackerGanaderoBlazorHibridMaui.Services
@using TrackerGanaderoBlazorHibridMaui.Models
@inject FarmTrackerService FarmTrackerService
@inject AnimalService AnimalService
@inject SettingsStateService SettingsStateService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">🐄 Gestión de Animales con Trackers - @(Farm?.Name ?? "Granja")</h5>
            <div class="real-time-indicator">
                <i class="fas fa-satellite-dish pulse-icon"></i>
                <small class="text-muted">Actualización automática</small>
            </div>
        </div>
    </div>
    <div class="card-body">
        @if (_isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p class="mt-2">Cargando información de animales...</p>
            </div>
        }
        else if (Farm != null)
        {

            <!-- Animals with Trackers Section -->
            <div class="row">
                <div class="col-12">
                    <h6 class="text-success">🐄 Animales con Trackers Asignados</h6>
                    @if (_farmAnimals?.Any() == true)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Animal</th>
                                        <th>Tracker</th>
                                        <th>Estado</th>
                                        <th>Batería</th>
                                        <th>Última Ubicación</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var animal in _farmAnimals)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@animal.Name</strong>
                                                @if (!string.IsNullOrEmpty(animal.Tag))
                                                {
                                                    <br><small class="text-muted">Tag: @animal.Tag</small>
                                                }
                                            </td>
                                            <td>
                                                @if (_animalTrackers.ContainsKey(animal.Id) && _animalTrackers[animal.Id] != null)
                                                {
                                                    var tracker = _animalTrackers[animal.Id]!;
                                                    <div>
                                                        <strong>@tracker.DisplayName</strong>
                                                        <br><small class="text-muted">@tracker.DeviceId</small>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Sin tracker</span>
                                                }
                                            </td>
                                            <td>
                                                @if (_animalTrackers.ContainsKey(animal.Id) && _animalTrackers[animal.Id] != null)
                                                {
                                                    var tracker = _animalTrackers[animal.Id]!;
                                                    <span class="badge @(tracker.IsOnline ? "bg-success" : "bg-secondary")">
                                                        @tracker.StatusText
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-dark">N/A</span>
                                                }
                                            </td>
                                            <td>
                                                @if (_animalTrackers.ContainsKey(animal.Id) && _animalTrackers[animal.Id] != null)
                                                {
                                                    var tracker = _animalTrackers[animal.Id]!;
                                                    <span class="text-@(tracker.BatteryLevel > 20 ? "success" : tracker.BatteryLevel > 10 ? "warning" : "danger")">
                                                        @tracker.BatteryLevel%
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td>
                                                @if (_animalTrackers.ContainsKey(animal.Id) && _animalTrackers[animal.Id] != null)
                                                {
                                                    var tracker = _animalTrackers[animal.Id]!;
                                                    <small>@tracker.LastSeenText</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td>
                                                @if (_animalTrackers.ContainsKey(animal.Id) && _animalTrackers[animal.Id] != null)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => UnassignTracker(animal.Id)">
                                                        <i class="fas fa-unlink me-1"></i>Desasignar
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-primary"
                                                            @onclick="() => ShowAssignModalForAnimal(animal)">
                                                        <i class="fas fa-link me-1"></i>Asignar Tracker
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary">
                            <i class="fas fa-cow me-2"></i>
                            No hay animales registrados en esta granja.
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal for Tracker Assignment -->
@if (_showAssignModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-link me-2"></i>
                        Asignar Tracker @(_selectedAnimal != null ? $"a {_selectedAnimal.Name}" : "")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseAssignModal"></button>
                </div>
                <div class="modal-body">
                    @if (_selectedAnimal != null)
                    {
                        <div class="mb-3">
                            <h6>Animal seleccionado:</h6>
                            <div class="card bg-light">
                                <div class="card-body p-3">
                                    <strong>@_selectedAnimal.Name</strong>
                                    @if (!string.IsNullOrEmpty(_selectedAnimal.Tag))
                                    {
                                        <br><small>Tag: @_selectedAnimal.Tag</small>
                                    }
                                    @if (!string.IsNullOrEmpty(_selectedAnimal.Breed))
                                    {
                                        <br><small>Raza: @_selectedAnimal.Breed</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Seleccionar Tracker:</label>
                        <select class="form-select" @bind="_selectedTrackerCustomerId">
                            <option value="0">-- Seleccionar Tracker --</option>
                            @if (GetUnassignedTrackers()?.Any() == true)
                            {
                                foreach (var tracker in GetUnassignedTrackers())
                                {
                                    <option value="@tracker.CustomerTrackerId">@tracker.DisplayName (@tracker.DeviceId)</option>
                                }
                            }
                        </select>
                        @if (GetUnassignedTrackers()?.Any() != true)
                        {
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                No hay trackers disponibles. Primero registre trackers desde <strong>Configuración → Descubrir Trackers</strong>.
                            </small>
                        }
                    </div>

                    @if (_assignmentMessage != null)
                    {
                        <div class="alert @(_assignmentSuccess ? "alert-success" : "alert-danger")">
                            @_assignmentMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAssignModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="AssignTracker" disabled="@(_selectedTrackerCustomerId == 0 || _isAssigning)">
                        @if (_isAssigning)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        Asignar Tracker
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal moderno para confirmación de eliminación -->
@if (_showDeleteModal)
{
    <div class="modern-modal-overlay" @onclick="CancelDelete">
        <div class="modern-modal" @onclick:stopPropagation="true">
            <div class="modern-modal-header">
                <div class="icon-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <h3>¿Eliminar Tracker?</h3>
            </div>

            <div class="modern-modal-body">
                <p>Está a punto de eliminar permanentemente el tracker:</p>
                <div class="tracker-info">
                    <strong>@_trackerToDelete?.DisplayName</strong>
                    <br>
                    <small>Device ID: @_trackerToDelete?.DeviceId</small>
                </div>
                <div class="warning-text">
                    <i class="fas fa-info-circle"></i>
                    Esta acción no se puede deshacer
                </div>
            </div>

            <div class="modern-modal-footer">
                <button type="button" class="btn-modern btn-cancel" @onclick="CancelDelete">
                    <i class="fas fa-times"></i>
                    <span>Cancelar</span>
                </button>
                <button type="button" class="btn-modern btn-delete" @onclick="ConfirmDelete" disabled="@_isDeleting">
                    @if (_isDeleting)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Eliminando</span>
                    }
                    else
                    {
                        <i class="fas fa-trash"></i>
                        <span>Sí, Eliminar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal moderno para confirmación de eliminar todos -->
@if (_showDeleteAllModal)
{
    <div class="modern-modal-overlay" @onclick="CancelDeleteAll">
        <div class="modern-modal" @onclick:stopPropagation="true">
            <div class="modern-modal-header danger">
                <div class="icon-danger">
                    <i class="fas fa-bomb"></i>
                </div>
                <h3>¿Eliminar TODOS los Trackers?</h3>
            </div>

            <div class="modern-modal-body">
                <p>Está a punto de eliminar <strong>TODOS</strong> los trackers registrados:</p>
                <div class="danger-stats">
                    <span class="stat">
                        <i class="fas fa-satellite-dish"></i>
                        @(_availableTrackers?.Count ?? 0) Trackers
                    </span>
                </div>
                <div class="warning-text danger">
                    <i class="fas fa-exclamation-triangle"></i>
                    ¡Esta acción eliminará TODOS los datos y NO se puede deshacer!
                </div>
            </div>

            <div class="modern-modal-footer">
                <button type="button" class="btn-modern btn-cancel" @onclick="CancelDeleteAll">
                    <i class="fas fa-shield-alt"></i>
                    <span>No, Conservar</span>
                </button>
                <button type="button" class="btn-modern btn-delete-all" @onclick="ConfirmDeleteAll" disabled="@_isDeletingAll">
                    @if (_isDeletingAll)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Eliminando Todo</span>
                    }
                    else
                    {
                        <i class="fas fa-bomb"></i>
                        <span>Sí, Eliminar TODO</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public FarmDto? Farm { get; set; }

    private bool _isLoading = false;
    private bool _isAssigning = false;
    private List<AvailableFarmTrackerDto>? _availableTrackers;
    private List<AnimalDto>? _farmAnimals;
    private Dictionary<int, AnimalTrackerInfoDto?> _animalTrackers = new();

    // Global tracker assignments - almacenar asignaciones de TODAS las granjas
    private HashSet<string> _globallyAssignedDeviceIds = new();
    private HashSet<int> _globallyAssignedCustomerTrackerIds = new();

    // Modal state
    private bool _showAssignModal = false;
    private AvailableFarmTrackerDto? _selectedTracker;
    private AnimalDto? _selectedAnimal;
    private int _selectedAnimalId = 0;
    private int _selectedTrackerCustomerId = 0;
    private string? _assignmentMessage;
    private bool _assignmentSuccess = false;

    // Modern delete modal state
    private bool _showDeleteModal = false;
    private bool _showDeleteAllModal = false;
    private AvailableFarmTrackerDto? _trackerToDelete;
    private bool _isDeleting = false;
    private bool _isDeletingAll = false;

    // Real-time update timer
    private Timer? _updateTimer;
    private readonly TimeSpan _updateInterval = TimeSpan.FromSeconds(5); // Update every 5 seconds

    // Track previous farm to detect actual changes
    private int? _previousFarmId = null;

    protected override async Task OnParametersSetAsync()
    {
        if (Farm != null)
        {
            // Only reload data if the farm actually changed
            if (_previousFarmId != Farm.Id)
            {
                _previousFarmId = Farm.Id;
                await LoadData();
                StartAutoUpdate();
            }
        }
        else if (_previousFarmId != null)
        {
            // Farm was cleared, reset state
            _previousFarmId = null;
            StopAutoUpdate();
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            // Load available trackers
            _availableTrackers = await FarmTrackerService.GetAvailableTrackersAsync();

            // Load animals in this farm
            _farmAnimals = await AnimalService.GetAnimalsAsync(Farm!.Id);

            // Load tracker info for each animal
            _animalTrackers.Clear();
            foreach (var animal in _farmAnimals)
            {
                try
                {
                    var trackerInfo = await FarmTrackerService.GetAnimalTrackerInfoAsync(animal.Id);
                    _animalTrackers[animal.Id] = trackerInfo;
                }
                catch
                {
                    _animalTrackers[animal.Id] = null;
                }
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("console.error", $"Error loading tracker data: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // MÉTODO YA NO USADO - Se eliminó la sección de "Trackers Disponibles para Asignar"
    // private void ShowAssignModal(AvailableFarmTrackerDto tracker)
    // {
    //     _selectedTracker = tracker;
    //     _selectedAnimal = null;
    //     _selectedAnimalId = 0;
    //     _assignmentMessage = null;
    //     _showAssignModal = true;
    //     StateHasChanged();
    // }

    private async void ShowAssignModalForAnimal(AnimalDto animal)
    {
        _selectedAnimal = animal;
        _selectedAnimalId = animal.Id;
        _selectedTracker = null;
        _selectedTrackerCustomerId = 0;
        _assignmentMessage = null;
        _showAssignModal = true;

        // Refrescar datos antes de mostrar el modal para asegurar lista actualizada
        try
        {
            await LoadData();
            // IMPORTANTE: También cargar información global de asignaciones
            await LoadGlobalTrackerAssignments();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing data for modal: {ex.Message}");
            StateHasChanged();
        }
    }

    private void CloseAssignModal()
    {
        _showAssignModal = false;
        _selectedTracker = null;
        _selectedAnimal = null;
        _selectedAnimalId = 0;
        _selectedTrackerCustomerId = 0;
        _assignmentMessage = null;
        StateHasChanged();
    }

    private async Task AssignTracker()
    {
        if (_selectedTrackerCustomerId == 0 || _selectedAnimalId == 0)
            return;

        _isAssigning = true;
        _assignmentMessage = null;
        StateHasChanged();

        try
        {
            var success = await FarmTrackerService.AssignTrackerToAnimalAsync(
                _selectedTrackerCustomerId,
                _selectedAnimalId);

            if (success)
            {
                _assignmentMessage = "Tracker asignado exitosamente al animal";
                _assignmentSuccess = true;
                await LoadData(); // Reload data to reflect changes
                await Task.Delay(1500);
                CloseAssignModal();
            }
            else
            {
                _assignmentMessage = "Error asignando el tracker. Intente nuevamente.";
                _assignmentSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _assignmentMessage = $"Error: {ex.Message}";
            _assignmentSuccess = false;
        }
        finally
        {
            _isAssigning = false;
            StateHasChanged();
        }
    }

    private async Task UnassignTracker(int animalId)
    {
        try
        {
            var success = await FarmTrackerService.UnassignTrackerFromAnimalAsync(animalId);
            if (success)
            {
                await LoadData(); // Reload data to reflect changes
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error desasignando el tracker");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    /// <summary>
    /// Abre el modal de confirmación para eliminar un tracker específico
    /// </summary>
    private void DeleteTracker(AvailableFarmTrackerDto tracker)
    {
        _trackerToDelete = tracker;
        _showDeleteModal = true;
        StateHasChanged();
    }

    /// <summary>
    /// Confirma y ejecuta la eliminación del tracker
    /// </summary>
    private async Task ConfirmDelete()
    {
        if (_trackerToDelete == null) return;

        try
        {
            _isDeleting = true;
            StateHasChanged();

            var response = await FarmTrackerService.DeleteTrackerAsync(_trackerToDelete.TrackerId);

            _showDeleteModal = false;

            if (response.success)
            {
                await ShowSuccessToast($"🎉 Tracker {_trackerToDelete.DeviceId} eliminado exitosamente");

                // Update SettingsStateService to reset the tracker status in discovery screen
                if (SettingsStateService.ScannedTrackers?.Any() == true)
                {
                    var trackerInScanned = SettingsStateService.ScannedTrackers.FirstOrDefault(t => t.DeviceId == _trackerToDelete.DeviceId);
                    if (trackerInScanned != null)
                    {
                        // Reset to unregistered state (Id = 0)
                        trackerInScanned.Id = 0;
                        trackerInScanned.Status = "Unregistered";
                        trackerInScanned.Name = null;
                        trackerInScanned.Model = null;
                        trackerInScanned.IsOnline = false;
                    }
                }

                await LoadData(); // Reload data to reflect changes
            }
            else
            {
                await ShowErrorToast($"❌ Error eliminando el tracker: {response.message}");
            }
        }
        catch (Exception ex)
        {
            _showDeleteModal = false;
            await ShowErrorToast($"❌ Error: {ex.Message}");
        }
        finally
        {
            _isDeleting = false;
            _trackerToDelete = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Cancela la eliminación del tracker
    /// </summary>
    private void CancelDelete()
    {
        _showDeleteModal = false;
        _trackerToDelete = null;
        StateHasChanged();
    }

    /// <summary>
    /// Abre el modal de confirmación para eliminar todos los trackers
    /// </summary>
    private void DeleteAllTrackers()
    {
        _showDeleteAllModal = true;
        StateHasChanged();
    }

    /// <summary>
    /// Confirma y ejecuta la eliminación de todos los trackers
    /// </summary>
    private async Task ConfirmDeleteAll()
    {
        try
        {
            _isDeletingAll = true;
            StateHasChanged();

            var response = await FarmTrackerService.DeleteAllTrackersAsync();

            _showDeleteAllModal = false;

            if (response.success)
            {
                await ShowSuccessToast($"🎯 Se eliminaron {response.deletedCount} trackers exitosamente");

                // Update SettingsStateService to reset ALL tracker statuses in discovery screen
                if (SettingsStateService.ScannedTrackers?.Any() == true)
                {
                    foreach (var trackerInScanned in SettingsStateService.ScannedTrackers.Where(t => t.Id > 0))
                    {
                        // Reset to unregistered state (Id = 0)
                        trackerInScanned.Id = 0;
                        trackerInScanned.Status = "Unregistered";
                        trackerInScanned.Name = null;
                        trackerInScanned.Model = null;
                        trackerInScanned.IsOnline = false;
                    }
                }

                await LoadData(); // Reload data to reflect changes
            }
            else
            {
                await ShowErrorToast($"❌ Error eliminando los trackers: {response.message}");
            }
        }
        catch (Exception ex)
        {
            _showDeleteAllModal = false;
            await ShowErrorToast($"❌ Error: {ex.Message}");
        }
        finally
        {
            _isDeletingAll = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Cancela la eliminación de todos los trackers
    /// </summary>
    private void CancelDeleteAll()
    {
        _showDeleteAllModal = false;
        StateHasChanged();
    }

    /// <summary>
    /// Muestra un toast de éxito moderno
    /// </summary>
    private async Task ShowSuccessToast(string message)
    {
        await JSRuntime.InvokeVoidAsync("eval", $@"
            const toast = document.createElement('div');
            toast.className = 'modern-toast success';
            toast.innerHTML = '{message}';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        ");
    }

    /// <summary>
    /// Muestra un toast de error moderno
    /// </summary>
    private async Task ShowErrorToast(string message)
    {
        await JSRuntime.InvokeVoidAsync("eval", $@"
            const toast = document.createElement('div');
            toast.className = 'modern-toast error';
            toast.innerHTML = '{message}';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 5000);
        ");
    }

    /// <summary>
    /// Starts the automatic update timer
    /// </summary>
    private void StartAutoUpdate()
    {
        StopAutoUpdate(); // Stop any existing timer
        _updateTimer = new Timer(async _ => await UpdateTrackerData(), null, _updateInterval, _updateInterval);
    }

    /// <summary>
    /// Stops the automatic update timer
    /// </summary>
    private void StopAutoUpdate()
    {
        _updateTimer?.Dispose();
        _updateTimer = null;
    }

    /// <summary>
    /// Updates only tracker data without full reload - optimized for real-time updates
    /// </summary>
    private async Task UpdateTrackerData()
    {
        if (Farm == null || _farmAnimals?.Any() != true || _isLoading)
            return;

        try
        {
            // Update tracker info for each animal that has a tracker assigned
            var updateTasks = new List<Task>();

            foreach (var animal in _farmAnimals.Where(a => _animalTrackers.ContainsKey(a.Id) && _animalTrackers[a.Id] != null))
            {
                updateTasks.Add(UpdateSingleAnimalTracker(animal.Id));
            }

            await Task.WhenAll(updateTasks);

            // Update the UI on the main thread
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            // Log error but don't break the update cycle
            await JSRuntime.InvokeVoidAsync("console.warn", $"Error updating tracker data: {ex.Message}");
        }
    }

    /// <summary>
    /// Updates tracker information for a single animal
    /// </summary>
    private async Task UpdateSingleAnimalTracker(int animalId)
    {
        try
        {
            var trackerInfo = await FarmTrackerService.GetAnimalTrackerInfoAsync(animalId);
            _animalTrackers[animalId] = trackerInfo;
        }
        catch
        {
            // Keep existing data if update fails
        }
    }

    /// <summary>
    /// Carga información global de asignaciones de trackers desde todas las granjas
    /// </summary>
    private async Task LoadGlobalTrackerAssignments()
    {
        try
        {
            // Limpiar sets globales
            _globallyAssignedDeviceIds.Clear();
            _globallyAssignedCustomerTrackerIds.Clear();

            // Consultar TODOS los animales de TODAS las granjas (sin filtro de granja)
            var allAnimals = await AnimalService.GetAnimalsAsync(null); // null = todas las granjas

            if (allAnimals?.Any() == true)
            {
                foreach (var animal in allAnimals)
                {
                    try
                    {
                        var trackerInfo = await FarmTrackerService.GetAnimalTrackerInfoAsync(animal.Id);
                        if (trackerInfo != null)
                        {
                            _globallyAssignedDeviceIds.Add(trackerInfo.DeviceId);
                            _globallyAssignedCustomerTrackerIds.Add(trackerInfo.CustomerTrackerId);
                        }
                    }
                    catch
                    {
                        // Ignorar errores individuales y continuar
                    }
                }
            }

            Console.WriteLine($"DEBUG LoadGlobalTrackerAssignments: Found {_globallyAssignedDeviceIds.Count} assigned trackers globally");
            Console.WriteLine($"  Assigned Device IDs: [{string.Join(", ", _globallyAssignedDeviceIds)}]");
            Console.WriteLine($"  Assigned Customer Tracker IDs: [{string.Join(", ", _globallyAssignedCustomerTrackerIds)}]");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR in LoadGlobalTrackerAssignments: {ex.Message}");
        }
    }

    /// <summary>
    /// Obtiene la lista de trackers que NO están asignados a ningún animal GLOBALMENTE (en todas las granjas)
    /// </summary>
    private List<AvailableFarmTrackerDto> GetUnassignedTrackers()
    {
        if (_availableTrackers == null || !_availableTrackers.Any())
            return new List<AvailableFarmTrackerDto>();

        try
        {
            // USAR ASIGNACIONES GLOBALES para filtrar trackers
            // Esto garantiza que trackers asignados en cualquier granja no aparezcan como disponibles

            var globallyUnassignedTrackers = _availableTrackers
                .Where(tracker =>
                    !_globallyAssignedDeviceIds.Contains(tracker.DeviceId) &&
                    !_globallyAssignedCustomerTrackerIds.Contains(tracker.CustomerTrackerId))
                .ToList();

            // Debug logging mejorado
            Console.WriteLine($"DEBUG GetUnassignedTrackers (Farm: {Farm?.Name ?? "Unknown"}):");
            Console.WriteLine($"  Total available trackers: {_availableTrackers.Count}");
            Console.WriteLine($"  Globally assigned device IDs: [{string.Join(", ", _globallyAssignedDeviceIds)}]");
            Console.WriteLine($"  Globally assigned customer tracker IDs: [{string.Join(", ", _globallyAssignedCustomerTrackerIds)}]");
            Console.WriteLine($"  Globally unassigned trackers: {globallyUnassignedTrackers.Count}");

            foreach (var tracker in _availableTrackers)
            {
                var isGloballyAssigned = _globallyAssignedDeviceIds.Contains(tracker.DeviceId) ||
                                       _globallyAssignedCustomerTrackerIds.Contains(tracker.CustomerTrackerId);
                Console.WriteLine($"    - {tracker.DeviceId} (ID: {tracker.CustomerTrackerId}) - {(isGloballyAssigned ? "ASSIGNED GLOBALLY" : "available")}");
            }

            return globallyUnassignedTrackers;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR in GetUnassignedTrackers: {ex.Message}");
            return _availableTrackers?.ToList() ?? new List<AvailableFarmTrackerDto>();
        }
    }

    /// <summary>
    /// Implements IDisposable to clean up the timer
    /// </summary>
    public void Dispose()
    {
        StopAutoUpdate();
    }
}

